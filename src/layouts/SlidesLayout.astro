---
import "../styles/global.css";
import "reveal.js/reveal.css";
// En lugar de cargar el tema completo, lo estilizamos para que herede del portfolio
// import 'reveal.js/dist/theme/night.css';

interface Props {
    title: string;
    /** Tema claro: mismo tipo y acentos del sitio, sobre fondo blanco. */
    light?: boolean;
    /** Centrado vertical. Conviene apagarlo en decks con slides densas. */
    center?: boolean;
}

const { title, light = false, center = true } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
    </head>
    <body class={light ? "is-light" : ""}>
        <div
            class:list={[
                "reveal h-screen",
                light ? "reveal-light" : "bg-ink-950 text-ink-100",
            ]}
            data-center={String(center)}
        >
            <div class="slides">
                <slot />
            </div>
        </div>

        <script>
            import Reveal from "reveal.js";

            const root = document.querySelector<HTMLElement>(".reveal");

            Reveal.initialize({
                controls: true,
                progress: true,
                center: root?.dataset.center !== "false",
                hash: true,
                transition: "slide", // Transiciones: none/fade/slide/convex/concave/zoom
            });
        </script>

        <style is:global>
            /* Ajuste para que Reveal.js ocupe toda la pantalla correctamente en Astro */
            html,
            body {
                width: 100%;
                height: 100%;
                margin: 0;
                padding: 0;
                overflow: hidden;
            }

            /* Sobrescribir variables de Reveal.js para que use los estilos de la app */
            .reveal {
                font-family: inherit;
                font-size: 40px;
                font-weight: normal;
                color: inherit;
            }

            .reveal h1,
            .reveal h2,
            .reveal h3,
            .reveal h4,
            .reveal h5,
            .reveal h6 {
                font-family: "Instrument Serif", serif;
                font-weight: normal;
                text-transform: none;
                letter-spacing: normal;
                color: #fff;
                text-shadow: none;
            }

            .reveal h1 {
                font-size: 2.5em;
            }
            .reveal h2 {
                font-size: 1.6em;
            }
            .reveal h3 {
                font-size: 1.3em;
            }

            .reveal section img {
                background: transparent;
                border: none;
                box-shadow: none;
            }

            /* Controles y progreso estilo del sitio */
            .reveal .controls {
                color: var(--color-cyan, #00f2ff);
            }
            .reveal .progress {
                color: var(--color-cyan, #00f2ff);
            }

            /* ── Tema claro ──────────────────────────────────────────────
               La escala `ink` del sitio va de claro (50) a oscuro (950) para
               texto sobre fondo negro; aquí se usa al revés. Los acentos
               puros (cyan #00f2ff, violet #a78bff) no alcanzan contraste AA
               sobre blanco, así que el texto usa las variantes profundas y
               los tonos brillantes quedan para rellenos y bordes. */
            body.is-light {
                background: #fbfbfd;
            }

            .reveal-light {
                --slide-fg: #13131a;
                --slide-fg-muted: #4d4d5d;
                --slide-heading: #07070a;
                --slide-accent: #007a82; /* cyan-deep: AA sobre blanco */
                --slide-accent-soft: rgba(0, 242, 255, 0.09);
                --slide-violet: #5b3fc4; /* violet oscurecido para texto */
                --slide-ember: #c2410c; /* ember oscurecido para texto */
                --slide-line: rgba(7, 7, 10, 0.1);
                --slide-surface: rgba(7, 7, 10, 0.025);

                background: #fbfbfd;
                color: var(--slide-fg);
                background-image: radial-gradient(
                    rgba(7, 7, 10, 0.055) 1px,
                    transparent 1px
                );
                background-size: 22px 22px;
                background-position: -1px -1px;
            }

            .reveal-light h1,
            .reveal-light h2,
            .reveal-light h3,
            .reveal-light h4,
            .reveal-light h5,
            .reveal-light h6 {
                color: var(--slide-heading);
            }

            .reveal-light .controls {
                color: var(--slide-accent);
            }
            .reveal-light .progress {
                color: var(--slide-accent);
            }
            .reveal-light .progress span {
                background: var(--slide-accent);
            }

            .reveal-light a {
                color: var(--slide-accent);
                text-decoration: none;
                border-bottom: 1px solid var(--slide-accent-soft);
            }
            .reveal-light a:hover {
                border-bottom-color: var(--slide-accent);
            }

            .reveal-light ::selection {
                background: #00f2ff;
                color: #07070a;
            }
        </style>
    </body>
</html>

---
// Recupera y muestra los repositorios públicos recientes de GitHub.
// Se renderiza en el cliente (la API pública de GitHub no requiere token).
const username = 'mikerb95'
---

<section id="github" class="px-6 md:px-12 lg:px-20 py-24 border-t border-white/5">
  <div class="max-w-[1280px] mx-auto">
    <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
      <span class="text-cyan">/05</span>
      <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
      <span>Open source</span>
    </div>
    <h2 class="font-sans text-5xl md:text-6xl font-medium tracking-[-.03em] text-mask max-w-2xl leading-[1]">
      Actividad reciente en GitHub.
    </h2>
    <p class="mt-5 text-[15px] text-ink-200 max-w-xl">
      Explorando ideas y construyendo herramientas en público.
    </p>

    <div id="github-grid" class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6" data-username={username}>
      {Array.from({ length: 6 }).map(() => (
        <div class="h-[180px] rounded-2xl bg-white/[.02] border border-white/5 animate-pulse"></div>
      ))}
    </div>
  </div>
</section>

<script>
  type Repo = {
    id: number
    name: string
    html_url: string
    description: string | null
    language: string | null
    stargazers_count: number
    forks_count: number
    fork: boolean
  }

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
  }

  const githubIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-ink-200 group-hover:text-cyan transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`
  const starIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
  const forkIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><circle cx="12" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9"/><path d="M12 12v3"/></svg>`

  function renderRepos(repos: Repo[]) {
    const grid = document.getElementById('github-grid')!
    grid.innerHTML = repos
      .map((r) => {
        const pill = r.language
          ? `<span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-mono uppercase tracking-wider border bg-ink-800 text-ink-200 border-ink-700">${escapeHtml(r.language)}</span>`
          : ''
        return `
          <a href="${r.html_url}" target="_blank" rel="noreferrer" class="group rounded-2xl flex flex-col p-6 bg-white/[.02] hover:bg-white/[.04] border border-white/5 transition-colors h-[180px]">
            <div class="flex items-start justify-between mb-4">
              ${githubIcon}
              ${pill}
            </div>
            <h3 class="text-[17px] font-medium text-ink-50 mb-2 truncate group-hover:text-cyan transition-colors">${escapeHtml(r.name)}</h3>
            <p class="text-[13px] text-ink-300 line-clamp-2 flex-1">${escapeHtml(r.description || 'Sin descripción.')}</p>
            <div class="mt-4 flex items-center gap-4 text-[11px] font-mono text-ink-200">
              <span class="flex items-center gap-1.5">${starIcon} ${r.stargazers_count}</span>
              <span class="flex items-center gap-1.5">${forkIcon} ${r.forks_count}</span>
            </div>
          </a>`
      })
      .join('')
  }

  async function load() {
    const grid = document.getElementById('github-grid')
    if (!grid) return
    const username = grid.dataset.username
    try {
      const res = await fetch(`https://api.github.com/users/${username}/repos?per_page=12&sort=updated`)
      if (!res.ok) throw new Error('API error')
      const data: Repo[] = await res.json()
      if (!Array.isArray(data)) throw new Error('bad response')
      const repos = data.filter((r) => !r.fork).slice(0, 6)
      if (!repos.length) {
        grid.innerHTML = '<p class="text-ink-300 text-sm py-4 col-span-full">Sin repositorios públicos.</p>'
        return
      }
      renderRepos(repos)
    } catch {
      grid.innerHTML = '<p class="text-ink-300 text-sm py-4 col-span-full">No se pudo cargar la actividad de GitHub.</p>'
    }
  }

  load()
</script>

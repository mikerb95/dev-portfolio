---
import { MILESTONE_LABELS, type Milestone } from '../../lib/portal/projects'
import { daysUntil, formatDate } from '../../lib/portal/format'

interface Props {
  milestones: Milestone[]
}

const { milestones } = Astro.props
const now = new Date()

// Un hito vencido y sin completar es la información más valiosa de esta vista:
// es exactamente lo que el cliente quiere saber y lo que un panel complaciente
// escondería.
const isLate = (m: Milestone) => m.status !== 'completado' && m.dueAt != null && daysUntil(m.dueAt, now)! < 0
---

{
  milestones.length === 0 ? (
    <p class="text-[13px] text-ink-300">Todavía no hay hitos definidos para este proyecto.</p>
  ) : (
    <ol class="relative">
      {milestones.map((m, i) => {
        const late = isLate(m)
        const days = daysUntil(m.dueAt, now)
        return (
          <li class="relative pl-7 pb-6 last:pb-0">
            {/* Línea vertical: no la dibuja el último para no dejar un rabo suelto */}
            {i < milestones.length - 1 && (
              <span class="absolute left-[7px] top-[18px] bottom-0 w-px bg-white/10" aria-hidden="true" />
            )}

            <span
              class:list={[
                'absolute left-0 top-[5px] w-[15px] h-[15px] rounded-full border-2 grid place-items-center',
                m.status === 'completado'
                  ? 'bg-lime/20 border-lime'
                  : m.status === 'en_curso'
                    ? 'bg-cyan/20 border-cyan'
                    : late
                      ? 'bg-ember/20 border-ember'
                      : 'bg-ink-800 border-white/20',
              ]}
              aria-hidden="true"
            >
              {m.status === 'completado' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#c9ff5b" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              )}
              {m.status === 'en_curso' && <span class="w-1.5 h-1.5 rounded-full bg-cyan pulse-dot" />}
            </span>

            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <h4
                class:list={[
                  'text-[14px] font-medium',
                  m.status === 'completado' ? 'text-ink-100' : 'text-ink-50',
                ]}
              >
                {m.title}
              </h4>
              <span
                class:list={[
                  'px-1.5 py-0.5 rounded text-[10px] font-mono uppercase tracking-wider',
                  m.status === 'completado'
                    ? 'bg-lime/10 text-lime'
                    : m.status === 'en_curso'
                      ? 'bg-cyan/10 text-cyan'
                      : late
                        ? 'bg-ember/10 text-ember'
                        : 'bg-white/[.04] text-ink-300',
                ]}
              >
                {late ? 'Retrasado' : MILESTONE_LABELS[m.status]}
              </span>
            </div>

            {m.description && (
              <p class="mt-1 text-[12.5px] leading-relaxed text-ink-200 max-w-[60ch]">{m.description}</p>
            )}

            <p class="mt-1.5 text-[11px] font-mono text-ink-300">
              {m.status === 'completado' && m.completedAt
                ? `Completado el ${formatDate(m.completedAt)}`
                : m.dueAt
                  ? late
                    ? `Previsto para el ${formatDate(m.dueAt)} · ${Math.abs(days!)} día${Math.abs(days!) !== 1 ? 's' : ''} de retraso`
                    : `Previsto para el ${formatDate(m.dueAt)}${days === 0 ? ' · hoy' : days != null && days <= 7 ? ` · en ${days} día${days !== 1 ? 's' : ''}` : ''}`
                  : 'Sin fecha definida'}
            </p>
          </li>
        )
      })}
    </ol>
  )
}

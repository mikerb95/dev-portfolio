---
interface Cert {
  id: number
  title: string
  institution: string | null
  description: string | null
  skills: string | null
  status: string | null
  completedDate: Date | null
  certificateUrl: string | null
}

interface Props {
  cert: Cert
}

const { cert } = Astro.props

const skills: string[] = cert.skills ? JSON.parse(cert.skills) : []

const statusStyle: Record<string, string> = {
  completado: 'text-emerald-600 bg-emerald-50 dark:text-emerald-400 dark:bg-emerald-900/20',
  en_curso: 'text-brand-600 bg-brand-50 dark:text-brand-400 dark:bg-brand-900/20',
  pausado: 'text-slate-500 bg-slate-100 dark:text-slate-400 dark:bg-slate-800',
}

const statusLabel: Record<string, string> = {
  completado: 'Completado',
  en_curso: 'En curso',
  pausado: 'Pausado',
}

const isImage = cert.certificateUrl && (
  !cert.certificateUrl.startsWith('http') ||
  (cert.certificateUrl?.match(/\.(png|jpg|jpeg|webp|gif|svg)(\?.*)?$/i) ?? false)
)
---

<div class="border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden bg-white dark:bg-slate-900/30 flex flex-col hover:border-brand-500/40 dark:hover:border-brand-500/20 transition-colors">
  {cert.certificateUrl && isImage && (
    <a
      href={cert.certificateUrl}
      target="_blank"
      rel="noopener"
      class="block overflow-hidden bg-slate-100 dark:bg-slate-800 border-b border-slate-200 dark:border-slate-800 aspect-[16/9]"
    >
      <img
        src={cert.certificateUrl}
        alt={`Certificado: ${cert.title}`}
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </a>
  )}

  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-start justify-between gap-3 mb-2">
      <h3 class="font-semibold text-slate-900 dark:text-slate-100 leading-snug">{cert.title}</h3>
      <span class={`text-xs px-2 py-0.5 rounded-full font-medium shrink-0 ${statusStyle[cert.status ?? 'completado']}`}>
        {statusLabel[cert.status ?? 'completado']}
      </span>
    </div>

    {cert.institution && (
      <p class="text-slate-500 dark:text-slate-500 text-sm mb-2">{cert.institution}</p>
    )}

    {cert.description && (
      <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-3">{cert.description}</p>
    )}

    {skills.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4 mt-auto pt-3">
        {skills.map((s) => (
          <span class="text-xs px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-full">{s}</span>
        ))}
      </div>
    )}

    <div class="flex items-center justify-between mt-auto pt-3 border-t border-slate-100 dark:border-slate-800">
      {cert.completedDate ? (
        <span class="text-xs text-slate-400 dark:text-slate-600">
          {cert.completedDate.toLocaleDateString('es-CO', { year: 'numeric', month: 'long' })}
        </span>
      ) : <span />}

      {cert.certificateUrl && !isImage && (
        <a
          href={cert.certificateUrl}
          target="_blank"
          rel="noopener"
          class="text-xs text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
        >
          Ver certificado →
        </a>
      )}
      {cert.certificateUrl && isImage && (
        <a
          href={cert.certificateUrl}
          target="_blank"
          rel="noopener"
          class="text-xs text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors"
        >
          Ver imagen →
        </a>
      )}
    </div>
  </div>
</div>

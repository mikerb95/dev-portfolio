---
const year = new Date().getFullYear()

const links = [
  { href: '/', label: 'Inicio' },
  { href: '/certifications', label: 'Certificaciones' },
  { href: '/log', label: 'Engineering Log' },
  { href: '/contact', label: 'Contacto' },
]
---

<footer class="mt-32 border-t border-slate-200/60 dark:border-slate-800/60 bg-white/40 dark:bg-[#0f1419]/40 backdrop-blur">
  <div class="mx-auto max-w-5xl px-6 py-16 grid gap-12 md:grid-cols-3 text-sm">
    <div class="md:col-span-2 space-y-4">
      <div>
        <span class="text-lg font-semibold tracking-tight bg-gradient-to-r from-slate-900 via-slate-700 to-slate-900/70 dark:from-white dark:via-slate-200 dark:to-white/70 bg-clip-text text-transparent">
          CodeByMike
        </span>
      </div>
      <p class="text-slate-600 dark:text-slate-400 leading-relaxed max-w-md text-[13px]">
        Ingeniería de software enfocada en rendimiento, arquitectura escalable y experiencias de usuario con valor tangible.
      </p>
      <div class="flex items-center gap-4 pt-2">
        <a
          href="https://github.com/mikerb95"
          target="_blank"
          rel="noopener"
          aria-label="GitHub"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-300/70 dark:border-slate-700/70 bg-white/70 dark:bg-slate-900/40 hover:border-brand-500/50 hover:text-brand-600 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/mdrb95/"
          target="_blank"
          rel="noopener"
          aria-label="LinkedIn"
          class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-300/70 dark:border-slate-700/70 bg-white/70 dark:bg-slate-900/40 hover:border-brand-500/50 hover:text-brand-600 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect width="4" height="12" x="2" y="9"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="space-y-4">
      <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Sitio</h3>
      <ul class="space-y-2 text-slate-600 dark:text-slate-400">
        {links.map((link) => (
          <li>
            <a href={link.href} class="hover:text-slate-900 dark:hover:text-slate-200 transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-200/60 dark:border-slate-800/60">
    <div class="mx-auto max-w-5xl px-6 py-6 text-[12px] flex flex-col md:flex-row items-center gap-4 justify-between text-slate-500 dark:text-slate-500">
      <span>© {year} CodeByMike. Algunos derechos reservados.</span>
      <span class="text-[11px]">Construido con Astro, Tailwind CSS & Drizzle ORM.</span>
    </div>
  </div>
</footer>

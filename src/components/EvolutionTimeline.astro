---
interface Milestone {
  id: number
  title: string
  institution: string | null
  description: string | null
  skills: string | null
  status: string | null
  startDate: Date | null
  completedDate: Date | null
  certificateUrl: string | null
  projectId: number | null
  projectTitle: string | null
  projectSlug: string | null
}

interface Props {
  milestones: Milestone[]
}

const { milestones } = Astro.props

const statusColors: Record<string, string> = {
  completado: 'bg-emerald-500',
  en_curso: 'bg-amber-400',
  pausado: 'bg-zinc-600',
}

const statusLabels: Record<string, string> = {
  completado: 'Completado',
  en_curso: 'En curso',
  pausado: 'Pausado',
}

const fmt = new Intl.DateTimeFormat('es', { year: 'numeric', month: 'short' })
---

{milestones.length > 0 && (
  <section>
    <h2 class="text-sm font-semibold text-zinc-400 uppercase tracking-wide mb-6">
      Evolution Path
    </h2>

    <ol class="relative border-l border-zinc-800 space-y-8 pl-6">
      {milestones.map((m) => {
        const skills: string[] = m.skills ? JSON.parse(m.skills) : []
        const dot = statusColors[m.status ?? 'en_curso'] ?? 'bg-zinc-600'
        const dateLabel = m.completedDate
          ? fmt.format(m.completedDate)
          : m.startDate
          ? fmt.format(m.startDate)
          : null

        return (
          <li class="relative">
            <span class={`absolute -left-[1.65rem] top-1.5 w-3 h-3 rounded-full border-2 border-zinc-950 ${dot}`} />

            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <span class="text-xs text-zinc-500">{statusLabels[m.status ?? 'en_curso']}</span>
                  {m.institution && (
                    <span class="text-xs text-zinc-600">· {m.institution}</span>
                  )}
                  {dateLabel && (
                    <span class="text-xs text-zinc-600">· {dateLabel}</span>
                  )}
                </div>

                <h3 class="text-white font-semibold leading-snug">{m.title}</h3>

                {m.description && (
                  <p class="text-zinc-400 text-sm mt-1">{m.description}</p>
                )}

                {skills.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-2">
                    {skills.map((s) => (
                      <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-300 rounded-md">{s}</span>
                    ))}
                  </div>
                )}

                {m.projectSlug && m.projectTitle && (
                  <p class="mt-2 text-xs">
                    <span class="text-zinc-600">Aplicado en → </span>
                    <a
                      href={`/projects/${m.projectSlug}`}
                      class="text-blue-400 hover:text-blue-300 transition-colors hover:underline"
                    >
                      {m.projectTitle}
                    </a>
                  </p>
                )}
              </div>

              {m.certificateUrl && (
                <a
                  href={m.certificateUrl}
                  target="_blank"
                  rel="noopener"
                  class="text-xs px-3 py-1.5 border border-zinc-700 rounded-lg text-zinc-400 hover:text-white hover:border-zinc-500 transition-colors shrink-0"
                >
                  Ver certificado ↗
                </a>
              )}
            </div>
          </li>
        )
      })}
    </ol>
  </section>
)}

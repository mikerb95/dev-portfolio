---
const currentPath = Astro.url.pathname

const navLinks = [
  { href: '/certifications', label: 'Certificaciones' },
  { href: '/log', label: 'Log' },
  { href: '/contact', label: 'Contacto' },
]
---

<header class="fixed top-4 inset-x-4 z-50 max-w-[1280px] mx-auto" aria-label="Navegación">
  <div class="glass-strong rounded-full pl-5 pr-2 py-2 flex items-center justify-between">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-3 select-none">
      <div class="w-7 h-7 rounded-full bg-gradient-to-br from-cyan to-violet shadow-[0_0_18px_rgba(0,242,255,.5)]"></div>
      <span class="font-mono text-[12px] tracking-[.2em] uppercase text-ink-50">
        Code<span class="text-cyan">By</span>Mike
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1 text-[12px] font-mono text-ink-100">
      {navLinks.map((link) => {
        const isActive = currentPath.startsWith(link.href)
        return (
          <a
            href={link.href}
            class={`px-3 py-2 rounded-full transition-colors hover:bg-white/5 ${isActive ? 'text-cyan' : 'text-ink-100'}`}
          >
            {link.label}
          </a>
        )
      })}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <span class="hidden md:flex items-center gap-2 text-[11px] font-mono text-ink-200 pr-2">
        <span class="w-1.5 h-1.5 rounded-full bg-lime pulse-dot"></span>
        Disponible
      </span>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 h-8 px-3 text-[12px] font-medium rounded-full bg-cyan text-ink-950 hover:brightness-110 transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
        Contáctame
      </a>
    </div>
  </div>
</header>

---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/tools", label: "Herramientas" },
  { href: "/engineering", label: "Ingeniería" },
  { href: "/lab", label: "Lab" },
  { href: "/notes", label: "Notas" },
  { href: "/security", label: "Seguridad" },
  { href: "/log", label: "Log" },
];
---

<header
  class="fixed top-4 inset-x-4 z-50 max-w-[1280px] mx-auto"
  aria-label="Navegación"
>
  <div
    class="glass-strong rounded-full pl-5 pr-2 py-2 flex items-center justify-between shadow-[0_8px_32px_rgba(0,0,0,.55)]"
  >
    <!-- Brand -->
    <a href="/" class="flex items-center gap-3 select-none">
      <img
        src="https://github.com/mikerb95.png"
        alt="Mike (@mikerb95)"
        width="28"
        height="28"
        loading="eager"
        referrerpolicy="no-referrer"
        class="w-7 h-7 rounded-full object-cover shadow-[0_0_18px_rgba(0,242,255,.5)]"
      />
      <span class="font-mono text-[12px] tracking-[.2em] uppercase text-ink-50">
        Code<span class="text-cyan">By</span>Mike
      </span>
    </a>

    <!-- Desktop nav -->
    <nav
      class="hidden lg:flex items-center gap-1 text-[12px] font-mono text-ink-100"
    >
      {
        navLinks.map((link) => {
          const isActive = currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              class={`px-3 py-2 rounded-full transition-colors hover:bg-white/5 ${isActive ? "text-cyan" : "text-ink-100"}`}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <span
        class="hidden lg:flex items-center gap-2 text-[11px] font-mono text-ink-200 pr-2"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-lime pulse-dot"></span>
        Disponible
      </span>
      <a
        href="/login?callbackUrl=%2Fentrar"
        aria-label="Login"
        class="inline-flex items-center gap-2 h-8 px-3 text-[12px] font-medium rounded-full bg-white/5 text-ink-100 hover:bg-white/10 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6.1 0-1.3-.5-2.4-1.3-3.2.1-.3.5-1.5-.1-3.2 0 0-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1c-.6 1.7-.2 2.9-.1 3.2A4.9 4.9 0 0 0 4 9.9c0 4.7 2.7 5.8 5.5 6.1-.6.5-1 1.4-1 2.8V21"
          ></path>
        </svg>
        <span class="hidden lg:inline">Login</span>
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 h-8 px-3 text-[12px] font-medium rounded-full bg-cyan text-ink-950 hover:brightness-110 transition-all"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
        Contáctame
      </a>

      <!-- Mobile menu button -->
      <button
        id="navbar-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="navbar-mobile-panel"
        aria-label="Abrir menú"
        class="lg:hidden inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/5 text-ink-100 hover:bg-white/10 transition-colors"
      >
        <svg
          id="navbar-toggle-icon-open"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="navbar-toggle-icon-close"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden"
        >
          <path d="M18 6 6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div
    id="navbar-mobile-panel"
    class="hidden lg:hidden glass-strong rounded-3xl mt-2 p-3 flex flex-col gap-1"
  >
    {
      navLinks.map((link) => {
        const isActive = currentPath.startsWith(link.href);
        return (
          <a
            href={link.href}
            class={`px-4 py-2.5 rounded-full text-[13px] font-mono transition-colors hover:bg-white/5 ${isActive ? "text-cyan" : "text-ink-100"}`}
          >
            {link.label}
          </a>
        );
      })
    }
    <div class="h-px bg-white/10 my-1"></div>
    <span
      class="flex items-center gap-2 px-4 py-2 text-[12px] font-mono text-ink-200"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-lime pulse-dot"></span>
      Disponible
    </span>
  </div>
</header>

<script>
  const toggle = document.getElementById("navbar-toggle");
  const panel = document.getElementById("navbar-mobile-panel");
  const iconOpen = document.getElementById("navbar-toggle-icon-open");
  const iconClose = document.getElementById("navbar-toggle-icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = panel?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");
    iconOpen?.classList.toggle("hidden", isOpen);
    iconClose?.classList.toggle("hidden", !isOpen);
  });

  panel?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      panel.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Abrir menú");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>

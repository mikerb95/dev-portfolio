---
// Renders client-side — does not block SSR
---

<section class="mt-20 border-t border-slate-200/60 dark:border-slate-800/60 pt-16">
  <div class="flex items-start justify-between mb-8 gap-6">
    <div>
      <h2 class="text-lg font-semibold mb-1 text-slate-900 dark:text-white">Engineering Activity</h2>
      <p class="text-slate-500 dark:text-slate-500 text-sm">Actividad de desarrollo en tiempo real extraída de GitHub.</p>
    </div>
    <a href="/log" class="text-xs text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors shrink-0 mt-1">
      Ver registro completo
    </a>
  </div>

  <div id="activity-stats" class="grid grid-cols-3 gap-3 mb-8">
    <div class="border border-slate-200 dark:border-slate-800 rounded-lg px-4 py-3 bg-white/50 dark:bg-slate-900/20">
      <p class="text-slate-400 dark:text-slate-600 text-xs mb-1">Deep Work · 7 días</p>
      <p class="text-xl font-semibold text-slate-900 dark:text-white" id="stat-week-hours">—</p>
      <p class="text-slate-400 dark:text-slate-600 text-xs">horas de trabajo profundo</p>
    </div>
    <div class="border border-slate-200 dark:border-slate-800 rounded-lg px-4 py-3 bg-white/50 dark:bg-slate-900/20">
      <p class="text-slate-400 dark:text-slate-600 text-xs mb-1">Commits · 30 días</p>
      <p class="text-xl font-semibold text-slate-900 dark:text-white" id="stat-commits">—</p>
      <p class="text-slate-400 dark:text-slate-600 text-xs">contribuciones recientes</p>
    </div>
    <div class="border border-slate-200 dark:border-slate-800 rounded-lg px-4 py-3 bg-white/50 dark:bg-slate-900/20">
      <p class="text-slate-400 dark:text-slate-600 text-xs mb-1">Racha activa</p>
      <p class="text-xl font-semibold text-slate-900 dark:text-white" id="stat-streak">—</p>
      <p class="text-slate-400 dark:text-slate-600 text-xs">días consecutivos</p>
    </div>
  </div>

  <div class="mb-6 flex items-end gap-0.5 h-8" id="sparkline" aria-hidden="true"></div>

  <div id="activity-feed" class="flex flex-col divide-y divide-slate-100 dark:divide-slate-800/50">
    {Array.from({ length: 5 }).map(() => (
      <div class="py-3 flex gap-3 animate-pulse">
        <div class="w-24 h-3 bg-slate-200 dark:bg-slate-800 rounded mt-0.5"></div>
        <div class="flex-1 h-3 bg-slate-100 dark:bg-slate-800/60 rounded"></div>
      </div>
    ))}
  </div>
</section>

<script>
  type FeedItem = {
    repo: string
    repoFull: string
    message: string
    sha: string
    timestamp: string
    type: 'commit' | 'pr_merged'
  }

  type ActivityData = {
    feed: FeedItem[]
    deepWork: { weekHours: number; monthHours: number; sessions: number }
    streak: number
    totalCommits: number
    sparkline: number[]
  }

  function relativeTime(iso: string): string {
    const diff = (Date.now() - new Date(iso).getTime()) / 1000
    if (diff < 3600) return `hace ${Math.floor(diff / 60)}m`
    if (diff < 86400) return `hace ${Math.floor(diff / 3600)}h`
    if (diff < 86400 * 7) return `hace ${Math.floor(diff / 86400)}d`
    return new Date(iso).toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })
  }

  function renderSparkline(data: number[]) {
    const el = document.getElementById('sparkline')!
    const max = Math.max(...data, 1)
    const isDark = document.documentElement.classList.contains('dark')
    el.innerHTML = data
      .map((v, i) => {
        const pct = Math.round((v / max) * 100)
        const isToday = i === data.length - 1
        const color = isToday
          ? (isDark ? 'bg-white' : 'bg-slate-900')
          : v > 0
            ? (isDark ? 'bg-slate-500' : 'bg-slate-400')
            : (isDark ? 'bg-slate-800' : 'bg-slate-200')
        return `<div class="flex-1 ${color} rounded-sm transition-all" style="height:${Math.max(pct, 4)}%" title="${v} commits"></div>`
      })
      .join('')
  }

  function renderFeed(items: FeedItem[]) {
    const el = document.getElementById('activity-feed')!

    if (!items.length) {
      el.innerHTML = '<p class="text-slate-400 dark:text-slate-600 text-sm py-4">Sin actividad reciente.</p>'
      return
    }

    const groups: Record<string, FeedItem[]> = {}
    for (const item of items) {
      const day = new Date(item.timestamp).toLocaleDateString('es-CO', {
        weekday: 'long',
        day: 'numeric',
        month: 'long',
      })
      if (!groups[day]) groups[day] = []
      groups[day].push(item)
    }

    el.innerHTML = Object.entries(groups)
      .map(([day, commits]) => {
        const rows = commits
          .map((c) => {
            const badge =
              c.type === 'pr_merged'
                ? `<span class="text-purple-500 dark:text-purple-400 text-xs shrink-0">PR merged</span>`
                : `<span class="font-mono text-slate-400 dark:text-slate-600 text-xs shrink-0">${c.sha}</span>`

            const repoTag = `<span class="text-slate-400 dark:text-slate-500 text-xs shrink-0 hidden sm:inline">${c.repo}</span>`

            return `
              <div class="py-2.5 flex items-baseline gap-3">
                ${badge}
                <span class="text-slate-700 dark:text-slate-300 text-sm leading-snug flex-1 min-w-0">${escapeHtml(c.message)}</span>
                ${repoTag}
                <span class="text-slate-400 dark:text-slate-600 text-xs shrink-0">${relativeTime(c.timestamp)}</span>
              </div>`
          })
          .join('')

        return `
          <div class="py-1">
            <p class="text-xs font-medium text-slate-400 dark:text-slate-600 uppercase tracking-wide py-2 capitalize">${day}</p>
            <div class="divide-y divide-slate-100 dark:divide-slate-800/40">${rows}</div>
          </div>`
      })
      .join('')
  }

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
  }

  async function load() {
    try {
      const res = await fetch('/api/github/activity')
      if (!res.ok) throw new Error('API error')
      const data: ActivityData = await res.json()

      document.getElementById('stat-week-hours')!.textContent = `${data.deepWork.weekHours}h`
      document.getElementById('stat-commits')!.textContent = String(data.totalCommits)
      document.getElementById('stat-streak')!.textContent = `${data.streak} días`

      renderSparkline(data.sparkline)
      renderFeed(data.feed.slice(0, 12))
    } catch {
      document.getElementById('activity-feed')!.innerHTML =
        '<p class="text-slate-400 dark:text-slate-700 text-sm py-4">No se pudo cargar la actividad.</p>'
    }
  }

  load()
</script>

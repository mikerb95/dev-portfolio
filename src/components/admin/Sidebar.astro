---
const links = [
  { href: '/admin',                icon: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10', label: 'Dashboard' },
  { href: '/admin/projects',       icon: 'M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7z M8 7v10 M12 7v10', label: 'Proyectos' },
  { href: '/admin/repos',          icon: 'M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4 M9 18c-4.51 2-5-2-7-2', label: 'Repositorios' },
  { href: '/admin/messages',       icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6', label: 'Mensajes' },
  { href: '/admin/clients',        icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75 M9 7m-4 0a4 4 0 1 0 8 0 4 4 0 0 0-8 0', label: 'Clientes' },
  { href: '/admin/briefings',      icon: 'M9 12h6 M9 16h6 M17 3H7a2 2 0 0 0-2 2v16l3-3 2 2 2-2 2 2 2-2 3 3V5a2 2 0 0 0-2-2z', label: 'Briefings' },
  { href: '/admin/finances',       icon: 'M12 1v22 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6', label: 'Finanzas' },
  { href: '/admin/certifications', icon: 'M12 15a7 7 0 1 0 0-14 7 7 0 0 0 0 14z M8.21 13.89L7 23l5-3 5 3-1.21-9.12', label: 'Certificaciones' },
  { href: '/admin/education',      icon: 'M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5', label: 'Evolution Path' },
  { href: '/admin/backup',         icon: 'M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4 M17 8l-5-5-5 5 M12 3v12', label: 'Backups' },
]

const current = Astro.url.pathname
---

<aside class="w-[240px] shrink-0 border-r border-white/5 bg-ink-900/60 backdrop-blur-xl flex flex-col min-h-screen">
  <!-- Brand -->
  <div class="px-5 py-5 flex items-center gap-3 border-b border-white/5">
    <div class="w-7 h-7 rounded-full bg-gradient-to-br from-cyan to-violet shadow-[0_0_18px_rgba(0,242,255,.5)]"></div>
    <div>
      <div class="font-mono text-[12px] tracking-[.2em] uppercase leading-none text-ink-50">
        Code<span class="text-cyan">By</span>Mike
      </div>
      <div class="text-[9.5px] font-mono uppercase tracking-[.2em] text-ink-300 mt-1">workspace</div>
    </div>
  </div>

  <!-- Nav -->
  <nav class="px-3 mt-4 flex-1 space-y-0.5">
    <div class="px-2 text-[10px] font-mono uppercase tracking-[.22em] text-ink-300 mb-2">Workspace</div>
    {links.map((l) => {
      const isActive = l.href === '/admin' ? current === '/admin' : current.startsWith(l.href)
      return (
        <a
          href={l.href}
          class={`w-full flex items-center gap-3 px-3 py-2 rounded-lg text-[13px] transition-colors ${
            isActive
              ? 'bg-cyan/10 text-cyan border border-cyan/20'
              : 'text-ink-100 hover:bg-white/5 border border-transparent'
          }`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d={l.icon} />
          </svg>
          {l.label}
        </a>
      )
    })}
  </nav>

  <!-- Footer -->
  <div class="p-3 border-t border-white/5">
    <div class="rounded-xl glass p-3 mb-3">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-gradient-to-br from-cyan to-violet flex items-center justify-center text-ink-950 text-[12px] font-medium shrink-0">M</div>
        <div class="min-w-0">
          <div class="text-[12.5px] text-ink-50 truncate">Mike</div>
          <div class="text-[10px] font-mono text-ink-300 truncate">admin</div>
        </div>
      </div>
    </div>
    <a
      href="/api/auth/signout"
      class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-[12px] text-ink-200 hover:bg-white/5 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" x2="9" y1="12" y2="12"/>
      </svg>
      Cerrar sesión
    </a>
  </div>
</aside>

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/admin" ? current === "/admin" : current.startsWith(href);
---

<aside
  class="fixed inset-y-0 left-0 z-50 w-[264px] -translate-x-full transition-transform duration-300 ease-out peer-checked:translate-x-0 lg:static lg:translate-x-0 lg:w-[240px] shrink-0 border-r border-white/5 bg-ink-900/95 lg:bg-ink-900/60 backdrop-blur-xl flex flex-col min-h-screen overflow-y-auto no-scrollbar"
>
  <!-- Brand + cerrar (móvil) -->
  <div
    class="px-5 py-5 flex items-center justify-between gap-3 border-b border-white/5 sticky top-0 bg-ink-900/95 lg:bg-transparent z-10"
  >
    <div class="flex items-center gap-3 min-w-0">
      <img
        src="https://github.com/mikerb95.png"
        alt="Mike (@mikerb95)"
        width="28"
        height="28"
        loading="eager"
        referrerpolicy="no-referrer"
        class="w-7 h-7 rounded-full object-cover shadow-[0_0_18px_rgba(0,242,255,.5)] shrink-0"
      />
      <div class="min-w-0">
        <div
          class="font-mono text-[12px] tracking-[.2em] uppercase leading-none text-ink-50"
        >
          Code<span class="text-cyan">By</span>Mike
        </div>
        <div
          class="text-[9.5px] font-mono uppercase tracking-[.2em] text-ink-300 mt-1"
        >
          workspace
        </div>
      </div>
    </div>
    <label
      for="nav-toggle"
      class="lg:hidden shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-lg text-ink-200 hover:bg-white/5 cursor-pointer transition-colors"
      aria-label="Cerrar menú"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg
      >
    </label>
  </div>

  <!-- Nav agrupada -->
  <nav class="px-3 mt-3 flex-1 space-y-4">
    {
      groups.map((g) => (
        <div>
          <div class="px-2 text-[10px] font-mono uppercase tracking-[.22em] text-ink-300 mb-1.5">
            {g.title}
          </div>
          <div class="space-y-0.5">
            {g.links.map((l) => (
              <a
                href={l.href}
                class={`w-full flex items-center gap-3 px-3 py-2 rounded-lg text-[13px] transition-colors ${
                  isActive(l.href)
                    ? "bg-cyan/10 text-cyan border border-cyan/20"
                    : "text-ink-100 hover:bg-white/5 border border-transparent"
                }`}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="shrink-0"
                >
                  <path d={l.icon} />
                </svg>
                {l.label}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </nav>

  <!-- Footer -->
  <div
    class="p-3 border-t border-white/5 sticky bottom-0 bg-ink-900/95 lg:bg-transparent"
  >
    <div class="rounded-xl glass p-3 mb-3">
      <div class="flex items-center gap-3">
        <img
          src="https://github.com/mikerb95.png"
          alt="Mike (@mikerb95)"
          width="36"
          height="36"
          loading="eager"
          referrerpolicy="no-referrer"
          class="w-9 h-9 rounded-full object-cover shrink-0"
        />
        <div class="min-w-0">
          <div class="text-[12.5px] text-ink-50 truncate">Mike</div>
          <div class="text-[10px] font-mono text-ink-300 truncate">admin</div>
        </div>
      </div>
    </div>
    <a
      href="/api/auth/signout"
      class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-[12px] text-ink-200 hover:bg-white/5 transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
        <polyline points="16 17 21 12 16 7"></polyline>
        <line x1="21" x2="9" y1="12" y2="12"></line>
      </svg>
      Cerrar sesión
    </a>
  </div>
</aside>

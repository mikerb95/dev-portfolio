---
interface Message {
  id: number
  name: string
  email: string
  subject?: string | null
  body: string
  read: boolean | null
  createdAt?: Date | null
}

interface Props {
  messages: Message[]
}

const { messages } = Astro.props
---

<div class="flex flex-col gap-3">
  {messages.map((m) => (
    <div class={`p-4 rounded-lg border ${m.read ? 'border-zinc-800 bg-zinc-900/50' : 'border-zinc-700 bg-zinc-900'}`}>
      <div class="flex items-start justify-between gap-4 mb-2">
        <div>
          <span class="font-medium text-white">{m.name}</span>
          <span class="text-zinc-400 text-sm ml-2">{m.email}</span>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          {!m.read && (
            <span class="text-xs px-2 py-0.5 bg-blue-900/50 text-blue-300 rounded-full">nuevo</span>
          )}
          {m.createdAt && (
            <span class="text-xs text-zinc-500">{m.createdAt.toLocaleDateString('es-AR')}</span>
          )}
        </div>
      </div>
      {m.subject && <p class="text-sm font-medium text-zinc-300 mb-1">{m.subject}</p>}
      <p class="text-sm text-zinc-400 line-clamp-3">{m.body}</p>
    </div>
  ))}
</div>

---
interface Message {
  id: number
  name: string
  email: string
  subject?: string | null
  body: string
  read: boolean | null
  createdAt?: Date | null
}

interface Props {
  messages: Message[]
}

const { messages } = Astro.props
---

<div class="rounded-2xl glass overflow-hidden">
  <div class="grid grid-cols-[1fr_1fr_2fr_.8fr] gap-4 px-5 py-3 border-b border-white/5 text-[10px] font-mono uppercase tracking-[.18em] text-ink-300">
    <span>Remitente</span><span>Email</span><span>Asunto / Mensaje</span><span class="text-right">Fecha</span>
  </div>

  {messages.length === 0 && (
    <div class="px-5 py-10 text-center text-[12px] font-mono text-ink-300">No hay mensajes todavía.</div>
  )}

  {messages.map((m) => (
    <div class={`grid grid-cols-[1fr_1fr_2fr_.8fr] gap-4 px-5 py-3.5 border-b border-white/[.03] hover:bg-white/[.02] items-start ${!m.read ? 'bg-cyan/[.02]' : ''}`}>
      <div class="flex items-center gap-2 min-w-0">
        {!m.read && <span class="w-1.5 h-1.5 rounded-full bg-cyan pulse-dot shrink-0"></span>}
        {m.read && <span class="w-1.5 h-1.5 rounded-full bg-ink-600 shrink-0"></span>}
        <span class="text-[13px] text-ink-50 font-medium truncate">{m.name}</span>
      </div>
      <div class="text-[12px] font-mono text-ink-300 truncate">{m.email}</div>
      <div class="min-w-0">
        {m.subject && <div class="text-[13px] text-ink-100 truncate mb-0.5">{m.subject}</div>}
        <p class="text-[12px] text-ink-300 line-clamp-2 leading-relaxed">{m.body}</p>
      </div>
      <div class="text-[10.5px] font-mono text-ink-300 text-right">
        {m.createdAt ? m.createdAt.toLocaleDateString('es-CO', { day: 'numeric', month: 'short' }) : '—'}
      </div>
    </div>
  ))}
</div>

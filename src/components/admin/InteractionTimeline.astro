---
// Timeline de interacciones (presentacional). Recibe filas con etiquetas listas.
export interface TimelineRow {
  id: number
  type: string
  typeLabel: string
  typeIcon: string
  occurredLabel: string
  title: string
  body: string | null
  projectTitle: string | null
  clientName: string | null
  nextAction: string | null
  dueLabel: string | null
  dueState: 'overdue' | 'soon' | 'ok' | null
  done: boolean
}

const { rows } = Astro.props as { rows: TimelineRow[] }

const typeTone: Record<string, string> = {
  call: 'text-cyan border-cyan/30 bg-cyan/10',
  meeting: 'text-violet border-violet/30 bg-violet/10',
  email: 'text-lime border-lime/30 bg-lime/10',
  whatsapp: 'text-lime border-lime/30 bg-lime/10',
  note: 'text-ink-100 border-white/15 bg-white/5',
  task: 'text-ember border-ember/30 bg-ember/10',
  other: 'text-ink-100 border-white/15 bg-white/5',
}
const dueTone: Record<string, string> = {
  overdue: 'text-ember',
  soon: 'text-violet',
  ok: 'text-ink-300',
}
---

{rows.length === 0 && (
  <div class="rounded-2xl glass px-5 py-10 text-center text-[12px] font-mono text-ink-300">
    No hay interacciones registradas.
  </div>
)}

<div class="space-y-2.5">
  {rows.map((r) => (
    <div class={`rounded-2xl glass p-4 ${r.done ? 'opacity-60' : ''}`}>
      <div class="flex items-start gap-3">
        <span class={`shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-lg border ${typeTone[r.type] ?? typeTone.other}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d={r.typeIcon} /></svg>
        </span>
        <div class="flex-1 min-w-0">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="text-[13.5px] text-ink-50 font-medium truncate">{r.title}</div>
              <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-[10.5px] font-mono text-ink-300 mt-0.5">
                <span>{r.typeLabel}</span>
                <span class="text-ink-500">·</span>
                <span>{r.occurredLabel}</span>
                {r.projectTitle && <><span class="text-ink-500">·</span><span class="truncate text-cyan/80">{r.projectTitle}</span></>}
                {r.clientName && <><span class="text-ink-500">·</span><span class="truncate">{r.clientName}</span></>}
              </div>
            </div>
            <div class="flex items-center gap-1 shrink-0">
              <button data-edit-int={r.id} class="edit-int text-ink-300 hover:text-cyan p-1" aria-label="Editar">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
              </button>
              <button data-del-int={r.id} class="del-int text-ink-300 hover:text-ember p-1" aria-label="Eliminar">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
              </button>
            </div>
          </div>

          {r.body && <p class="text-[12.5px] text-ink-100 mt-2 whitespace-pre-wrap break-words">{r.body}</p>}

          {(r.nextAction || r.dueLabel) && (
            <div class="mt-2.5 flex items-center justify-between gap-3 rounded-lg bg-white/[.03] border border-white/8 px-3 py-2">
              <div class="min-w-0 text-[12px]">
                <span class="text-ink-300 font-mono text-[10px] uppercase tracking-wider mr-2">Próx.</span>
                <span class="text-ink-100">{r.nextAction ?? '—'}</span>
                {r.dueLabel && <span class={`ml-2 font-mono text-[11px] ${r.done ? 'text-ink-300' : (dueTone[r.dueState ?? 'ok'])}`}>{r.dueState === 'overdue' && !r.done ? '⚠ ' : ''}{r.dueLabel}</span>}
              </div>
              <button data-done-int={r.id} data-done={r.done ? '1' : '0'} class={`done-int shrink-0 text-[10px] font-mono px-2 py-1 rounded-md border transition-colors ${r.done ? 'border-lime/30 text-lime bg-lime/10' : 'border-white/15 text-ink-200 hover:bg-white/5'}`}>
                {r.done ? '✓ hecho' : 'marcar hecho'}
              </button>
            </div>
          )}
        </div>
      </div>
    </div>
  ))}
</div>

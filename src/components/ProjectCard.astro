---
interface Props {
  slug: string
  title: string
  description?: string | null
  techStack?: string | null
  screenshotUrl?: string | null
}

const { slug, title, description, techStack, screenshotUrl } = Astro.props
const stack: string[] = techStack ? JSON.parse(techStack) : []
---

<a
  href={`/projects/${slug}`}
  class="group block bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden hover:border-zinc-600 transition-colors"
>
  {screenshotUrl && (
    <div class="aspect-video bg-zinc-800 overflow-hidden">
      <img
        src={screenshotUrl}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      />
    </div>
  )}
  <div class="p-5">
    <h3 class="font-semibold text-white mb-1">{title}</h3>
    {description && <p class="text-zinc-400 text-sm line-clamp-2 mb-3">{description}</p>}
    {stack.length > 0 && (
      <div class="flex flex-wrap gap-1">
        {stack.map((t) => (
          <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-300 rounded-full">{t}</span>
        ))}
      </div>
    )}
  </div>
</a>

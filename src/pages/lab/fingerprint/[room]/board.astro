---
import BaseLayout from '../../../../layouts/BaseLayout.astro'
import { getRoom } from '../../../../lib/fingerprint'
import QRCode from 'qrcode'

const roomId = Astro.params.room!
const room = await getRoom(roomId)

if (!room) {
  return new Response(null, { status: 404 })
}

const site = import.meta.env.AUTH_URL ?? 'https://codebymike.tech'
const joinUrl = `${site}/lab/fingerprint/${roomId}`
const qrSvg = await QRCode.toString(joinUrl, { type: 'svg', margin: 1, width: 260 })
---

<BaseLayout title={`Tablero — Sala ${roomId}`} description="Tablero en vivo del laboratorio de fingerprinting." noindex>
  <div id="fp-board" data-room={roomId} class="max-w-[1400px] mx-auto px-6 md:px-12 pt-16 pb-24">
    <div class="grid lg:grid-cols-[300px_1fr] gap-8">
      <!-- QR + info -->
      <div class="lg:sticky lg:top-16 lg:self-start">
        <div class="rounded-2xl glass p-6 text-center mb-4">
          <div class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300 mb-4">Escanea para entrar</div>
          <div class="bg-white rounded-xl p-3 [&_svg]:w-full [&_svg]:h-auto" set:html={qrSvg} />
          <p class="text-[11px] font-mono text-ink-400 mt-4 break-all">{joinUrl}</p>
        </div>
        <div class="rounded-2xl glass p-5">
          <div class="text-[10px] font-mono uppercase tracking-[.18em] text-ink-300">Dispositivos en sala</div>
          <div id="device-count" class="mt-1.5 text-3xl font-medium text-cyan tabular-nums">0</div>
        </div>
      </div>

      <!-- Tablero -->
      <div>
        <header class="mb-8">
          <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-cyan pulse-dot"></span>
            <span>Sala {roomId} · en vivo</span>
          </div>
          <h1 class="text-4xl font-medium tracking-[-.03em] text-mask mb-2">Sala de espejos</h1>
          <p class="text-[14px] text-ink-100 max-w-2xl leading-relaxed">
            Cada dispositivo que escanea el QR aparece aquí, identificado sin cookies ni login. Si
            alguien vuelve a entrar en incógnito, el contador de <span class="text-ember">revisitas</span>
            sube — el mismo dispositivo, reconocido de nuevo.
          </p>
        </header>

        <p id="board-expired" class="hidden text-[13px] text-ember mb-6">
          Esta sala expiró — los datos ya se purgaron. Crea una nueva desde el inicio.
        </p>

        <div id="devices" class="grid md:grid-cols-2 gap-4">
          <p id="devices-empty" class="text-ink-400 text-[13px]">Esperando dispositivos…</p>
        </div>
      </div>
    </div>

    <!-- Cierre pedagógico -->
    <section class="mt-16 rounded-2xl glass p-8">
      <h2 class="text-[13px] font-mono uppercase tracking-[.18em] text-ink-200 mb-4">Cómo defenderte</h2>
      <div class="grid md:grid-cols-3 gap-6 text-[13px] text-ink-100 leading-relaxed">
        <p><strong class="text-ink-50">El modo incógnito no protege.</strong> Borra cookies e historial local, pero el canvas, el GPU, las fuentes y el audio que expone tu navegador siguen siendo los mismos — por eso el tablero te reconoció igual.</p>
        <p><strong class="text-ink-50">Tor Browser</strong> normaliza deliberadamente estas señales entre todos sus usuarios (mismo canvas, misma resolución reportada) para que el fingerprint no sirva para distinguir a nadie.</p>
        <p><strong class="text-ink-50">Firefox con resistFingerprinting</strong> (about:config) reduce la precisión de varias de estas señales. Extensiones de bloqueo de canvas/WebGL también ayudan, aunque paradójicamente un fingerprint "demasiado bloqueado" puede volverse único en sí mismo.</p>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const roomId = (document.getElementById('fp-board') as HTMLElement).dataset.room!

  const esc = (v: unknown) => String(v ?? '').replace(/[&<>"']/g, (c) =>
    ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!))

  type Device = {
    label: number
    revisits: number
    entropyBits: number | null
    idShort: string
    libFpHash: string | null
    behaviorSig: { avgKeyIntervalMs: number | null; avgMouseSpeed: number | null; tiltX: number | null } | null
    firstSeen: string
    lastSeen: string
  }

  const container = document.getElementById('devices')!
  const empty = document.getElementById('devices-empty')!
  const expired = document.getElementById('board-expired')!
  // Reconciliamos por label para no reconstruir todo el DOM en cada tick
  // (evita el parpadeo y que se pierda el hover en el proyector).
  const cards = new Map<number, HTMLElement>()
  let stopped = false

  function cardHtml(d: Device): string {
    const b = d.behaviorSig
    const behaviorLine = b
      ? [
          b.avgKeyIntervalMs != null ? `⌨ ${Math.round(b.avgKeyIntervalMs)}ms` : null,
          b.avgMouseSpeed != null ? `🖱 ${b.avgMouseSpeed.toFixed(2)}px/ms` : null,
          b.tiltX != null ? `📱 tilt ${Math.round(b.tiltX)}°` : null,
        ].filter(Boolean).join(' · ') || 'sin datos de comportamiento aún'
      : 'sin datos de comportamiento aún'
    const revisitBadge = d.revisits > 0
      ? `<span class="text-[10px] font-mono uppercase tracking-[.15em] px-2.5 py-1 rounded-full border text-ember border-ember/40 bg-ember/15">${d.revisits} revisita${d.revisits === 1 ? '' : 's'}</span>`
      : ''
    const libLine = d.libFpHash
      ? `<div class="text-[11px] font-mono text-ink-400 mt-2">FingerprintJS: <span class="text-cyan">${esc(d.libFpHash.slice(0, 12))}</span></div>`
      : ''
    return `
      <div class="flex items-center justify-between mb-3">
        <span class="text-[15px] font-medium text-mask">Dispositivo #${esc(d.label)}</span>
        ${revisitBadge}
      </div>
      <div class="text-[11px] font-mono text-ink-400 mb-1">id propio: <span class="text-ink-200">${esc(d.idShort)}</span></div>
      <div class="text-[12px] font-mono text-ink-300 mb-2">≈ ${d.entropyBits ?? '?'} bits de entropía</div>
      <div class="text-[12px] text-ink-100">${esc(behaviorLine)}</div>
      ${libLine}
    `
  }

  function render(devices: Device[]) {
    document.getElementById('device-count')!.textContent = String(devices.length)
    empty.classList.toggle('hidden', devices.length > 0)

    const seen = new Set<number>()
    for (const d of devices) {
      seen.add(d.label)
      const html = cardHtml(d)
      let card = cards.get(d.label)
      if (!card) {
        card = document.createElement('div')
        card.className = 'rounded-2xl glass p-5 lift'
        cards.set(d.label, card)
        container.appendChild(card)
      }
      // Solo tocamos el DOM si el contenido cambió (firma en dataset).
      if (card.dataset.sig !== html) {
        card.innerHTML = html
        card.dataset.sig = html
      }
    }
    // Quita tarjetas de dispositivos que ya no están (no debería pasar en la
    // vida de una sala, pero mantiene el DOM en sincronía).
    for (const [label, card] of cards) {
      if (!seen.has(label)) { card.remove(); cards.delete(label) }
    }
  }

  async function poll() {
    if (stopped) return
    try {
      const res = await fetch(`/api/lab/fp/${roomId}`)
      if (res.status === 404) {
        // Sala expirada/purgada: paramos el polling y avisamos.
        stopped = true
        expired.classList.remove('hidden')
        return
      }
      if (!res.ok) return
      const data = await res.json()
      render(data.devices as Device[])
    } catch {
      // silencioso: reintenta en el próximo tick
    }
  }

  poll()
  const timer = setInterval(() => {
    if (stopped) { clearInterval(timer); return }
    poll()
  }, 1500)
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro'
import ProjectCard from '../components/ProjectCard.astro'
import EngineeringFeed from '../components/EngineeringFeed.astro'
import { db } from '../db'
import { projects } from '../db/schema'
import { eq } from 'drizzle-orm'

const visibleProjects = await db
  .select()
  .from(projects)
  .where(eq(projects.visible, true))
  .orderBy(projects.createdAt)
---

<BaseLayout title="CodeByMike | Senior Software Engineer">
  <!-- Hero -->
  <section class="relative overflow-hidden pt-32 pb-24 md:pt-48 md:pb-32">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-100/20 via-white to-white dark:from-brand-900/20 dark:via-[#0b0f14] dark:to-[#0b0f14]" />
    <div class="mx-auto max-w-5xl px-6">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white/50 px-3 py-1 text-sm text-slate-600 backdrop-blur-sm dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75" />
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500" />
          </span>
          Disponible para nuevos proyectos
        </div>

        <h1 class="mt-8 text-5xl font-bold tracking-tight text-slate-900 md:text-7xl dark:text-white font-serif">
          Ingeniería de software con{' '}
          <span class="text-brand-600 dark:text-brand-400">propósito</span>.
        </h1>

        <p class="mt-6 text-xl leading-relaxed text-slate-600 md:text-2xl dark:text-slate-300 max-w-2xl">
          Ayudo a empresas a escalar sus productos digitales mediante arquitectura robusta,
          rendimiento obsesivo y experiencia de usuario de clase mundial.
        </p>

        <div class="mt-10 flex flex-wrap gap-4">
          {visibleProjects.length > 0 ? (
            <a
              href="#proyectos"
              class="inline-flex items-center gap-2 rounded-lg bg-slate-900 px-6 py-3 text-base font-medium text-white shadow-lg shadow-slate-900/20 transition hover:bg-slate-800 focus:outline-none dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100"
            >
              Ver proyectos
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          ) : (
            <a
              href="/certifications"
              class="inline-flex items-center gap-2 rounded-lg bg-slate-900 px-6 py-3 text-base font-medium text-white shadow-lg shadow-slate-900/20 transition hover:bg-slate-800 focus:outline-none dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100"
            >
              Certificaciones
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          )}
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-6 py-3 text-base font-medium text-slate-700 shadow-sm transition hover:bg-slate-50 focus:outline-none dark:border-slate-800 dark:bg-transparent dark:text-slate-300 dark:hover:bg-slate-800"
          >
            Hablemos
          </a>
          <a
            href="https://github.com/mikerb95"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-6 py-3 text-base font-medium text-slate-700 shadow-sm transition hover:bg-slate-50 focus:outline-none dark:border-slate-800 dark:bg-transparent dark:text-slate-300 dark:hover:bg-slate-800"
          >
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise -->
  <section class="py-24 border-t border-slate-100 dark:border-slate-800/50">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
        Expertise Técnico &amp; Filosofía
      </h2>
      <div class="mt-12 grid gap-12 md:grid-cols-3">
        <div class="space-y-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600 dark:bg-brand-900/20 dark:text-brand-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white">Arquitectura Escalable</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Diseño sistemas distribuidos y modulares pensados para crecer. Monorepos, microservicios (cuando tienen sentido) y patrones de diseño sólidos.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-purple-50 text-purple-600 dark:bg-purple-900/20 dark:text-purple-400">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white">Performance First</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            La velocidad es una feature. Optimizo Core Web Vitals, tiempos de respuesta de API y eficiencia en bases de datos.
          </p>
        </div>
        <div class="space-y-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-50 text-emerald-600 dark:bg-emerald-900/20 dark:text-emerald-400">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 dark:text-white">Calidad de Código</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Testing riguroso (Unit, E2E), tipado estático estricto y documentación clara. Código mantenible es código rentable.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  {visibleProjects.length > 0 && (
    <section id="proyectos" class="py-24 border-t border-slate-100 dark:border-slate-800/50">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-12">
          Proyectos
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {visibleProjects.map((p) => (
            <ProjectCard
              slug={p.slug}
              title={p.title}
              description={p.description}
              techStack={p.techStack}
              screenshotUrl={p.screenshotUrl}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Engineering Feed -->
  <div class="mx-auto max-w-5xl px-6 pb-24">
    <EngineeringFeed />
  </div>
</BaseLayout>

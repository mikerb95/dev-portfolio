---
import BaseLayout from '../layouts/BaseLayout.astro'
import ProjectCard from '../components/ProjectCard.astro'
import EngineeringFeed from '../components/EngineeringFeed.astro'
import { db } from '../db'
import { projects } from '../db/schema'
import { eq } from 'drizzle-orm'

const visibleProjects = await db
  .select()
  .from(projects)
  .where(eq(projects.visible, true))
  .orderBy(projects.createdAt)
---

<BaseLayout title="Portfolio">
  <div class="max-w-5xl mx-auto px-6 py-20">
    <header class="mb-16">
      <p class="text-zinc-500 text-sm font-mono mb-3">@mikerb95</p>
      <h1 class="text-4xl font-bold mb-4">Senior Software Engineer</h1>
      <p class="text-zinc-400 text-lg max-w-xl leading-relaxed">
        Ayudo a empresas a escalar sus productos digitales mediante arquitectura robusta,
        rendimiento obsesivo y experiencia de usuario de clase mundial.
      </p>
      <div class="flex gap-3 mt-6 flex-wrap">
        <a
          href="/contact"
          class="inline-block px-5 py-2.5 bg-white text-zinc-900 rounded-lg font-medium hover:bg-zinc-100 transition-colors"
        >
          Contactar
        </a>
        <a
          href="https://github.com/mikerb95"
          target="_blank"
          rel="noopener"
          class="inline-block px-5 py-2.5 border border-zinc-700 rounded-lg text-zinc-300 hover:bg-zinc-800 transition-colors"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/mdrb95/"
          target="_blank"
          rel="noopener"
          class="inline-block px-5 py-2.5 border border-zinc-700 rounded-lg text-zinc-300 hover:bg-zinc-800 transition-colors"
        >
          LinkedIn
        </a>
      </div>
    </header>

    {visibleProjects.length > 0 && (
      <section>
        <h2 class="text-xl font-semibold mb-6">Proyectos</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {visibleProjects.map((p) => (
            <ProjectCard
              slug={p.slug}
              title={p.title}
              description={p.description}
              techStack={p.techStack}
              screenshotUrl={p.screenshotUrl}
            />
          ))}
        </div>
      </section>
    )}

    <EngineeringFeed />
  </div>
</BaseLayout>

---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { db } from '../../db'
import { educationMilestones, educationLabProgress, projects } from '../../db/schema'
import { eq, desc } from 'drizzle-orm'
import { educationPaths, labProgressKey } from '../../lib/education-paths'

const labProgressRows = await db
  .select({ labSlug: educationLabProgress.labSlug, completed: educationLabProgress.completed })
  .from(educationLabProgress)
const completedLabSlugs = new Set(labProgressRows.filter((r) => r.completed).map((r) => r.labSlug))

const milestones = await db
  .select({
    id: educationMilestones.id,
    title: educationMilestones.title,
    institution: educationMilestones.institution,
    description: educationMilestones.description,
    skills: educationMilestones.skills,
    status: educationMilestones.status,
    startDate: educationMilestones.startDate,
    completedDate: educationMilestones.completedDate,
    certificateUrl: educationMilestones.certificateUrl,
    isPublic: educationMilestones.isPublic,
    projectId: educationMilestones.projectId,
    projectTitle: projects.title,
    projectSlug: projects.slug,
  })
  .from(educationMilestones)
  .leftJoin(projects, eq(educationMilestones.projectId, projects.id))
  .orderBy(desc(educationMilestones.startDate))

const allProjects = await db.select({ id: projects.id, title: projects.title }).from(projects).orderBy(projects.title)

const statusColors: Record<string, string> = {
  completado: 'text-emerald-400 bg-emerald-950',
  en_curso: 'text-amber-400 bg-amber-950',
  pausado: 'text-zinc-400 bg-zinc-800',
}

const statusLabels: Record<string, string> = {
  completado: 'Completado',
  en_curso: 'En curso',
  pausado: 'Pausado',
}

const completados = milestones.filter((m) => m.status === 'completado').length
const enCurso = milestones.filter((m) => m.status === 'en_curso').length
const progress = completados + enCurso > 0 ? Math.round((completados / (completados + enCurso)) * 100) : 0
---

<AdminLayout title="Evolution Path">
  <div class="space-y-6">

    <!-- Header + progress -->
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-xl font-bold text-white">Evolution Path</h1>
        <p class="text-zinc-400 text-sm mt-1">Seguimiento de formación continua y su impacto en proyectos</p>
      </div>
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-4 text-right min-w-40">
        <p class="text-zinc-400 text-xs mb-1">Progreso de evolución</p>
        <p class="text-2xl font-bold text-emerald-400">{progress}%</p>
        <p class="text-zinc-500 text-xs">{completados} completados · {enCurso} en curso</p>
      </div>
    </div>

    <!-- Rutas de aprendizaje -->
    <div class="space-y-3">
      <div>
        <h2 class="text-white font-semibold">Rutas de aprendizaje</h2>
        <p class="text-zinc-500 text-xs mt-0.5">Labs prácticos por tema, con seguimiento de progreso.</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
        {educationPaths.map((path) => {
          const total = path.labs.length
          const done = path.labs.filter((l) => completedLabSlugs.has(labProgressKey(path.slug, l.slug))).length
          const pct = total > 0 ? Math.round((done / total) * 100) : 0
          return (
            <details class="bg-zinc-900 border border-zinc-800 rounded-xl">
              <summary class="px-5 py-4 cursor-pointer select-none list-none">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap mb-1">
                      <span class="text-xs text-zinc-500">Ruta {String(path.order).padStart(2, '0')}</span>
                      <span class="text-xs text-zinc-600">·</span>
                      <span class="text-xs text-zinc-500">{total} labs</span>
                    </div>
                    <h3 class="text-white font-semibold">{path.title}</h3>
                    <p class="text-zinc-400 text-sm mt-1">{path.tagline}</p>
                  </div>
                  <div class="text-right shrink-0">
                    <p class={`text-lg font-bold ${done === total ? 'text-emerald-400' : 'text-zinc-300'}`}>{pct}%</p>
                    <p class="text-zinc-500 text-xs">{done}/{total}</p>
                  </div>
                </div>
                <div class="mt-3 h-1.5 bg-zinc-800 rounded-full overflow-hidden">
                  <div class="h-full bg-emerald-500 transition-all" style={`width: ${pct}%`} />
                </div>
              </summary>
              <div class="px-5 pb-5 space-y-2">
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {path.topics.map((t) => (
                    <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-400 rounded-md">{t}</span>
                  ))}
                </div>
                {path.labs.map((lab) => {
                  const key = labProgressKey(path.slug, lab.slug)
                  const isDone = completedLabSlugs.has(key)
                  return (
                    <div class={`lab-row flex items-start gap-3 p-3 rounded-lg border ${isDone ? 'border-emerald-900 bg-emerald-950/30' : 'border-zinc-800 bg-zinc-950'}`} data-lab-slug={key}>
                      <input
                        type="checkbox"
                        class="lab-checkbox mt-1 accent-emerald-500 shrink-0"
                        checked={isDone}
                        data-lab-slug={key}
                      />
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                          <span class={`text-sm font-medium ${isDone ? 'text-emerald-300' : 'text-white'}`}>
                            {lab.title}
                          </span>
                        </div>
                        <p class="text-zinc-500 text-xs mt-1">{lab.description}</p>
                        <div class="flex items-center gap-2 flex-wrap mt-2">
                          <span class="text-xs text-zinc-500">{lab.durationMin} min</span>
                          <span class="text-xs text-zinc-600">·</span>
                          <span class="text-xs text-zinc-500">{lab.level}</span>
                          {lab.tags.map((t) => (
                            <span class="text-xs px-1.5 py-0.5 bg-zinc-800 text-zinc-400 rounded">#{t}</span>
                          ))}
                        </div>
                      </div>
                    </div>
                  )
                })}
              </div>
            </details>
          )
        })}
      </div>
    </div>

    <!-- Create form -->
    <details class="bg-zinc-900 border border-zinc-800 rounded-xl">
      <summary class="px-5 py-4 cursor-pointer text-sm font-medium text-zinc-300 hover:text-white select-none">
        + Nuevo hito educativo
      </summary>
      <form id="form-create" class="p-5 pt-0 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="sm:col-span-2">
          <label class="block text-xs text-zinc-400 mb-1">Título *</label>
          <input name="title" required class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500" placeholder="ej. Curso TypeScript Avanzado" />
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Institución</label>
          <input name="institution" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500" placeholder="Udemy, Platzi, freeCodeCamp…" />
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Estado</label>
          <select name="status" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500">
            <option value="en_curso">En curso</option>
            <option value="completado">Completado</option>
            <option value="pausado">Pausado</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Fecha inicio</label>
          <input type="date" name="startDate" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500" />
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Fecha completado</label>
          <input type="date" name="completedDate" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500" />
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs text-zinc-400 mb-1">Descripción</label>
          <textarea name="description" rows="2" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500 resize-none" placeholder="¿Qué aprendiste?"></textarea>
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Skills (separadas por coma)</label>
          <input name="skills" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500" placeholder="TypeScript, Drizzle ORM, Astro" />
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Proyecto vinculado</label>
          <select name="projectId" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500">
            <option value="">— Ninguno —</option>
            {allProjects.map((p) => (
              <option value={p.id}>{p.title}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">URL Certificado</label>
          <input name="certificateUrl" type="url" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-zinc-500" placeholder="https://…" />
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="isPublic" id="isPublic" checked class="accent-emerald-500" />
          <label for="isPublic" class="text-xs text-zinc-400">Visible en portafolio público</label>
        </div>
        <div class="sm:col-span-2 flex justify-end">
          <button type="submit" class="px-4 py-2 bg-white text-zinc-900 rounded-lg text-sm font-medium hover:bg-zinc-100 transition-colors">
            Crear hito
          </button>
        </div>
      </form>
    </details>

    <!-- Milestones list -->
    <div class="space-y-3">
      {milestones.length === 0 && (
        <p class="text-zinc-500 text-sm text-center py-12">Aún no hay hitos educativos. Crea el primero arriba.</p>
      )}
      {milestones.map((m) => {
        const skills: string[] = m.skills ? JSON.parse(m.skills) : []
        return (
          <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5" data-id={m.id}>
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${statusColors[m.status ?? 'en_curso']}`}>
                    {statusLabels[m.status ?? 'en_curso']}
                  </span>
                  {m.institution && <span class="text-xs text-zinc-500">{m.institution}</span>}
                  {!m.isPublic && <span class="text-xs text-zinc-600 bg-zinc-800 px-2 py-0.5 rounded-full">Privado</span>}
                </div>
                <h3 class="text-white font-semibold">{m.title}</h3>
                {m.description && <p class="text-zinc-400 text-sm mt-1 line-clamp-2">{m.description}</p>}
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {skills.map((s) => (
                    <span class="text-xs px-2 py-0.5 bg-zinc-800 text-zinc-300 rounded-md">{s}</span>
                  ))}
                </div>
                {m.projectTitle && (
                  <p class="text-xs text-blue-400 mt-2">
                    Vinculado a: <a href={`/admin/projects/${m.projectId}`} class="hover:underline">{m.projectTitle}</a>
                  </p>
                )}
              </div>
              <div class="flex gap-2 shrink-0">
                {m.certificateUrl && (
                  <a href={m.certificateUrl} target="_blank" rel="noopener" class="text-xs px-3 py-1.5 border border-zinc-700 rounded-lg text-zinc-400 hover:text-white hover:border-zinc-500 transition-colors">
                    Cert.
                  </a>
                )}
                <button
                  class="btn-delete text-xs px-3 py-1.5 border border-red-900 rounded-lg text-red-400 hover:bg-red-950 transition-colors"
                  data-id={m.id}
                >
                  Eliminar
                </button>
              </div>
            </div>
          </div>
        )
      })}
    </div>
  </div>
</AdminLayout>

<script>
  // Rutas de aprendizaje: toggle de progreso por lab
  document.querySelectorAll('.lab-checkbox').forEach((checkbox) => {
    checkbox.addEventListener('change', async (e) => {
      const input = e.target as HTMLInputElement
      const labSlug = input.dataset.labSlug
      const completed = input.checked
      const row = input.closest('.lab-row') as HTMLElement | null

      const res = await fetch('/api/admin/education/lab-progress', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ labSlug, completed }),
      })

      if (res.ok) {
        window.location.reload()
      } else {
        input.checked = !completed
        if (row) row.classList.add('opacity-50')
        alert('Error al guardar el progreso')
      }
    })
  })

  // Create
  document.getElementById('form-create')?.addEventListener('submit', async (e) => {
    e.preventDefault()
    const form = e.target as HTMLFormElement
    const data = new FormData(form)

    const skillsRaw = (data.get('skills') as string).trim()
    const skills = skillsRaw ? skillsRaw.split(',').map((s) => s.trim()).filter(Boolean) : []

    const body = {
      title: data.get('title'),
      institution: data.get('institution') || null,
      description: data.get('description') || null,
      skills,
      status: data.get('status'),
      startDate: data.get('startDate') || null,
      completedDate: data.get('completedDate') || null,
      certificateUrl: data.get('certificateUrl') || null,
      projectId: data.get('projectId') || null,
      isPublic: (data.get('isPublic') as string) === 'on',
    }

    const res = await fetch('/api/admin/education', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    })

    if (res.ok) {
      window.location.reload()
    } else {
      const { error } = await res.json()
      alert(error ?? 'Error al crear el hito')
    }
  })

  // Delete
  document.querySelectorAll('.btn-delete').forEach((btn) => {
    btn.addEventListener('click', async () => {
      if (!confirm('¿Eliminar este hito educativo?')) return
      const id = Number((btn as HTMLElement).dataset.id)
      const res = await fetch(`/api/admin/education/${id}`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      })
      if (res.ok) window.location.reload()
    })
  })
</script>

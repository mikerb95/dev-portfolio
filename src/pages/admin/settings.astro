---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { db } from '../../db'
import { appSettings } from '../../db/schema'
import { CURRENCIES, BASE_CURRENCY } from '../../lib/money'
import { ALLOWED_GITHUB_LOGINS } from '../../lib/auth'

const settingsRows = await db.select().from(appSettings)
const map = Object.fromEntries(settingsRows.map((r) => [r.key, r.value]))

const fxCurrencies = CURRENCIES.filter((c) => c !== BASE_CURRENCY)
const rateOf = (cur: string) => map[`fx_${cur}_per_USD`] ?? ''

// Estado de seguridad (no se expone el valor de la clave)
const encKey = import.meta.env.ENCRYPTION_KEY as string | undefined
const encKeyOk = !!encKey && encKey.length === 64
---

<AdminLayout title="Ajustes">
  <div class="max-w-2xl space-y-6">
    <!-- Tasas de cambio -->
    <div class="rounded-2xl glass p-5 md:p-6">
      <h2 class="text-base font-medium text-ink-50">Tasas de cambio</h2>
      <p class="text-[12px] text-ink-300 mt-1 mb-4">
        Unidades de cada moneda por <span class="font-mono text-cyan">1 {BASE_CURRENCY}</span>. Se usan para convertir costos a USD base.
        Déjalo vacío si no usas esa moneda.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {fxCurrencies.map((cur) => (
          <div>
            <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">{cur} / USD</label>
            <input
              data-cur={cur}
              type="number" step="0.0001" min="0"
              value={rateOf(cur)}
              placeholder="—"
              class="rate-input input-base w-full rounded-lg px-3 py-2 text-[13px] font-mono"
            />
          </div>
        ))}
      </div>
      <div class="flex items-center gap-3 mt-4">
        <button id="save-rates" class="h-9 px-4 text-[13px] font-medium rounded-full bg-cyan text-ink-950 hover:bg-cyan-glow transition-colors">Guardar tasas</button>
        <span id="rates-status" class="text-[12px] font-mono text-lime hidden">✓ Guardado</span>
      </div>
    </div>

    <!-- Seguridad -->
    <div class="rounded-2xl glass p-5 md:p-6">
      <h2 class="text-base font-medium text-ink-50 mb-4">Seguridad</h2>

      <div class="flex items-center justify-between py-2.5 border-b border-white/5">
        <div>
          <div class="text-[13px] text-ink-100">Clave de cifrado (ENCRYPTION_KEY)</div>
          <div class="text-[11px] font-mono text-ink-300">Requerida para la bóveda de credenciales y env vars</div>
        </div>
        {encKeyOk
          ? <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-mono bg-lime/10 text-lime border border-lime/30">✓ configurada</span>
          : <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-mono bg-ember/10 text-ember border border-ember/30">✗ falta</span>}
      </div>

      {!encKeyOk && (
        <div class="mt-3 rounded-lg border border-ember/25 bg-ember/[.05] px-3 py-2.5 text-[11.5px] text-ink-100">
          Genera una clave hex de 32 bytes y añádela como <span class="font-mono text-ember">ENCRYPTION_KEY</span> en tu <span class="font-mono">.env</span> y en Vercel:
          <code class="block mt-1.5 font-mono text-[11px] text-cyan bg-black/30 rounded px-2 py-1 select-all">node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"</code>
        </div>
      )}

      <div class="py-2.5 mt-1">
        <div class="text-[13px] text-ink-100 mb-2">Logins de GitHub autorizados</div>
        <div class="flex flex-wrap gap-2">
          {ALLOWED_GITHUB_LOGINS.map((l) => (
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-mono bg-white/5 text-ink-100 border border-white/10">
              <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="text-ink-300"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.26.82-.577v-2.03c-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.082-.73.082-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.835 2.807 1.305 3.492.997.108-.776.42-1.305.762-1.605-2.665-.305-5.467-1.332-5.467-5.93 0-1.31.467-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23A11.5 11.5 0 0 1 12 5.8c1.02.005 2.045.138 3.003.404 2.29-1.552 3.295-1.23 3.295-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.62-5.475 5.92.43.37.81 1.096.81 2.21v3.28c0 .32.21.695.825.575C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
              {l}
            </span>
          ))}
        </div>
        <p class="text-[11px] font-mono text-ink-300 mt-2">Edítalos con la variable <span class="text-ink-100">ALLOWED_GITHUB_LOGINS</span> (separados por coma).</p>
      </div>
    </div>

    <!-- Info -->
    <div class="rounded-2xl glass p-5 md:p-6">
      <h2 class="text-base font-medium text-ink-50 mb-2">Moneda base</h2>
      <p class="text-[12px] text-ink-300">Todos los totales del panel se muestran en <span class="font-mono text-cyan">{BASE_CURRENCY}</span>.</p>
    </div>
  </div>
</AdminLayout>

<script>
  document.getElementById('save-rates')?.addEventListener('click', async () => {
    const settings: Record<string, string | null> = {}
    document.querySelectorAll<HTMLInputElement>('.rate-input').forEach((el) => {
      const cur = el.dataset.cur
      if (cur) settings[`fx_${cur}_per_USD`] = el.value.trim() || null
    })
    const res = await fetch('/api/admin/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ settings }),
    })
    const status = document.getElementById('rates-status')!
    if (res.ok) {
      status.classList.remove('hidden')
      setTimeout(() => status.classList.add('hidden'), 2500)
    } else {
      alert('Error al guardar las tasas.')
    }
  })
</script>

---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { getSession } from 'auth-astro/server'
import { listCredentials } from '../../lib/webauthn'

const session = await getSession(Astro.request)
const login = (session?.user as { login?: string } | undefined)?.login ?? ''

const rows = await listCredentials(login)
const items = rows.map((r) => ({
  id: r.id,
  nickname: r.nickname,
  deviceType: r.deviceType,
  createdAt: r.createdAt?.getTime() ?? null,
  lastUsedAt: r.lastUsedAt?.getTime() ?? null,
}))
---

<AdminLayout title="Llaves de seguridad">
  <div class="max-w-2xl space-y-6">
    <div class="rounded-2xl glass p-5 md:p-6">
      <div class="flex items-start justify-between gap-4 mb-4">
        <div>
          <h2 class="text-base font-medium text-ink-50">Llaves de seguridad (WebAuthn)</h2>
          <p class="text-[12px] text-ink-300 mt-1">
            Segundo factor para /admin. Con al menos una llave registrada, entrar con GitHub ya no
            basta: cada nueva sesión te pide tocar la llave antes de dejarte pasar.
          </p>
        </div>
        <button
          id="add-key-btn"
          class="shrink-0 h-9 px-4 text-[13px] font-medium rounded-full bg-cyan/10 text-cyan border border-cyan/30 hover:bg-cyan/20 transition-colors"
        >
          + Añadir llave
        </button>
      </div>

      {items.length === 0 ? (
        <p class="text-[13px] text-ink-300 py-6 text-center">
          Sin llaves registradas todavía — el panel solo pide GitHub.
        </p>
      ) : (
        <div class="space-y-2" id="keys-list">
          {items.map((it) => (
            <div
              class="key-row flex items-center justify-between gap-4 py-3 px-3.5 rounded-xl border border-white/5 bg-white/[.02]"
              data-id={it.id}
            >
              <div class="min-w-0 flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ink-300 shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <div class="min-w-0">
                  <div class="text-[13px] text-ink-50 truncate">{it.nickname || 'Llave sin nombre'}</div>
                  <div class="text-[11px] font-mono text-ink-300 mt-1 truncate">
                    <span>{it.deviceType === 'singleDevice' ? 'llave física' : 'passkey sincronizada'}</span>
                    <span class="mx-1.5 text-ink-500">·</span>
                    <span class="rel-time" data-ts={it.lastUsedAt ?? ''}>nunca usada</span>
                  </div>
                </div>
              </div>
              <button
                class="revoke-key shrink-0 h-8 px-3 text-[12px] font-medium rounded-full text-ink-200 border border-white/10 hover:border-ember/40 hover:text-ember transition-colors"
                data-id={it.id}
              >
                Quitar
              </button>
            </div>
          ))}
        </div>
      )}
    </div>

    <p class="text-[11px] text-ink-400 leading-relaxed px-1">
      Si quitas todas las llaves, el panel vuelve a pedir solo GitHub (el MFA se desactiva
      automáticamente, nunca queda un candado sin llave). La verificación se re-pide cada 12&nbsp;h
      por dispositivo.
    </p>
  </div>

  <script>
    import { startRegistration } from '@simplewebauthn/browser'

    const fmt = (ts: number) => {
      const s = Math.max(0, Math.floor((Date.now() - ts) / 1000))
      if (s < 60) return 'usada hace instantes'
      const m = Math.floor(s / 60)
      if (m < 60) return `usada hace ${m} min`
      const h = Math.floor(m / 60)
      if (h < 24) return `usada hace ${h} h`
      const d = Math.floor(h / 24)
      return `usada hace ${d} d`
    }
    document.querySelectorAll<HTMLElement>('.rel-time').forEach((el) => {
      const ts = Number(el.dataset.ts)
      if (ts) el.textContent = fmt(ts)
    })

    const addBtn = document.getElementById('add-key-btn') as HTMLButtonElement
    addBtn?.addEventListener('click', async () => {
      addBtn.disabled = true
      addBtn.textContent = 'Esperando llave…'
      try {
        const optRes = await fetch('/api/admin/webauthn/registration/options')
        if (!optRes.ok) throw new Error((await optRes.json().catch(() => ({}))).error ?? 'no se pudo iniciar')
        const options = await optRes.json()

        const regResponse = await startRegistration({ optionsJSON: options })

        const nickname = prompt('Nombre para esta llave (opcional):', 'YubiKey') ?? undefined

        const verifyRes = await fetch('/api/admin/webauthn/registration/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ response: regResponse, nickname }),
        })
        const result = await verifyRes.json()
        if (!verifyRes.ok || !result.ok) throw new Error(result.error ?? 'no se pudo registrar')

        window.location.reload()
      } catch (err) {
        alert(err instanceof Error ? err.message : 'algo falló registrando la llave')
        addBtn.disabled = false
        addBtn.textContent = '+ Añadir llave'
      }
    })

    document.querySelectorAll<HTMLButtonElement>('.revoke-key').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('¿Quitar esta llave? Ya no servirá para entrar al panel.')) return
        btn.disabled = true
        btn.textContent = '…'
        const res = await fetch('/api/admin/webauthn/credentials', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: btn.dataset.id }),
        })
        if (res.ok) {
          btn.closest('.key-row')?.remove()
        } else {
          btn.disabled = false
          btn.textContent = 'Quitar'
        }
      })
    })
  </script>
</AdminLayout>

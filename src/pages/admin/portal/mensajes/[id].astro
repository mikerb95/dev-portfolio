---
import AdminLayout from '../../../../layouts/AdminLayout.astro'
import { db } from '../../../../db'
import { clients, portalThreads } from '../../../../db/schema'
import { eq } from 'drizzle-orm'
import { renderBody, threadWithMessages } from '../../../../lib/portal/threads'
import { formatDateTime } from '../../../../lib/portal/format'

const id = Number(Astro.params.id)
if (!Number.isInteger(id)) return Astro.rewrite('/404')

// Del lado admin no hay tenant que aislar (los veo todos), así que el clientId
// se saca del propio hilo en vez de una sesión.
const [thread] = await db.select().from(portalThreads).where(eq(portalThreads.id, id)).limit(1)
if (!thread) return Astro.rewrite('/404')

const result = await threadWithMessages(thread.clientId, id)
if (!result) return Astro.rewrite('/404')

const [client] = await db.select().from(clients).where(eq(clients.id, thread.clientId)).limit(1)

const rendered = result.messages.map((m) => ({
  ...m,
  html: renderBody(m.body),
  displayName: m.authorType === 'admin' ? 'Yo' : (m.userName ?? m.authorName ?? 'Cliente'),
}))
---

<AdminLayout title={result.thread.subject}>
  <div class="flex items-center justify-between gap-3 mb-5">
    <div>
      <p class="text-[13px] text-ink-100">{client?.company ?? client?.name}</p>
      {result.thread.projectTitle && (
        <p class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300 mt-0.5">{result.thread.projectTitle}</p>
      )}
    </div>
    <a href="/admin/portal/mensajes" class="text-[12px] text-ink-300 hover:text-cyan transition-colors">← Bandeja</a>
  </div>

  <div class="max-w-[760px] space-y-3 mb-6">
    {rendered.map((m) => (
      <div class:list={['flex gap-3', m.authorType === 'admin' && 'flex-row-reverse']}>
        <span
          class:list={[
            'shrink-0 w-7 h-7 rounded-full grid place-items-center text-[10px] font-semibold',
            m.authorType === 'admin'
              ? 'bg-cyan/15 text-cyan border border-cyan/25'
              : 'bg-white/[.06] text-ink-100 border border-white/10',
          ]}
        >
          {m.displayName.slice(0, 2).toUpperCase()}
        </span>
        <div class:list={['min-w-0 max-w-[min(78%,560px)]', m.authorType === 'admin' && 'text-right']}>
          <div class="flex items-baseline gap-2 mb-1" style={m.authorType === 'admin' ? 'justify-content:flex-end' : ''}>
            <span class="text-[12px] font-medium text-ink-100">{m.displayName}</span>
            <span class="text-[10px] font-mono text-ink-300">{formatDateTime(m.createdAt)}</span>
          </div>
          <div
            class:list={[
              'rounded-2xl px-3.5 py-2.5 text-[13.5px] leading-relaxed text-left',
              m.authorType === 'admin'
                ? 'bg-cyan/[.08] border border-cyan/20 text-ink-50'
                : 'bg-white/[.04] border border-white/[.06] text-ink-100',
            ]}
          >
            {/* Ya escapado en renderBody; ver el comentario de ese módulo. */}
            <Fragment set:html={m.html} />
          </div>
        </div>
      </div>
    ))}
  </div>

  <form id="reply" class="glass rounded-2xl p-4 max-w-[760px]">
    <label for="body" class="block text-[12px] font-medium text-ink-100 mb-2">Responder al cliente</label>
    <textarea id="body" name="body" required rows="4" maxlength="5000" class="input-base w-full resize-y" placeholder="Tu respuesta…" />
    <div class="mt-3 flex items-center justify-between gap-3">
      <label class="flex items-center gap-2 text-[12px] text-ink-200 cursor-pointer">
        <input type="checkbox" id="close-thread" class="w-3.5 h-3.5 accent-cyan" />
        Marcar la conversación como cerrada
      </label>
      <button
        type="submit"
        id="send"
        class="shrink-0 h-9 px-4 rounded-full bg-cyan text-ink-950 text-[13px] font-semibold hover:bg-cyan-glow transition-colors disabled:opacity-50"
      >
        Enviar
      </button>
    </div>
    <p id="error" class="hidden mt-2 text-[12px] text-ember" role="alert" />
  </form>
</AdminLayout>

<script define:vars={{ threadId: id }}>
  const form = document.getElementById('reply')
  const errorEl = document.getElementById('error')
  const send = document.getElementById('send')

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    send.disabled = true
    send.textContent = 'Enviando…'

    try {
      const res = await fetch(`/api/admin/portal/mensajes/${threadId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          body: new FormData(form).get('body'),
          close: document.getElementById('close-thread').checked,
        }),
      })
      if (res.ok) {
        window.location.reload()
        return
      }
      const data = await res.json().catch(() => ({}))
      errorEl.textContent = data.error ?? 'No se pudo enviar.'
      errorEl.classList.remove('hidden')
    } catch {
      errorEl.textContent = 'Error de conexión.'
      errorEl.classList.remove('hidden')
    }
    send.disabled = false
    send.textContent = 'Enviar'
  })
</script>

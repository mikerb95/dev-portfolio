---
import AdminLayout from '../../../../layouts/AdminLayout.astro'
import { adminThreads } from '../../../../lib/portal/threads'
import { db } from '../../../../db'
import { clients } from '../../../../db/schema'
import { relativeTime } from '../../../../lib/portal/format'

const [threads, clientRows] = await Promise.all([adminThreads(), db.select().from(clients)])
const clientById = new Map(clientRows.map((c) => [c.id, c.company ?? c.name]))

// Los que esperan respuesta mía van arriba: es la única ordenación que importa
// cuando abro esta página.
const rows = threads
  .map((t) => ({ ...t, clientName: clientById.get(t.clientId) ?? '—', waiting: t.lastAuthor === 'client' && t.status === 'open' }))
  .sort((a, b) => Number(b.waiting) - Number(a.waiting))

const waiting = rows.filter((r) => r.waiting).length
---

<AdminLayout title="Bandeja del portal">
  <div class="flex justify-between items-center mb-6 gap-3">
    <p class="text-ink-200 text-sm">
      {waiting === 0 ? (
        <span class="text-lime">Todo respondido</span>
      ) : (
        <span class="text-ember">{waiting} conversación{waiting !== 1 ? 'es' : ''} esperando respuesta</span>
      )}
    </p>
    <a href="/admin/portal" class="text-[12px] text-ink-300 hover:text-cyan transition-colors">← Portal</a>
  </div>

  {rows.length === 0 ? (
    <div class="glass rounded-2xl p-10 text-center">
      <p class="text-ink-200">No hay conversaciones todavía.</p>
    </div>
  ) : (
    <div class="glass rounded-2xl divide-y divide-white/5 overflow-hidden">
      {rows.map((t) => (
        <a href={`/admin/portal/mensajes/${t.id}`} class="block px-4 py-3.5 hover:bg-white/[.02] transition-colors">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                {t.waiting && <span class="shrink-0 w-1.5 h-1.5 rounded-full bg-ember" aria-label="Esperando respuesta" />}
                <h3 class:list={['text-[14px] truncate', t.waiting ? 'text-ink-50 font-medium' : 'text-ink-100']}>
                  {t.subject}
                </h3>
                {t.status === 'closed' && (
                  <span class="shrink-0 px-1.5 py-0.5 rounded text-[10px] font-mono uppercase bg-white/[.04] text-ink-300">
                    Cerrada
                  </span>
                )}
              </div>
              <p class="mt-1 text-[12px] text-ink-300">
                {t.clientName}
                {t.projectTitle && ` · ${t.projectTitle}`}
                {` · ${t.messageCount} mensaje${t.messageCount !== 1 ? 's' : ''}`}
              </p>
            </div>
            <p class="shrink-0 text-[11px] font-mono text-ink-300">{relativeTime(t.lastMessageAt)}</p>
          </div>
        </a>
      ))}
    </div>
  )}
</AdminLayout>

---
import AdminLayout from '../../layouts/AdminLayout.astro'
import FinanceTable from '../../components/admin/FinanceTable.astro'
import { db } from '../../db'
import { finances, projects, clients, projectServices, appSettings } from '../../db/schema'
import { desc, eq } from 'drizzle-orm'
import { parseRates, fmtUSD } from '../../lib/money'
import { monthlyCostUSD, type ServiceLike } from '../../lib/pnl'

const [rows, serviceRows, settingsRows] = await Promise.all([
  db.select({
    id: finances.id,
    description: finances.description,
    amount: finances.amount,
    status: finances.status,
    dueDate: finances.dueDate,
    projectTitle: projects.title,
    clientName: clients.name,
  })
    .from(finances)
    .leftJoin(projects, eq(finances.projectId, projects.id))
    .leftJoin(clients, eq(finances.clientId, clients.id))
    .orderBy(desc(finances.createdAt)),
  db.select({ cost: projectServices.cost, currency: projectServices.currency, billingCycle: projectServices.billingCycle, active: projectServices.active }).from(projectServices),
  db.select().from(appSettings),
])

const cobrado    = rows.filter((r) => r.status === 'cobrado').reduce((s, r) => s + r.amount, 0)
const pendiente  = rows.filter((r) => r.status === 'pendiente').reduce((s, r) => s + r.amount, 0)
const proyectado = rows.filter((r) => r.status === 'proyectado').reduce((s, r) => s + r.amount, 0)

const rates = parseRates(settingsRows)
const { total: costoMensualUSD } = monthlyCostUSD(serviceRows as ServiceLike[], rates)

const cards = [
  { label: 'Cobrado', value: cobrado, tone: 'text-lime' },
  { label: 'Pendiente', value: pendiente, tone: 'text-ember' },
  { label: 'Proyectado', value: proyectado, tone: 'text-violet' },
]
---

<AdminLayout title="Ingresos">
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-6">
    {cards.map((c) => (
      <div class="rounded-2xl glass p-5">
        <p class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200 mb-1.5">{c.label}</p>
        <p class={`text-2xl font-medium tracking-tight ${c.tone}`}>{fmtUSD(c.value)}</p>
      </div>
    ))}
    <a href="/admin/costs" class="rounded-2xl glass p-5 hover:bg-white/[.03] transition-colors">
      <p class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200 mb-1.5">Costo infra / mes</p>
      <p class="text-2xl font-medium tracking-tight text-cyan">{fmtUSD(costoMensualUSD)}</p>
      <p class="mt-1 text-[10px] font-mono text-cyan">ver costos →</p>
    </a>
  </div>

  <FinanceTable rows={rows} />
</AdminLayout>

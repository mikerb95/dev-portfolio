---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import DocsNav from '../../../components/admin/DocsNav.astro'
import { CASOS_DE_USO, CASOS_DE_USO_EXTENDIDOS, ACTORES } from '../../../data/documentacion'
---

<AdminLayout title="Casos de uso extendidos">
  <DocsNav />

  <div class="max-w-3xl mb-6">
    <p class="text-[13px] text-ink-200 leading-relaxed">
      Formato extendido (precondiciones, flujo principal, flujos alternos, excepciones y postcondiciones)
      para los {CASOS_DE_USO_EXTENDIDOS.length} casos de uso más críticos del sistema: los que involucran
      dinero, seguridad o estado que debe ser consistente ante fallos.
    </p>
  </div>

  <div class="space-y-8">
    {CASOS_DE_USO_EXTENDIDOS.map((ext) => {
      const cu = CASOS_DE_USO.find((c) => c.id === ext.id)!
      const actor = ACTORES.find((a) => a.id === cu.actor)
      return (
        <section class="rounded-xl border border-white/10 overflow-hidden text-[12.5px]">
          <table class="w-full border-collapse">
            <tbody>
              <tr>
                <td class="w-[160px] bg-cyan/15 text-cyan font-semibold uppercase tracking-wide text-[11px] px-3 py-2 border border-white/10">
                  Caso de uso
                </td>
                <td class="bg-cyan/15 text-ink-50 font-semibold px-3 py-2 border border-white/10">
                  <span class="font-mono text-[11px] text-cyan mr-2">{cu.id}</span>
                  {cu.nombre}
                  <span class="ml-2 text-[10.5px] font-medium px-2 py-0.5 rounded-full border bg-white/5 text-ink-200 border-white/20 align-middle">
                    {actor?.nombre}
                  </span>
                </td>
              </tr>

              <tr>
                <td class="bg-cyan/10 text-cyan font-semibold uppercase tracking-wide text-[11px] px-3 py-2 border border-white/10 align-top">
                  Descripción
                </td>
                <td class="text-ink-100 px-3 py-2 border border-white/10 align-top">{cu.resumen}</td>
              </tr>

              <tr>
                <td class="bg-cyan/10 text-cyan font-semibold uppercase tracking-wide text-[11px] px-3 py-2 border border-white/10 align-top">
                  Precondición
                </td>
                <td class="text-ink-100 px-3 py-2 border border-white/10 align-top">
                  {ext.precondiciones.join(' ')}
                </td>
              </tr>

              <tr>
                <td class="bg-cyan/10 text-cyan font-semibold uppercase tracking-wide text-[11px] px-3 py-2 border border-white/10 align-top">
                  Secuencia normal
                </td>
                <td class="p-0 border border-white/10">
                  <table class="w-full border-collapse">
                    <tbody>
                      <tr>
                        <td class="w-[64px] bg-white/[.04] text-ink-300 font-semibold uppercase tracking-wide text-[10.5px] px-3 py-1.5 border border-white/10">Paso</td>
                        <td class="bg-white/[.04] text-ink-300 font-semibold uppercase tracking-wide text-[10.5px] px-3 py-1.5 border border-white/10">Acción</td>
                      </tr>
                      {ext.flujoPrincipal.map((p, i) => (
                        <tr>
                          <td class="text-cyan font-mono text-[11.5px] text-center px-3 py-1.5 border border-white/10">{i + 1}</td>
                          <td class="text-ink-100 px-3 py-1.5 border border-white/10">{p}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </td>
              </tr>

              {ext.flujosAlternos.length > 0 && (
                <tr>
                  <td class="bg-violet/10 text-violet font-semibold uppercase tracking-wide text-[11px] px-3 py-2 border border-white/10 align-top">
                    Flujos alternos
                  </td>
                  <td class="text-ink-100 px-3 py-2 border border-white/10 align-top">
                    <div class="space-y-2">
                      {ext.flujosAlternos.map((alt) => (
                        <div>
                          <div class="text-[12px] font-medium text-violet mb-1">{alt.titulo}</div>
                          <ol class="space-y-0.5">
                            {alt.pasos.map((p, i) => (
                              <li class="text-[12px] text-ink-100 flex gap-2">
                                <span class="font-mono text-[10.5px] text-violet shrink-0">{i + 1}.</span>
                                <span>{p}</span>
                              </li>
                            ))}
                          </ol>
                        </div>
                      ))}
                    </div>
                  </td>
                </tr>
              )}

              <tr>
                <td class="bg-cyan/10 text-cyan font-semibold uppercase tracking-wide text-[11px] px-3 py-2 border border-white/10 align-top">
                  Postcondición
                </td>
                <td class="text-ink-100 px-3 py-2 border border-white/10 align-top">
                  {ext.postcondiciones.join(' ')}
                </td>
              </tr>

              {ext.excepciones.length > 0 && (
                <tr>
                  <td class="bg-ember/10 text-ember font-semibold uppercase tracking-wide text-[11px] px-3 py-2 border border-white/10 align-top">
                    Excepciones
                  </td>
                  <td class="p-0 border border-white/10">
                    <table class="w-full border-collapse">
                      <tbody>
                        <tr>
                          <td class="w-[64px] bg-white/[.04] text-ink-300 font-semibold uppercase tracking-wide text-[10.5px] px-3 py-1.5 border border-white/10">Paso</td>
                          <td class="bg-white/[.04] text-ink-300 font-semibold uppercase tracking-wide text-[10.5px] px-3 py-1.5 border border-white/10">Acción</td>
                        </tr>
                        {ext.excepciones.map((e, i) => (
                          <tr>
                            <td class="text-ember font-mono text-[11.5px] text-center px-3 py-1.5 border border-white/10">{i + 1}</td>
                            <td class="text-ink-100 px-3 py-1.5 border border-white/10">{e}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </section>
      )
    })}
  </div>
</AdminLayout>

---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import DocsNav from '../../../components/admin/DocsNav.astro'
import IteracionesBoard from '../../../components/IteracionesBoard.astro'
import { PARES, COLUMNAS, ITERACIONES, COMMITS_POR_MES, REPO } from '../../../data/iteraciones-portfolio'
---

<AdminLayout title="Kanban — Documentación">
  <DocsNav />

  <IteracionesBoard
    pares={PARES}
    columnas={COLUMNAS}
    iteraciones={ITERACIONES}
    commitsPorMes={COMMITS_POR_MES}
    repo={REPO}
    subtitle="Tablero XP del propio proyecto dev-portfolio, reconstruido del historial real de GitHub — cada historia con su Definition of Done, anclada a sus commits."
    showBiblio={false}
  />
</AdminLayout>

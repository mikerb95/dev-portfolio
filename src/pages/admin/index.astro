---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { db } from '../../db'
import { projects, messages, finances, clients, educationMilestones, projectServices, appSettings } from '../../db/schema'
import { eq, count, desc } from 'drizzle-orm'
import { parseRates, fmtUSD } from '../../lib/money'
import { monthlyCostUSD, projectPnL, type FinanceLike, type ServiceLike } from '../../lib/pnl'

const [
  visibleProjectsCount, unreadCount, clientsCount,
  allFinances, serviceRows, settingsRows, milestoneRows,
  projectsAll, recentMessages,
] = await Promise.all([
  db.select({ c: count() }).from(projects).where(eq(projects.visible, true)),
  db.select({ c: count() }).from(messages).where(eq(messages.read, false)),
  db.select({ c: count() }).from(clients),
  db.select({ amount: finances.amount, status: finances.status, projectId: finances.projectId }).from(finances),
  db.select({
    cost: projectServices.cost, currency: projectServices.currency, billingCycle: projectServices.billingCycle,
    active: projectServices.active, renewalDate: projectServices.renewalDate, projectId: projectServices.projectId,
  }).from(projectServices),
  db.select().from(appSettings),
  db.select({ status: educationMilestones.status }).from(educationMilestones),
  db.select({ id: projects.id, title: projects.title, status: projects.status, techStack: projects.techStack, startDate: projects.startDate, visible: projects.visible }).from(projects),
  db.select().from(messages).orderBy(desc(messages.createdAt)).limit(5),
])

const totalProjects = visibleProjectsCount[0]?.c ?? 0
const unreadMessages = unreadCount[0]?.c ?? 0
const totalClients = clientsCount[0]?.c ?? 0

const cobrado    = allFinances.filter((r) => r.status === 'cobrado').reduce((s, r) => s + r.amount, 0)
const pendiente  = allFinances.filter((r) => r.status === 'pendiente').reduce((s, r) => s + r.amount, 0)
const proyectado = allFinances.filter((r) => r.status === 'proyectado').reduce((s, r) => s + r.amount, 0)

const rates = parseRates(settingsRows)
const { total: costoMensualUSD } = monthlyCostUSD(serviceRows as ServiceLike[], rates)
const costoAnualUSD = costoMensualUSD * 12
const margenEstimado = cobrado - costoAnualUSD

const renewSoon = serviceRows.filter((s) => {
  if (!s.active || !s.renewalDate) return false
  const days = (new Date(s.renewalDate).getTime() - Date.now()) / 86_400_000
  return days <= 30
}).length

// P&L por proyecto
const finByProject = new Map<number, FinanceLike[]>()
for (const f of allFinances) {
  if (f.projectId == null) continue
  const arr = finByProject.get(f.projectId) ?? []
  arr.push(f)
  finByProject.set(f.projectId, arr)
}
const svcByProject = new Map<number, ServiceLike[]>()
for (const s of serviceRows) {
  if (s.projectId == null) continue
  const arr = svcByProject.get(s.projectId) ?? []
  arr.push(s as ServiceLike)
  svcByProject.set(s.projectId, arr)
}

const projectPnls = projectsAll
  .map((p) => ({ p, pnl: projectPnL(p, finByProject.get(p.id) ?? [], svcByProject.get(p.id) ?? [], rates) }))
  .filter((x) => x.pnl.ingresosCobrados > 0 || x.pnl.costoMensualUSD > 0)
  .sort((a, b) => b.pnl.margenEstimado - a.pnl.margenEstimado)
  .slice(0, 5)

const completados = milestoneRows.filter((m) => m.status === 'completado').length
const enCurso     = milestoneRows.filter((m) => m.status === 'en_curso').length
const evolutionPct = completados + enCurso > 0 ? Math.round((completados / (completados + enCurso)) * 100) : 0
---

<AdminLayout title="Dashboard">
  <!-- KPI bento -->
  <div class="grid grid-cols-12 gap-3 md:gap-4 mb-4">
    <!-- Cobrado — big tile -->
    <div class="col-span-12 md:col-span-6 rounded-2xl glass p-6 relative overflow-hidden">
      <div class="absolute inset-0 grid-bg opacity-30 pointer-events-none"></div>
      <div class="relative">
        <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200">Ingresos cobrados</div>
        <div class="mt-3 text-[40px] md:text-[44px] font-medium tracking-[-.02em] text-ink-50">{fmtUSD(cobrado)}</div>
        <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] font-mono">
          <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full border bg-lime/10 text-lime border-lime/30">
            <span class="w-1.5 h-1.5 rounded-full bg-lime"></span>cobrado
          </span>
          <span class="text-ink-300">{fmtUSD(pendiente)} pendiente</span>
          <span class="text-ink-300">{fmtUSD(proyectado)} proyectado</span>
        </div>
      </div>
    </div>

    {[
      { label: 'Proyectos visibles', value: String(totalProjects), sub: 'publicados', tone: 'text-cyan', icon: 'M2 7a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2z M8 7v10 M12 7v10' },
      { label: 'Mensajes sin leer', value: String(unreadMessages), sub: 'en bandeja', tone: 'text-violet', icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6' },
      { label: 'Clientes', value: String(totalClients), sub: 'registrados', tone: 'text-ember', icon: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 7m-4 0a4 4 0 1 0 8 0 4 4 0 0 0-8 0' },
    ].map((k) => (
      <div class="col-span-6 md:col-span-2 rounded-2xl glass p-5 flex flex-col justify-between min-h-[120px] md:min-h-[140px]">
        <div class="flex items-center justify-between">
          <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200">{k.label}</div>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ink-200"><path d={k.icon} /></svg>
        </div>
        <div>
          <div class={`text-3xl font-medium tracking-tight ${k.tone}`}>{k.value}</div>
          <div class="mt-1 text-[10px] font-mono text-ink-300">{k.sub}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- P&L row -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-6">
    <div class="rounded-2xl glass p-5">
      <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200">Costo infra / mes</div>
      <div class="mt-2 text-2xl font-medium text-cyan tracking-tight">{fmtUSD(costoMensualUSD)}</div>
      <div class="mt-1 text-[10px] font-mono text-ink-300">USD recurrente</div>
    </div>
    <div class="rounded-2xl glass p-5">
      <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200">Costo infra / año</div>
      <div class="mt-2 text-2xl font-medium text-ink-50 tracking-tight">{fmtUSD(costoAnualUSD)}</div>
      <div class="mt-1 text-[10px] font-mono text-ink-300">USD anualizado</div>
    </div>
    <div class="rounded-2xl glass p-5">
      <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200">Margen estimado</div>
      <div class={`mt-2 text-2xl font-medium tracking-tight ${margenEstimado >= 0 ? 'text-lime' : 'text-ember'}`}>{fmtUSD(margenEstimado)}</div>
      <div class="mt-1 text-[10px] font-mono text-ink-300">cobrado − costo anual</div>
    </div>
    <a href="/admin/costs" class="rounded-2xl glass p-5 hover:bg-white/[.03] transition-colors">
      <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200">Renovaciones ≤30d</div>
      <div class={`mt-2 text-2xl font-medium tracking-tight ${renewSoon > 0 ? 'text-ember' : 'text-ink-50'}`}>{renewSoon}</div>
      <div class="mt-1 text-[10px] font-mono text-cyan">ver costos →</div>
    </a>
  </div>

  <!-- Evolution + rentabilidad -->
  <div class="grid grid-cols-12 gap-4 mb-6">
    <div class="col-span-12 md:col-span-4 rounded-2xl glass p-6">
      <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200 mb-1">Evolution Path</div>
      <h3 class="text-lg font-medium text-ink-50 mb-4">Progreso de formación</h3>
      <div class="flex items-baseline gap-3 mb-3">
        <div class="text-[40px] font-medium tracking-tight text-cyan">{evolutionPct}%</div>
        <div class="text-[11px] font-mono text-ink-300">{completados} completados · {enCurso} en curso</div>
      </div>
      <div class="h-2 rounded-full bg-white/5 overflow-hidden">
        <div class="h-full bg-gradient-to-r from-cyan to-violet rounded-full transition-all" style={`width:${evolutionPct}%`}></div>
      </div>
      <a href="/admin/education" class="mt-4 inline-flex items-center gap-1 text-[11px] font-mono text-cyan hover:underline">Ver hitos ↗</a>
    </div>

    <div class="col-span-12 md:col-span-8 rounded-2xl glass p-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200">Rentabilidad</div>
          <h3 class="mt-1 text-lg font-medium text-ink-50">Margen por proyecto</h3>
        </div>
        <a href="/admin/costs" class="inline-flex items-center gap-1 text-[11px] font-mono text-cyan hover:underline">Costos ↗</a>
      </div>
      {projectPnls.length === 0 && <p class="text-[12px] font-mono text-ink-300 py-4">Aún no hay ingresos ni costos por proyecto.</p>}
      <div class="space-y-2">
        {projectPnls.map(({ p, pnl }) => (
          <a href={`/admin/projects/${p.id}`} class="flex items-center gap-3 md:gap-4 px-3 py-2.5 rounded-xl bg-white/[.02] border border-white/5 hover:bg-white/[.04] transition-colors">
            <div class="flex-1 min-w-0">
              <div class="text-[13px] text-ink-50 truncate">{p.title}</div>
              <div class="text-[10.5px] font-mono text-ink-300">{fmtUSD(pnl.ingresosCobrados)} ingresos · {fmtUSD(pnl.costoMensualUSD, 2)}/mes</div>
            </div>
            <div class={`text-[13px] font-mono shrink-0 ${pnl.margenEstimado >= 0 ? 'text-lime' : 'text-ember'}`}>{fmtUSD(pnl.margenEstimado)}</div>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Mensajes recientes -->
  <div class="rounded-2xl glass p-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200">Mensajes</div>
        <h3 class="mt-1 text-lg font-medium text-ink-50">Recibidos recientemente</h3>
      </div>
      <a href="/admin/messages" class="inline-flex items-center gap-1 text-[11px] font-mono text-cyan hover:underline">Ver todos ↗</a>
    </div>
    {recentMessages.length === 0 && <p class="text-[12px] font-mono text-ink-300 py-4">No hay mensajes todavía.</p>}
    <div class="space-y-2">
      {recentMessages.map((m) => (
        <div class={`flex items-start gap-4 px-4 py-3 rounded-xl border ${m.read ? 'border-white/5 bg-white/[.01]' : 'border-cyan/20 bg-cyan/[.03]'}`}>
          <div class={`w-2 h-2 rounded-full mt-2 shrink-0 ${m.read ? 'bg-ink-600' : 'bg-cyan pulse-dot'}`}></div>
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-baseline gap-x-3">
              <span class="text-[13px] text-ink-50 font-medium">{m.name}</span>
              <span class="text-[10.5px] font-mono text-ink-300">{m.email}</span>
            </div>
            {m.subject && <div class="text-[12px] text-ink-200 truncate">{m.subject}</div>}
          </div>
          <span class="text-[10px] font-mono text-ink-300 shrink-0">
            {m.createdAt ? new Date(m.createdAt).toLocaleDateString('es-CO', { day: 'numeric', month: 'short' }) : ''}
          </span>
        </div>
      ))}
    </div>
  </div>
</AdminLayout>

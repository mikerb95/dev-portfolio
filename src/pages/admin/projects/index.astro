---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { db } from '../../../db'
import { projects, clients } from '../../../db/schema'
import { desc, eq } from 'drizzle-orm'
import { parseTechStack } from '../../../lib/tech-stack'

const rows = await db
  .select({
    id: projects.id,
    slug: projects.slug,
    title: projects.title,
    status: projects.status,
    techStack: projects.techStack,
    startDate: projects.startDate,
    endDate: projects.endDate,
    visible: projects.visible,
    clientName: clients.name,
  })
  .from(projects)
  .leftJoin(clients, eq(projects.clientId, clients.id))
  .orderBy(desc(projects.createdAt))

const allClients = await db.select({ id: clients.id, name: clients.name }).from(clients)

const statusColors: Record<string, string> = {
  activo: 'text-cyan bg-cyan/10 border-cyan/30',
  pausado: 'text-violet bg-violet/10 border-violet/30',
  completado: 'text-lime bg-lime/10 border-lime/30',
  archivado: 'text-ink-300 bg-white/5 border-white/10',
}
const fmtDate = (d?: Date | null) =>
  d ? new Date(d).toLocaleDateString('es-CO', { year: 'numeric', month: 'short' }) : '—'
---

<AdminLayout title="Proyectos">
  <div class="flex items-center justify-between gap-3 mb-6">
    <p class="text-[12px] font-mono text-ink-300">{rows.length} proyecto{rows.length !== 1 ? 's' : ''}</p>
    <button id="btn-new" class="shrink-0 inline-flex items-center gap-2 h-9 px-4 text-[13px] font-medium rounded-full bg-cyan/15 text-cyan border border-cyan/30 hover:bg-cyan/25 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      Nuevo proyecto
    </button>
  </div>

  <!-- Formulario nuevo proyecto -->
  <div id="form-new" class="hidden mb-6 rounded-2xl glass p-5">
    <h2 class="text-[13px] font-medium text-ink-100 mb-4">Nuevo proyecto</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Slug *</label>
        <input id="new-slug" type="text" placeholder="mi-proyecto" class="input-base w-full rounded-lg px-3 py-2 text-[13px]" />
      </div>
      <div>
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Título *</label>
        <input id="new-title" type="text" placeholder="Mi Proyecto" class="input-base w-full rounded-lg px-3 py-2 text-[13px]" />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Descripción</label>
        <input id="new-description" type="text" class="input-base w-full rounded-lg px-3 py-2 text-[13px]" />
      </div>
      <div>
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Stack (coma)</label>
        <input id="new-stack" type="text" placeholder="Next.js, Tailwind, Supabase" class="input-base w-full rounded-lg px-3 py-2 text-[13px]" />
      </div>
      <div>
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Cliente</label>
        <select id="new-client" class="input-base w-full rounded-lg px-3 py-2 text-[13px]">
          <option value="">Sin cliente</option>
          {allClients.map((c) => <option value={c.id}>{c.name}</option>)}
        </select>
      </div>
      <div>
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Estado</label>
        <select id="new-status" class="input-base w-full rounded-lg px-3 py-2 text-[13px]">
          <option value="activo">Activo</option>
          <option value="pausado">Pausado</option>
          <option value="completado">Completado</option>
          <option value="archivado">Archivado</option>
        </select>
      </div>
      <div>
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Fecha inicio</label>
        <input id="new-start" type="date" class="input-base w-full rounded-lg px-3 py-2 text-[13px]" />
      </div>
      <div>
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Repo URL</label>
        <input id="new-repo" type="url" class="input-base w-full rounded-lg px-3 py-2 text-[13px]" />
      </div>
      <div>
        <label class="block text-[11px] font-mono uppercase tracking-wider text-ink-300 mb-1">Preview URL</label>
        <input id="new-preview" type="url" class="input-base w-full rounded-lg px-3 py-2 text-[13px]" />
      </div>
    </div>
    <div class="flex gap-2 mt-4">
      <button id="btn-save-new" class="h-9 px-4 text-[13px] font-medium rounded-full bg-cyan text-ink-950 hover:bg-cyan-glow transition-colors">Guardar</button>
      <button id="btn-cancel-new" class="h-9 px-4 text-[13px] rounded-full border border-white/10 text-ink-200 hover:bg-white/5 transition-colors">Cancelar</button>
    </div>
  </div>

  {rows.length === 0 ? (
    <div class="rounded-2xl glass px-5 py-10 text-center text-[12px] font-mono text-ink-300">No hay proyectos. Crea el primero.</div>
  ) : (
    <div class="rounded-2xl glass overflow-hidden">
      <!-- Cabecera (md+) -->
      <div class="hidden md:grid grid-cols-[2fr_1.3fr_1.5fr_1fr_.8fr_auto] gap-4 px-5 py-3 border-b border-white/5 text-[10px] font-mono uppercase tracking-[.18em] text-ink-300">
        <span>Proyecto</span><span>Cliente</span><span>Stack</span><span>Estado</span><span>Inicio</span><span></span>
      </div>
      {rows.map((p) => {
        const stack = parseTechStack(p.techStack)
        const stackLabel = stack.slice(0, 3).join(', ') + (stack.length > 3 ? ` +${stack.length - 3}` : '')
        return (
          <Fragment>
            <!-- Fila (md+) -->
            <a href={`/admin/projects/${p.id}`} class="hidden md:grid grid-cols-[2fr_1.3fr_1.5fr_1fr_.8fr_auto] gap-4 px-5 py-3.5 border-b border-white/[.03] hover:bg-white/[.02] items-center">
              <div class="min-w-0">
                <span class="text-[13px] font-medium text-ink-50 truncate block">{p.title}</span>
                <span class="text-[10px] text-ink-400 font-mono">{p.slug}</span>
              </div>
              <div class="text-[12px] font-mono text-ink-200 truncate">{p.clientName ?? '—'}</div>
              <div class="text-[11px] font-mono text-ink-300 truncate">{stackLabel || '—'}</div>
              <div>
                <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-mono uppercase tracking-wider border ${statusColors[p.status ?? 'activo']}`}>{p.status ?? 'activo'}</span>
              </div>
              <div class="text-[11px] font-mono text-ink-300">{fmtDate(p.startDate)}</div>
              <div class="text-ink-300"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg></div>
            </a>
            <!-- Tarjeta (móvil) -->
            <a href={`/admin/projects/${p.id}`} class="md:hidden flex items-center justify-between gap-3 px-4 py-3.5 border-b border-white/[.04]">
              <div class="min-w-0">
                <div class="text-[13px] font-medium text-ink-50 truncate">{p.title}</div>
                <div class="text-[10.5px] font-mono text-ink-300 truncate">{p.clientName ? `${p.clientName} · ` : ''}{stackLabel || p.slug}</div>
              </div>
              <span class={`shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-mono uppercase tracking-wider border ${statusColors[p.status ?? 'activo']}`}>{p.status ?? 'activo'}</span>
            </a>
          </Fragment>
        )
      })}
    </div>
  )}
</AdminLayout>

<script>
  const btnNew = document.getElementById('btn-new')!
  const formNew = document.getElementById('form-new')!
  const btnCancel = document.getElementById('btn-cancel-new')!
  const btnSave = document.getElementById('btn-save-new')!

  btnNew.addEventListener('click', () => formNew.classList.toggle('hidden'))
  btnCancel.addEventListener('click', () => formNew.classList.add('hidden'))

  btnSave.addEventListener('click', async () => {
    const slug = (document.getElementById('new-slug') as HTMLInputElement).value.trim()
    const title = (document.getElementById('new-title') as HTMLInputElement).value.trim()
    const description = (document.getElementById('new-description') as HTMLInputElement).value.trim()
    const stackRaw = (document.getElementById('new-stack') as HTMLInputElement).value.trim()
    const clientId = (document.getElementById('new-client') as HTMLSelectElement).value
    const status = (document.getElementById('new-status') as HTMLSelectElement).value
    const startDate = (document.getElementById('new-start') as HTMLInputElement).value
    const repoUrl = (document.getElementById('new-repo') as HTMLInputElement).value.trim()
    const previewUrl = (document.getElementById('new-preview') as HTMLInputElement).value.trim()

    if (!slug || !title) return alert('Slug y título son requeridos')

    const techStack = stackRaw ? JSON.stringify(stackRaw.split(',').map((s) => s.trim()).filter(Boolean)) : null

    const res = await fetch('/api/admin/projects', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        slug, title,
        description: description || null,
        techStack,
        repoUrl: repoUrl || null,
        previewUrl: previewUrl || null,
        clientId: clientId ? Number(clientId) : null,
        status,
        startDate: startDate || null,
      }),
    })

    if (res.ok) {
      const data = await res.json()
      window.location.href = `/admin/projects/${data.id}`
    } else {
      const err = await res.json()
      alert(err.error)
    }
  })
</script>

    <!-- Lista de ADRs -->
    <div id="adrs-list" class="flex flex-col gap-4">
      {adrs.length === 0 ? (
        <p class="text-zinc-600 text-sm">No hay decisiones documentadas para este proyecto.</p>
      ) : (
        adrs.map((adr, i) => (
          <div class="adr-card border border-zinc-800 rounded-lg overflow-hidden" data-id={adr.id}>
            <!-- Header del ADR -->

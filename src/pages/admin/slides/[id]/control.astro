---
import { db } from '../../../../db'
import { presentations, presentationSlides } from '../../../../db/schema'
import { eq, asc } from 'drizzle-orm'

const id = Number(Astro.params.id)
if (!id) return Astro.redirect('/admin')

const [pres] = await db
  .select({ id: presentations.id, title: presentations.title, currentSlide: presentations.currentSlide })
  .from(presentations)
  .where(eq(presentations.id, id))
  .limit(1)

if (!pres) return Astro.redirect('/admin')

const slides = await db.select({ url: presentationSlides.url })
  .from(presentationSlides)
  .where(eq(presentationSlides.presentationId, id))
  .orderBy(asc(presentationSlides.order))

const urls = slides.map(s => s.url)
const initial = pres.currentSlide ?? 0
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
  <title>Control · {pres.title}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      width: 100%; height: 100%;
      background: #050508;
      color: #e8e8f0;
      font-family: monospace;
      overscroll-behavior: none;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(5,5,8,0.95);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 12px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    header h1 { font-size: 13px; color: rgba(255,255,255,0.7); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 60%; }
    #counter-badge {
      font-size: 11px;
      background: rgba(0,242,255,0.1);
      border: 1px solid rgba(0,242,255,0.2);
      color: #00f2ff;
      padding: 3px 10px;
      border-radius: 20px;
    }

    /* Prev / Next bar */
    #nav {
      display: flex;
      gap: 8px;
      padding: 12px 16px;
    }
    .nav-btn {
      flex: 1;
      padding: 16px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      color: #e8e8f0;
      font-size: 20px;
      cursor: pointer;
      transition: background 0.1s;
      -webkit-tap-highlight-color: transparent;
    }
    .nav-btn:active { background: rgba(255,255,255,0.12); }
    .nav-btn:disabled { opacity: 0.2; cursor: default; }

    /* Grid de thumbnails */
    #grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      padding: 0 16px 32px;
    }
    .thumb {
      position: relative;
      border-radius: 8px;
      overflow: hidden;
      border: 2px solid transparent;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: border-color 0.15s;
      aspect-ratio: 16/9;
      background: rgba(255,255,255,0.04);
    }
    .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .thumb.active { border-color: #00f2ff; }
    .thumb .num {
      position: absolute;
      bottom: 4px;
      right: 5px;
      font-size: 9px;
      color: rgba(255,255,255,0.5);
    }
    .thumb.active .num { color: #00f2ff; }

    #empty { text-align: center; padding: 60px 16px; color: rgba(255,255,255,0.25); font-size: 13px; }
  </style>
</head>
<body>
  <header>
    <h1>{pres.title}</h1>
    <span id="counter-badge">— / {urls.length}</span>
  </header>

  {urls.length > 0 ? (
    <>
      <div id="nav">
        <button class="nav-btn" id="btn-prev">←</button>
        <button class="nav-btn" id="btn-next">→</button>
      </div>
      <div id="grid">
        {urls.map((url, i) => (
          <div class={`thumb${i === initial ? ' active' : ''}`} data-idx={i}>
            <img src={url} alt={`Slide ${i + 1}`} loading="lazy" />
            <span class="num">{i + 1}</span>
          </div>
        ))}
      </div>
    </>
  ) : (
    <p id="empty">Sin slides en esta presentación.</p>
  )}

  <script define:vars={{ presId: id, total: urls.length, initialSlide: initial }}>
    let current = initialSlide

    const badge = document.getElementById('counter-badge')
    const btnPrev = document.getElementById('btn-prev')
    const btnNext = document.getElementById('btn-next')
    const thumbs = document.querySelectorAll('.thumb')

    function updateUI(idx) {
      thumbs.forEach((t) => t.classList.toggle('active', Number(t.dataset.idx) === idx))
      badge.textContent = `${idx + 1} / ${total}`
      if (btnPrev) btnPrev.disabled = idx === 0
      if (btnNext) btnNext.disabled = idx === total - 1
    }

    async function goTo(idx) {
      if (idx < 0 || idx >= total) return
      current = idx
      updateUI(current)
      await fetch(`/api/slides/${presId}/slide`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slide: current }),
      })
    }

    thumbs.forEach((t) => t.addEventListener('click', () => goTo(Number(t.dataset.idx))))
    btnPrev?.addEventListener('click', () => goTo(current - 1))
    btnNext?.addEventListener('click', () => goTo(current + 1))

    updateUI(current)
  </script>
</body>
</html>

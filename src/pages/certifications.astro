---
import BaseLayout from '../layouts/BaseLayout.astro'
import { db } from '../db'
import { educationMilestones } from '../db/schema'
import { eq, desc } from 'drizzle-orm'

const certs = await db
  .select()
  .from(educationMilestones)
  .where(eq(educationMilestones.isPublic, true))
  .orderBy(desc(educationMilestones.completedDate), desc(educationMilestones.createdAt))

const byStatus = {
  completado: certs.filter((c) => c.status === 'completado'),
  en_curso: certs.filter((c) => c.status === 'en_curso'),
  pausado: certs.filter((c) => c.status === 'pausado'),
}

const statusLabel: Record<string, string> = {
  completado: 'Completado',
  en_curso: 'En curso',
  pausado: 'Pausado',
}

const statusStyle: Record<string, string> = {
  completado: 'text-emerald-400 bg-emerald-950',
  en_curso: 'text-blue-400 bg-blue-950',
  pausado: 'text-zinc-400 bg-zinc-800',
}
---

<BaseLayout
  title="Certificaciones"
  description="Formación técnica continua: certificaciones, cursos y habilidades adquiridas."
>
  <div class="max-w-4xl mx-auto px-6 py-16">
    <a href="/" class="text-zinc-500 hover:text-white text-sm mb-10 inline-block">← Volver</a>

    <header class="mb-14">
      <h1 class="text-3xl font-bold mb-3">Formación y certificaciones</h1>
      <p class="text-zinc-400 max-w-xl leading-relaxed">
        Aprendizaje técnico continuo. Cursos, certificaciones y habilidades que complementan la experiencia práctica.
      </p>
    </header>

    {certs.length === 0 && (
      <p class="text-zinc-600">No hay certificaciones publicadas aún.</p>
    )}

    <!-- En curso primero -->
    {byStatus.en_curso.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-5">En curso</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {byStatus.en_curso.map((c) => <CertCard cert={c} statusStyle={statusStyle} statusLabel={statusLabel} />)}
        </div>
      </section>
    )}

    <!-- Completados -->
    {byStatus.completado.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-5">Completados</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {byStatus.completado.map((c) => <CertCard cert={c} statusStyle={statusStyle} statusLabel={statusLabel} />)}
        </div>
      </section>
    )}

    <!-- Pausados -->
    {byStatus.pausado.length > 0 && (
      <section>
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-5">Pausados</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {byStatus.pausado.map((c) => <CertCard cert={c} statusStyle={statusStyle} statusLabel={statusLabel} />)}
        </div>
      </section>
    )}
  </div>
</BaseLayout>


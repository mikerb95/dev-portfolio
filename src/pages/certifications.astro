---
import BaseLayout from '../layouts/BaseLayout.astro'
import CertCard from '../components/CertCard.astro'
import { db } from '../db'
import { educationMilestones } from '../db/schema'
import { eq, desc } from 'drizzle-orm'

const certs = await db
  .select()
  .from(educationMilestones)
  .where(eq(educationMilestones.isPublic, true))
  .orderBy(desc(educationMilestones.completedDate), desc(educationMilestones.createdAt))

const byStatus = {
  en_curso: certs.filter((c) => c.status === 'en_curso'),
  completado: certs.filter((c) => c.status === 'completado'),
  pausado: certs.filter((c) => c.status === 'pausado'),
}
---

<BaseLayout
  title="Certificaciones — CodeByMike"
  description="Formación técnica continua: certificaciones, cursos y habilidades adquiridas."
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <header class="mb-16">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">/certifications</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
        <span>Formación continua</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-medium tracking-[-.035em] text-mask leading-[.95] mb-5">
        Formación y<br/>certificaciones.
      </h1>
      <p class="text-[16px] text-ink-100 max-w-xl leading-relaxed">
        Aprendizaje técnico continuo. Cursos, certificaciones y habilidades que complementan la experiencia práctica.
      </p>
    </header>

    {certs.length === 0 && (
      <div class="rounded-2xl glass p-12 text-center">
        <p class="text-[13px] font-mono text-ink-300">No hay certificaciones publicadas aún.</p>
      </div>
    )}

    {byStatus.en_curso.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan pulse-dot"></span>
          <span>En curso</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {byStatus.en_curso.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}

    {byStatus.completado.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-lime"></span>
          <span>Completados</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {byStatus.completado.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}

    {byStatus.pausado.length > 0 && (
      <section>
        <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-ink-400"></span>
          <span>Pausados</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {byStatus.pausado.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

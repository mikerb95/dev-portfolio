---
import BaseLayout from '../layouts/BaseLayout.astro'
import CertCard from '../components/CertCard.astro'
import { db } from '../db'
import { educationMilestones } from '../db/schema'
import { eq, desc } from 'drizzle-orm'

const certs = await db
  .select()
  .from(educationMilestones)
  .where(eq(educationMilestones.isPublic, true))
  .orderBy(desc(educationMilestones.completedDate), desc(educationMilestones.createdAt))

const byStatus = {
  en_curso: certs.filter((c) => c.status === 'en_curso'),
  completado: certs.filter((c) => c.status === 'completado'),
  pausado: certs.filter((c) => c.status === 'pausado'),
}
---

<BaseLayout
  title="Certificaciones — CodeByMike"
  description="Formación técnica continua: certificaciones, cursos y habilidades adquiridas."
>
  <div class="max-w-4xl mx-auto px-6 pt-36 pb-24">
    <a href="/" class="text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-white text-sm mb-10 inline-block transition-colors">← Volver</a>

    <header class="mb-14">
      <h1 class="text-3xl font-bold mb-3 text-slate-900 dark:text-white">Formación y certificaciones</h1>
      <p class="text-slate-500 dark:text-slate-400 max-w-xl leading-relaxed">
        Aprendizaje técnico continuo. Cursos, certificaciones y habilidades que complementan la experiencia práctica.
      </p>
    </header>

    {certs.length === 0 && (
      <p class="text-slate-400 dark:text-slate-600">No hay certificaciones publicadas aún.</p>
    )}

    {byStatus.en_curso.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-6">En curso</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {byStatus.en_curso.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}

    {byStatus.completado.length > 0 && (
      <section class="mb-14">
        <h2 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-6">Completados</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {byStatus.completado.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}

    {byStatus.pausado.length > 0 && (
      <section>
        <h2 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-6">Pausados</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {byStatus.pausado.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

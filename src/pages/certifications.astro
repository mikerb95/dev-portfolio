---
import BaseLayout from '../layouts/BaseLayout.astro'
import CertCard from '../components/CertCard.astro'
import { db } from '../db'
import { educationMilestones } from '../db/schema'
import { eq, desc } from 'drizzle-orm'

const certs = await db
  .select()
  .from(educationMilestones)
  .where(eq(educationMilestones.isPublic, true))
  .orderBy(desc(educationMilestones.completedDate), desc(educationMilestones.createdAt))

const byStatus = {
  en_curso: certs.filter((c) => c.status === 'en_curso'),
  completado: certs.filter((c) => c.status === 'completado'),
  pausado: certs.filter((c) => c.status === 'pausado'),
}
---

<BaseLayout
  title="Certificaciones — CodeByMike"
  description="Formación técnica continua: certificaciones, cursos y habilidades adquiridas."
  image="/og-certifications.png"
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <header class="mb-16">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">/certifications</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
        <span>Formación continua</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-medium tracking-[-.035em] text-mask leading-[.95] mb-5">
        Formación y<br/>certificaciones.
      </h1>
      <p class="text-[16px] text-ink-100 max-w-xl leading-relaxed">
        Aprendizaje técnico continuo. Cursos, certificaciones y habilidades que complementan la experiencia práctica.
      </p>
    </header>

    {certs.length === 0 && (
      <div class="rounded-2xl glass p-12 text-center">
        <p class="text-[13px] font-mono text-ink-300">No hay certificaciones publicadas aún.</p>
      </div>
    )}

    {byStatus.en_curso.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan pulse-dot"></span>
          <span>En curso</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {byStatus.en_curso.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}

    {byStatus.completado.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-lime"></span>
          <span>Completados</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {byStatus.completado.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}

    {byStatus.pausado.length > 0 && (
      <section>
        <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-ink-400"></span>
          <span>Pausados</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {byStatus.pausado.map((c) => <CertCard cert={c} />)}
        </div>
      </section>
    )}

    <!-- CTA Cards -->
    <section class="mt-20">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">//</span>
        <span>Ver perfil completo</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <!-- Platzi -->
        <a
          href="https://platzi.com/p/MichaelRodriguez/"
          target="_blank"
          rel="noopener"
          class="group rounded-2xl glass lift p-6 flex items-center gap-5 hover:border-cyan/30 transition-colors border border-white/5"
        >
          <div class="w-12 h-12 rounded-xl bg-[#98CA3F]/10 border border-[#98CA3F]/20 flex items-center justify-center shrink-0">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16 0C7.163 0 0 7.163 0 16s7.163 16 16 16 16-7.163 16-16S24.837 0 16 0z" fill="#98CA3F"/>
              <path d="M10.5 22.5V9.5l11 6.5-11 6.5z" fill="white"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[13px] font-mono uppercase tracking-[.12em] text-ink-300 mb-0.5">Platzi</p>
            <p class="text-[15px] font-medium text-ink-50 leading-snug">Ver mis cursos y rutas</p>
            <p class="text-[12px] text-ink-300 mt-1">Historial completo de aprendizaje</p>
          </div>
          <svg class="text-ink-400 group-hover:text-cyan transition-colors shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>

        <!-- LinkedIn -->
        <a
          href="https://www.linkedin.com/in/mdrb95/"
          target="_blank"
          rel="noopener"
          class="group rounded-2xl glass lift p-6 flex items-center gap-5 hover:border-cyan/30 transition-colors border border-white/5"
        >
          <div class="w-12 h-12 rounded-xl bg-[#0A66C2]/10 border border-[#0A66C2]/20 flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#0A66C2" xmlns="http://www.w3.org/2000/svg">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[13px] font-mono uppercase tracking-[.12em] text-ink-300 mb-0.5">LinkedIn</p>
            <p class="text-[15px] font-medium text-ink-50 leading-snug">Ver perfil profesional</p>
            <p class="text-[12px] text-ink-300 mt-1">Experiencia, skills y recomendaciones</p>
          </div>
          <svg class="text-ink-400 group-hover:text-cyan transition-colors shrink-0" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>

      </div>
    </section>

  </div>
</BaseLayout>

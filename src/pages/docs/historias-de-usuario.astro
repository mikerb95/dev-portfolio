---
import BaseLayout from '../../layouts/BaseLayout.astro'
import DocsNav from '../../components/DocsNav.astro'
import { ITERACIONES, type Historia } from '../../data/iteraciones-portfolio'

// Las historias ya viven en formato XP ("Como X, quiero Y para Z") dentro del
// kanban (iteraciones-portfolio.ts). Esta página las consolida en un catálogo
// propio, agrupado por el rol del actor extraído del propio título, sin
// duplicar datos ni tocar el tablero.
interface HistoriaConIteracion extends Historia {
  iterId: string
  iterNombre: string
  iterFase: string
}

const TODAS: HistoriaConIteracion[] = ITERACIONES.flatMap((it) =>
  it.historias.map((h) => ({ ...h, iterId: it.id, iterNombre: it.nombre, iterFase: it.fase }))
)

function extraerActor(titulo: string): string {
  const m = titulo.match(/^Como\s+([^,]+),/i)
  return m ? m[1].trim() : 'Sin actor'
}

const GRUPOS = new Map<string, HistoriaConIteracion[]>()
for (const h of TODAS) {
  const actor = extraerActor(h.titulo)
  if (!GRUPOS.has(actor)) GRUPOS.set(actor, [])
  GRUPOS.get(actor)!.push(h)
}

const TIPO_BADGE: Record<Historia['tipo'], string> = {
  historia: 'bg-cyan/10 text-cyan border-cyan/30',
  bug: 'bg-ember/10 text-ember border-ember/30',
  tarea: 'bg-white/5 text-ink-200 border-white/15',
  spike: 'bg-violet/10 text-violet border-violet/30',
}
const VALOR_DOT: Record<Historia['valor'], string> = {
  alto: 'bg-ember',
  medio: 'bg-violet',
  bajo: 'bg-ink-300',
}
const VALOR_BORDER: Record<Historia['valor'], string> = {
  alto: 'border-l-ember/50',
  medio: 'border-l-violet/50',
  bajo: 'border-l-white/10',
}
const COL_LABEL: Record<string, string> = {
  cola: 'Cola',
  iteracion: 'Planeada',
  desarrollo: 'En desarrollo',
  aceptacion: 'En aceptación',
  aceptada: 'Aceptada',
}

const totalAceptadas = TODAS.filter((h) => h.col === 'aceptada').length
---

<BaseLayout title="Historias de usuario">
  <DocsNav />

  <div class="max-w-3xl mb-6">
    <p class="text-[14.5px] text-ink-200 leading-relaxed">
      {TODAS.length} historias en formato XP ("Como &lt;actor&gt;, quiero &lt;acción&gt; para &lt;beneficio&gt;"),
      consolidadas desde el kanban del proyecto ({totalAceptadas} aceptadas de {TODAS.length}). Agrupadas por
      el rol del actor; cada una conserva su Definition of Done y la iteración de origen —
      <a href="/admin/docs/kanban" class="text-cyan hover:underline">ver en el tablero →</a>.
    </p>
  </div>

  <div class="space-y-8">
    {[...GRUPOS.entries()].map(([actor, historias]) => (
      <section>
        <h2 class="text-[14.5px] font-semibold uppercase tracking-wide text-cyan mb-4 pb-2 border-b border-cyan/15">
          Como {actor} <span class="text-ink-300 font-normal normal-case">({historias.length})</span>
        </h2>
        <div class="space-y-2">
          {historias.map((h) => (
            <div class={`rounded-xl border border-white/10 bg-white/[.025] p-3.5 border-l-2 ${VALOR_BORDER[h.valor]}`}>
              <div class="flex items-start justify-between gap-3 flex-wrap">
                <div class="flex items-center gap-2 min-w-0 flex-wrap">
                  <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${VALOR_DOT[h.valor]}`} title={`Valor ${h.valor}`}></span>
                  <span class="font-mono text-[12.5px] text-ink-300 shrink-0">{h.id}</span>
                  <span class={`shrink-0 text-[12px] font-medium px-2 py-0.5 rounded-full border uppercase tracking-wide ${TIPO_BADGE[h.tipo]}`}>
                    {h.tipo}
                  </span>
                </div>
                <span class="shrink-0 text-[12px] font-medium px-2 py-0.5 rounded-full border bg-white/5 text-ink-200 border-white/15">
                  {COL_LABEL[h.col] ?? h.col}
                </span>
              </div>
              <p class="text-[14.5px] text-ink-50 mt-2 leading-relaxed">{h.titulo}</p>
              <div class="flex items-center gap-2 flex-wrap mt-2">
                {h.tags.map((t) => (
                  <span class="text-[12px] text-ink-300 bg-white/5 rounded px-1.5 py-0.5">#{t}</span>
                ))}
                <span class="text-[12px] text-ink-300 ml-auto">{h.iterFase} · {h.iterNombre}</span>
              </div>
              {h.dod.length > 0 && (
                <ul class="mt-2.5 pt-2.5 border-t border-white/10 space-y-1">
                  {h.dod.map((d) => (
                    <li class="text-[13px] flex items-start gap-1.5">
                      <span class={`shrink-0 ${d.estado === 'pass' ? 'text-lime' : d.estado === 'fail' ? 'text-ember' : 'text-ink-300'}`}>
                        {d.estado === 'pass' ? '✓' : d.estado === 'fail' ? '✗' : '·'}
                      </span>
                      <span class="text-ink-200">{d.texto}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

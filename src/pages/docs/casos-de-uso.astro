---
import BaseLayout from '../../layouts/BaseLayout.astro'
import DocsNav from '../../components/DocsNav.astro'
import { ACTORES, CASOS_DE_USO } from '../../data/documentacion'

// Diagrama de casos de uso dibujado a mano como SVG (no con Mermaid): la
// notación UML exige actores como muñecos de palitos y casos de uso como
// óvalos dentro de un rectángulo de "límite del sistema". Mermaid no tiene
// un tipo "usecase" nativo y su layout automático (dagre) no deja controlar
// bien la posición de figuras humanas, así que se calcula la posición de
// cada elemento aquí mismo y se emite el SVG directo.
//
// Una caja de sistema POR ROL: cada actor tiene su propia caja con solo sus
// casos de uso adentro (no una única caja compartida por los 6 actores).
const ROW_H = 76
const ELLIPSE_RX = 150
const ELLIPSE_RY = 30
const ACTOR_X = 90
const BOUNDARY_PAD = 24
const BOUNDARY_X = 190
const TITLE_H = 30
const BLOCK_GAP = 50
const CU_CX = BOUNDARY_X + BOUNDARY_PAD + ELLIPSE_RX
const BOUNDARY_W = ELLIPSE_RX * 2 + BOUNDARY_PAD * 2

const actoresConCU = ACTORES.filter((a) => CASOS_DE_USO.some((c) => c.actor === a.id))

interface Row {
  label: string
  cy: number
}
interface Bloque {
  actor: (typeof ACTORES)[number]
  top: number
  height: number
  rows: Row[]
  actorCy: number
}

const bloques: Bloque[] = []
let top = 0
for (const actor of actoresConCU) {
  const cus = CASOS_DE_USO.filter((c) => c.actor === actor.id)
  const rows: Row[] = cus.map((cu, i) => ({
    label: `${cu.id}: ${cu.nombre}`,
    cy: top + TITLE_H + BOUNDARY_PAD + ELLIPSE_RY + i * ROW_H,
  }))
  const bottom = rows[rows.length - 1].cy + ELLIPSE_RY + BOUNDARY_PAD
  const height = bottom - top
  const actorCy = top + height / 2
  bloques.push({ actor, top, height, rows, actorCy })
  top = bottom + BLOCK_GAP
}

const SVG_W = BOUNDARY_X + BOUNDARY_W + 20
const SVG_H = top - BLOCK_GAP + 10

function actorFigure(cx: number, cy: number) {
  return `
    <circle cx="${cx}" cy="${cy - 26}" r="11" fill="none" stroke="#e7e7ec" stroke-width="2" />
    <line x1="${cx}" y1="${cy - 15}" x2="${cx}" y2="${cy + 15}" stroke="#e7e7ec" stroke-width="2" />
    <line x1="${cx - 16}" y1="${cy - 5}" x2="${cx + 16}" y2="${cy - 5}" stroke="#e7e7ec" stroke-width="2" />
    <line x1="${cx}" y1="${cy + 15}" x2="${cx - 14}" y2="${cy + 34}" stroke="#e7e7ec" stroke-width="2" />
    <line x1="${cx}" y1="${cy + 15}" x2="${cx + 14}" y2="${cy + 34}" stroke="#e7e7ec" stroke-width="2" />
  `
}

function wrappedLabel(cx: number, cy: number, w: number, h: number, text: string, fontSize: number) {
  return `<foreignObject x="${cx - w / 2}" y="${cy - h / 2}" width="${w}" height="${h}">
    <div xmlns="http://www.w3.org/1999/xhtml" style="font:${fontSize}px sans-serif;color:#e7e7ec;display:flex;align-items:center;justify-content:center;text-align:center;height:100%;line-height:1.25;">${text}</div>
  </foreignObject>`
}

let diagramSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="${SVG_W}" height="${SVG_H}" viewBox="0 0 ${SVG_W} ${SVG_H}">`

for (const { actor, cy } of actorPos) {
  const rs = rows.filter((r) => r.actorId === actor.id)
  for (const r of rs) {
    diagramSvg += `<line x1="${ACTOR_X + 16}" y1="${cy}" x2="${CU_CX - ELLIPSE_RX}" y2="${r.cy}" stroke="#8a8a99" stroke-width="1.2" />`
  }
}

diagramSvg += `<rect x="${BOUNDARY_X}" y="${BOUNDARY_Y}" width="${BOUNDARY_W}" height="${BOUNDARY_H}" fill="none" stroke="#8a8a99" stroke-width="1.5" />`
diagramSvg += `<text x="${BOUNDARY_X + 10}" y="${BOUNDARY_Y + 20}" fill="#7de1e8" font-size="13" font-family="sans-serif">Sistema · codebymike.tech</text>`

for (const r of rows) {
  diagramSvg += `<ellipse cx="${CU_CX}" cy="${r.cy}" rx="${ELLIPSE_RX}" ry="${ELLIPSE_RY}" fill="#1c1c26" stroke="#c4c4cc" stroke-width="1.5" />`
  diagramSvg += wrappedLabel(CU_CX, r.cy, ELLIPSE_RX * 2 - 20, ELLIPSE_RY * 2 - 8, r.label, 11.5)
}

for (const { actor, cy } of actorPos) {
  diagramSvg += actorFigure(ACTOR_X, cy)
  diagramSvg += wrappedLabel(ACTOR_X, cy + 52, 150, 30, actor.nombre, 11.5)
}

diagramSvg += `</svg>`
---

<BaseLayout title="Casos de uso">
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">
  <DocsNav />

  <div class="max-w-3xl mb-6">
    <p class="text-[14.5px] text-ink-200 leading-relaxed">
      {ACTORES.length} actores y {CASOS_DE_USO.length} casos de uso que cubren el ciclo completo del sistema:
      desde la exploración pública hasta el enforcement de seguridad y el procesamiento de pagos.
    </p>
  </div>

  <section class="mb-10">
    <h2 class="text-[14.5px] font-semibold uppercase tracking-wide text-cyan mb-4 pb-2 border-b border-cyan/15">Actores</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {ACTORES.map((a) => (
        <div class="rounded-xl border border-white/10 bg-white/[.025] p-3.5">
          <div class="text-[14.5px] font-medium text-ink-50">{a.nombre}</div>
          <p class="text-[13.5px] text-ink-200 mt-1 leading-relaxed">{a.descripcion}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-[14.5px] font-semibold uppercase tracking-wide text-cyan mb-4 pb-2 border-b border-cyan/15">Diagrama de casos de uso</h2>
    <div class="rounded-xl border border-white/15 bg-ink-800 p-4 overflow-auto flex justify-center" set:html={diagramSvg} />
  </section>

  <section>
    <h2 class="text-[14.5px] font-semibold uppercase tracking-wide text-cyan mb-4 pb-2 border-b border-cyan/15">Catálogo</h2>
    <div class="space-y-2">
      {CASOS_DE_USO.map((c) => {
        const actor = ACTORES.find((a) => a.id === c.actor)
        return (
          <div class="rounded-xl border border-white/10 bg-white/[.025] p-3.5">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-mono text-[12.5px] text-ink-300">{c.id}</span>
              <span class="text-[14.5px] font-medium text-ink-50">{c.nombre}</span>
              <span class="text-[12px] font-medium px-2 py-0.5 rounded-full border bg-cyan/10 text-cyan border-cyan/30">
                {actor?.nombre}
              </span>
            </div>
            <p class="text-[13.5px] text-ink-200 mt-1.5">{c.resumen}</p>
            <div class="flex gap-1.5 mt-2 flex-wrap">
              {c.rf.map((id) => (
                <span class="font-mono text-[12px] text-ink-300 bg-white/5 rounded px-1.5 py-0.5">{id}</span>
              ))}
            </div>
          </div>
        )
      })}
    </div>
  </section>
  </div>
</BaseLayout>

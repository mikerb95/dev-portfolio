---
import BaseLayout from '../../layouts/BaseLayout.astro'
import DocsNav from '../../components/DocsNav.astro'
import { ACTORES, CASOS_DE_USO, REQUISITOS_FUNCIONALES } from '../../data/documentacion'

// Diagrama de casos de uso dibujado a mano como SVG (no con Mermaid): la
// notación UML exige actores como muñecos de palitos y casos de uso como
// óvalos dentro de un rectángulo de "límite del sistema". Mermaid no tiene
// un tipo "usecase" nativo y su layout automático (dagre) no deja controlar
// bien la posición de figuras humanas, así que se calcula la posición de
// cada elemento aquí mismo y se emite el SVG directo.
//
// Una caja por (módulo × actor): igual que un diagrama UML de libro, la caja
// es el subsistema (lleva su nombre en una barra de título arriba) y a su
// izquierda va el único actor que participa en esos casos de uso.
const ROW_H = 76
const ELLIPSE_RX = 150
const ELLIPSE_RY = 30
const ACTOR_X = 90
const BOUNDARY_PAD = 24
const BOUNDARY_X = 190
const TITLE_H = 28
const BLOCK_GAP = 54
const CU_CX = BOUNDARY_X + BOUNDARY_PAD + ELLIPSE_RX
const CHAIN_GAP = 110 // espacio horizontal entre óvalos encadenados por <<include>> (debe caber la etiqueta)
const EXT_STEP = ELLIPSE_RY * 2 + 34 // paso vertical entre óvalos apilados por Extends

// Cada CU apunta a requerimientos funcionales (RF-xxx); el módulo del primero
// de ellos define a qué subsistema pertenece el caso de uso.
const moduloPorRf = new Map<string, string>()
for (const modulo of REQUISITOS_FUNCIONALES) {
  for (const item of modulo.items) moduloPorRf.set(item.id, modulo.nombre)
}
const moduloDeCU = (cu: (typeof CASOS_DE_USO)[number]) =>
  cu.rf.map((id) => moduloPorRf.get(id)).find(Boolean) ?? 'Sistema'

interface NodoDiagrama {
  cx: number
  cy: number
  label: string
  variante: 'principal' | 'relacionado'
}
interface Arco {
  x1: number
  y1: number
  x2: number
  y2: number
  tipo: 'include' | 'extends'
  etiqueta: string
}
interface Bloque {
  actor: (typeof ACTORES)[number]
  modulo: string
  top: number
  height: number
  width: number
  actorCy: number
  actorLineasY: number[]
}

// Agrupar por módulo y, dentro de cada módulo, por actor: un bloque por pareja.
const grupos = new Map<string, (typeof CASOS_DE_USO)[number][]>()
for (const cu of CASOS_DE_USO) {
  const clave = `${moduloDeCU(cu)}||${cu.actor}`
  const previos = grupos.get(clave)
  if (previos) previos.push(cu)
  else grupos.set(clave, [cu])
}

const nodos: NodoDiagrama[] = []
const arcos: Arco[] = []
const bloques: Bloque[] = []
let top = 0
let svgMaxX = 0

for (const [clave, cus] of grupos) {
  const [modulo, actorId] = clave.split('||')
  const actor = ACTORES.find((a) => a.id === actorId)
  if (!actor) continue

  const blockTop = top
  const actorLineasY: number[] = []
  let blockRight = CU_CX + ELLIPSE_RX
  let cy = blockTop + TITLE_H + BOUNDARY_PAD + ELLIPSE_RY

  for (const cu of cus) {
    nodos.push({ cx: CU_CX, cy, label: `${cu.id}: ${cu.nombre}`, variante: 'principal' })
    actorLineasY.push(cy)

    const relaciones = cu.relaciones ?? []
    const cadenaCx = new Map<string, number>([[cu.id, CU_CX]])

    // Cadenas de <<include>>: se extienden en horizontal, a la misma altura del CU.
    for (const rel of relaciones.filter((r) => r.tipo === 'include')) {
      const previoCx = cadenaCx.get(rel.despues ?? cu.id) ?? CU_CX
      const nodeCx = previoCx + ELLIPSE_RX * 2 + CHAIN_GAP
      nodos.push({ cx: nodeCx, cy, label: rel.nodo.nombre, variante: 'relacionado' })
      arcos.push({ x1: previoCx + ELLIPSE_RX, y1: cy, x2: nodeCx - ELLIPSE_RX, y2: cy, tipo: 'include', etiqueta: '<<include>>' })
      cadenaCx.set(rel.nodo.id, nodeCx)
      blockRight = Math.max(blockRight, nodeCx + ELLIPSE_RX)
    }

    // Extends: todos en una sola fila por debajo del CU, en abanico horizontal,
    // para que ninguna flecha tenga que atravesar otro óvalo apilado encima.
    const extendsRel = relaciones.filter((r) => r.tipo === 'extends')
    let maxExtendCy = cy
    if (extendsRel.length > 0) {
      const rowCy = cy + EXT_STEP
      extendsRel.forEach((rel, i) => {
        const baseCx = cadenaCx.get(rel.despues ?? cu.id) ?? CU_CX
        const nodeCx = baseCx + i * (ELLIPSE_RX * 2 + 40)
        nodos.push({ cx: nodeCx, cy: rowCy, label: rel.nodo.nombre, variante: 'relacionado' })
        arcos.push({ x1: nodeCx, y1: rowCy - ELLIPSE_RY, x2: baseCx, y2: cy + ELLIPSE_RY, tipo: 'extends', etiqueta: 'Extends' })
        blockRight = Math.max(blockRight, nodeCx + ELLIPSE_RX)
      })
      maxExtendCy = rowCy
    }

    cy = extendsRel.length > 0 ? maxExtendCy + ELLIPSE_RY + BOUNDARY_PAD + ELLIPSE_RY : cy + ROW_H
  }

  const bottom = cy - ROW_H + ELLIPSE_RY + BOUNDARY_PAD
  const height = bottom - blockTop
  const width = blockRight - BOUNDARY_X
  const actorCy = blockTop + TITLE_H + (height - TITLE_H) / 2
  bloques.push({ actor, modulo, top: blockTop, height, width, actorCy, actorLineasY })
  svgMaxX = Math.max(svgMaxX, blockRight)
  top = bottom + BLOCK_GAP
}

const SVG_W = svgMaxX + 20
const SVG_H = top - BLOCK_GAP + 10

function actorFigure(cx: number, cy: number) {
  return `
    <circle cx="${cx}" cy="${cy - 26}" r="11" fill="none" stroke="#e7e7ec" stroke-width="2" />
    <line x1="${cx}" y1="${cy - 15}" x2="${cx}" y2="${cy + 15}" stroke="#e7e7ec" stroke-width="2" />
    <line x1="${cx - 16}" y1="${cy - 5}" x2="${cx + 16}" y2="${cy - 5}" stroke="#e7e7ec" stroke-width="2" />
    <line x1="${cx}" y1="${cy + 15}" x2="${cx - 14}" y2="${cy + 34}" stroke="#e7e7ec" stroke-width="2" />
    <line x1="${cx}" y1="${cy + 15}" x2="${cx + 14}" y2="${cy + 34}" stroke="#e7e7ec" stroke-width="2" />
  `
}

function wrappedLabel(cx: number, cy: number, w: number, h: number, text: string, fontSize: number) {
  return `<foreignObject x="${cx - w / 2}" y="${cy - h / 2}" width="${w}" height="${h}">
    <div xmlns="http://www.w3.org/1999/xhtml" style="font:${fontSize}px sans-serif;color:#e7e7ec;display:flex;align-items:center;justify-content:center;text-align:center;height:100%;line-height:1.25;">${text}</div>
  </foreignObject>`
}

let diagramSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="${SVG_W}" height="${SVG_H}" viewBox="0 0 ${SVG_W} ${SVG_H}">`

diagramSvg += `<defs>
  <marker id="arrow-include" viewBox="0 0 10 10" markerWidth="8" markerHeight="8" refX="9" refY="5" markerUnits="userSpaceOnUse" orient="auto">
    <path d="M0,1 L9,5 L0,9" fill="none" stroke="#00f2ff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
  </marker>
  <marker id="arrow-extends" viewBox="0 0 10 10" markerWidth="10" markerHeight="10" refX="9" refY="5" markerUnits="userSpaceOnUse" orient="auto">
    <path d="M0,1 L9,5 L0,9 Z" fill="#1c1c26" stroke="#a78bff" stroke-width="1.4" stroke-linejoin="round" />
  </marker>
</defs>`

for (const { actorCy, actorLineasY } of bloques) {
  for (const y of actorLineasY) {
    diagramSvg += `<line x1="${ACTOR_X + 16}" y1="${actorCy}" x2="${CU_CX - ELLIPSE_RX}" y2="${y}" stroke="#8a8a99" stroke-width="1.2" />`
  }
}

for (const { modulo, top: blockTop, height, width } of bloques) {
  diagramSvg += `<rect x="${BOUNDARY_X}" y="${blockTop}" width="${width}" height="${height}" fill="none" stroke="#8a8a99" stroke-width="1.5" />`
  diagramSvg += `<rect x="${BOUNDARY_X}" y="${blockTop}" width="${width}" height="${TITLE_H}" fill="#20202b" stroke="#8a8a99" stroke-width="1.5" />`
  diagramSvg += `<text x="${BOUNDARY_X + width / 2}" y="${blockTop + TITLE_H / 2 + 4}" fill="#e7e7ec" font-size="12.5" font-weight="600" font-family="sans-serif" text-anchor="middle">${modulo}</text>`
}

for (const arco of arcos) {
  const stroke = arco.tipo === 'include' ? '#00f2ff' : '#a78bff'
  const marker = arco.tipo === 'include' ? 'url(#arrow-include)' : 'url(#arrow-extends)'
  diagramSvg += `<line x1="${arco.x1}" y1="${arco.y1}" x2="${arco.x2}" y2="${arco.y2}" stroke="${stroke}" stroke-width="1.3" stroke-dasharray="5,4" marker-end="${marker}" />`
  const mx = (arco.x1 + arco.x2) / 2
  const my = (arco.y1 + arco.y2) / 2
  const labelBg = arco.tipo === 'include' ? '#00f2ff' : '#a78bff'
  const anchorDy = arco.x1 === arco.x2 ? 0 : -6
  const anchorDx = arco.x1 === arco.x2 ? 14 : 0
  diagramSvg += `<text x="${mx + anchorDx}" y="${my + anchorDy}" fill="${labelBg}" font-size="10.5" font-style="italic" font-family="sans-serif" text-anchor="middle">${arco.etiqueta}</text>`
}

for (const nodo of nodos) {
  const isPrincipal = nodo.variante === 'principal'
  diagramSvg += `<ellipse cx="${nodo.cx}" cy="${nodo.cy}" rx="${ELLIPSE_RX}" ry="${ELLIPSE_RY}" fill="${isPrincipal ? '#1c1c26' : '#20202b'}" stroke="${isPrincipal ? '#c4c4cc' : '#8a8a99'}" stroke-width="1.5" />`
  diagramSvg += wrappedLabel(nodo.cx, nodo.cy, ELLIPSE_RX * 2 - 20, ELLIPSE_RY * 2 - 8, nodo.label, 11.5)
}

for (const { actor, actorCy } of bloques) {
  diagramSvg += actorFigure(ACTOR_X, actorCy)
  diagramSvg += wrappedLabel(ACTOR_X, actorCy + 52, 150, 30, actor.nombre, 11.5)
}

diagramSvg += `</svg>`
---

<BaseLayout title="Casos de uso">
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">
  <DocsNav />

  <div class="max-w-3xl mb-6">
    <p class="text-[14.5px] text-ink-200 leading-relaxed">
      {ACTORES.length} actores y {CASOS_DE_USO.length} casos de uso que cubren el ciclo completo del sistema:
      desde la exploración pública hasta el enforcement de seguridad y el procesamiento de pagos.
    </p>
  </div>

  <section class="mb-10">
    <h2 class="text-[14.5px] font-semibold uppercase tracking-wide text-cyan mb-4 pb-2 border-b border-cyan/15">Actores</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {ACTORES.map((a) => (
        <div class="rounded-xl border border-white/10 bg-white/[.025] p-3.5">
          <div class="text-[14.5px] font-medium text-ink-50">{a.nombre}</div>
          <p class="text-[13.5px] text-ink-200 mt-1 leading-relaxed">{a.descripcion}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-[14.5px] font-semibold uppercase tracking-wide text-cyan mb-4 pb-2 border-b border-cyan/15">Diagrama de casos de uso</h2>
    <div class="rounded-xl border border-white/15 bg-ink-800 p-4 overflow-auto flex justify-center" set:html={diagramSvg} />
  </section>

  <section>
    <h2 class="text-[14.5px] font-semibold uppercase tracking-wide text-cyan mb-4 pb-2 border-b border-cyan/15">Catálogo</h2>
    <div class="space-y-2">
      {CASOS_DE_USO.map((c) => {
        const actor = ACTORES.find((a) => a.id === c.actor)
        return (
          <div class="rounded-xl border border-white/10 bg-white/[.025] p-3.5">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="font-mono text-[12.5px] text-ink-300">{c.id}</span>
              <span class="text-[14.5px] font-medium text-ink-50">{c.nombre}</span>
              <span class="text-[12px] font-medium px-2 py-0.5 rounded-full border bg-cyan/10 text-cyan border-cyan/30">
                {actor?.nombre}
              </span>
            </div>
            <p class="text-[13.5px] text-ink-200 mt-1.5">{c.resumen}</p>
            <div class="flex gap-1.5 mt-2 flex-wrap">
              {c.rf.map((id) => (
                <span class="font-mono text-[12px] text-ink-300 bg-white/5 rounded px-1.5 py-0.5">{id}</span>
              ))}
            </div>
          </div>
        )
      })}
    </div>
  </section>
  </div>
</BaseLayout>

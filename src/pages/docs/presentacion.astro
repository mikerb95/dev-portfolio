---
// Deck de sustentación: resumen de /docs en formato presentación.
// Las cifras salen de las mismas fuentes que las páginas de documentación,
// así que no hay números escritos a mano que se desincronicen.
import SlidesLayout from '../../layouts/SlidesLayout.astro'
import {
  REQUISITOS_FUNCIONALES,
  REQUISITOS_NO_FUNCIONALES,
  CASOS_DE_USO,
  CASOS_DE_USO_EXTENDIDOS,
  ACTORES,
} from '../../data/documentacion'
import { ITERACIONES } from '../../data/iteraciones-portfolio'
import {
  NIVELES,
  PIPELINE,
  ESCENARIOS,
  METRICAS_REFERENCIA as TEST_REF,
  TOTAL_AUTOMATIZADOS,
} from '../../data/testing'

const rf = REQUISITOS_FUNCIONALES.flatMap((m) => m.items)
const rfTotal = rf.length
const rfImpl = rf.filter((r) => r.estado === 'implementado').length
const rnf = REQUISITOS_NO_FUNCIONALES.flatMap((m) => m.items)
const rnfTotal = rnf.length
const rnfImpl = rnf.filter((r) => r.estado === 'implementado').length
const cuTotal = CASOS_DE_USO.length
const historias = ITERACIONES.flatMap((i) => i.historias)
const commitsTotal = ITERACIONES.reduce((a, i) => a + i.commits, 0)

const nombreActor = (id: string) => ACTORES.find((a) => a.id === id)?.nombre ?? id

const kpis = [
  { valor: rfTotal, label: 'Req. funcionales', sub: `${rfImpl} implementados` },
  { valor: rnfTotal, label: 'Req. no funcionales', sub: 'ISO/IEC 25010' },
  { valor: cuTotal, label: 'Casos de uso', sub: `${ACTORES.length} actores` },
  { valor: historias.length, label: 'Historias XP', sub: `${ITERACIONES.length} iteraciones` },
]

const stack = [
  { grupo: 'Framework', items: ['Astro 7 (SSR, adapter Vercel)', 'Tailwind CSS 4'] },
  { grupo: 'Datos', items: ['Drizzle ORM', 'libSQL / Turso'] },
  { grupo: 'Auth', items: ['Auth.js (auth-astro)', 'GitHub OAuth + WebAuthn'] },
  { grupo: 'Almacenamiento', items: ['Vercel Blob (backups, screenshots)'] },
  { grupo: 'Observabilidad', items: ['Cron externo (cron-job.org)', 'ntfy.sh (push)', 'Web Vitals (RUM)'] },
  { grupo: 'Testing', items: ['Vitest + coverage v8'] },
]

const decisiones = [
  {
    titulo: 'Datos como código',
    detalle:
      'RF, RNF y casos de uso viven tipados en src/data/documentacion.ts; las páginas solo renderizan. Cambiar un requerimiento es un commit revisable, no un documento que se desincroniza.',
  },
  {
    titulo: 'Kanban sin duplicación',
    detalle:
      'IteracionesBoard se parametrizó con props, así /projects/dobleyo y /docs/kanban comparten el mismo motor de render con datos distintos.',
  },
  {
    titulo: 'Iteraciones ancladas al historial real',
    detalle:
      `Los rangos y los ${commitsTotal} commits salen de git log del repositorio, no de una estimación. Cada historia lleva su DoD verificado.`,
  },
  {
    titulo: 'Mermaid como dependencia, no CDN',
    detalle:
      'El CSP del panel es script-src \'self\', así que los diagramas se bundlean localmente. El texto queda versionado en el repo.',
  },
]

const diagramas = [
  { nombre: 'Secuencia', desc: 'Login OAuth, chequeo de monitor, enforcement de seguridad y webhook de pagos.' },
  { nombre: 'Componentes', desc: 'Navegador → Vercel (Astro SSR + middleware) → Turso, Blob, GitHub, ntfy, cron.' },
  { nombre: 'Clases', desc: 'Entidades del dominio derivadas de src/db/schema.ts, agrupadas por módulo.' },
  { nombre: 'Objetos', desc: 'Instantáneas reales: proyecto con servicios, pago con evento duplicado, IP bloqueada.' },
]

const cuDestacados = CASOS_DE_USO_EXTENDIDOS.map(
  (ext) => CASOS_DE_USO.find((c) => c.id === ext.id)!,
).filter(Boolean)

// Slide "El pipeline, paso a paso": el mismo escenario "Todo verde" que
// /docs/pipeline-en-vivo reproduce solo, pero aquí cada línea es un
// fragmento de Reveal — avanza con la misma tecla/clic que el resto del
// deck, nada de temporizadores.
const ESCENARIO_VERDE = ESCENARIOS.find((e) => e.id === 'verde')!
const NODO_DE_ETAPA: Record<string, string> = {
  local: 'push',
  push: 'push',
  ci: 'ci',
  deploy: 'deploy',
  verify: 'verify',
  operacion: 'operacion',
}
const NODOS_SIM = [
  { id: 'push', nombre: 'GitHub — push a main' },
  { id: 'ci', nombre: 'GitHub Actions — CI' },
  { id: 'deploy', nombre: 'Vercel — build + deploy' },
  { id: 'verify', nombre: '/api/health — verificación' },
  { id: 'turso', nombre: 'Turso — libSQL prod' },
  { id: 'operacion', nombre: 'Monitoreo continuo' },
]
---

<SlidesLayout title="Documentación de ingeniería — CodeByMike" light>
  {/* ── Portada ─────────────────────────────────────────────── */}
  <section class="deck-cover">
    <div class="cover-halo" aria-hidden="true"></div>
    <div class="eyebrow">Documentación de ingeniería</div>
    <h1 class="brand-mark">Code<span class="brand-by">By</span>Mike</h1>
    <p class="lede">
      Requerimientos, casos de uso, diagramas UML y el tablero del propio proyecto —
      un sistema en producción documentado con rigor formal.
    </p>
    <div class="cover-meta">
      <span>codebymike.tech</span>
      <span class="dot">·</span>
      <span>Mike (@mikerb95)</span>
    </div>
  </section>

  {/* ── Propósito ───────────────────────────────────────────── */}
  <section>
    <h2>Propósito</h2>
    <p class="body">
      Dejar <strong>trazabilidad formal del ciclo de vida</strong> — del requerimiento a la
      historia de usuario y su estado en el kanban — usando formatos reconocidos de
      ingeniería de software.
    </p>
    <div class="two-up">
      <div class="panel">
        <div class="panel-title">Evidencia académica</div>
        <p>Requerimientos, casos de uso extendidos y diagramas UML para sustentación.</p>
      </div>
      <div class="panel">
        <div class="panel-title">Referencia técnica real</div>
        <p>Documenta un sistema vivo en producción, no un ejercicio de papel.</p>
      </div>
    </div>
  </section>

  {/* ── Números ─────────────────────────────────────────────── */}
  <section>
    <h2>El proyecto en números</h2>
    <div class="kpi-row">
      {kpis.map((k) => (
        <div class="kpi fragment">
          <div class="kpi-value">{k.valor}</div>
          <div class="kpi-label">{k.label}</div>
          <div class="kpi-sub">{k.sub}</div>
        </div>
      ))}
    </div>
    <p class="foot">
      {commitsTotal} commits reales en {ITERACIONES.length} iteraciones · {rfImpl} de {rfTotal} RF
      implementados · {rnfImpl} de {rnfTotal} RNF verificados
    </p>
  </section>

  {/* ── Alcance ─────────────────────────────────────────────── */}
  <section>
    <h2>Alcance</h2>
    <div class="two-up">
      <div class="panel panel-in">
        <div class="panel-title">Dentro</div>
        <ul class="tight">
          <li>Sitio público de portafolio</li>
          <li>CRM interno (proyectos, clientes, briefings)</li>
          <li>Finanzas y P&amp;L por proyecto</li>
          <li>Observabilidad: monitoreo, SLO, alertas</li>
          <li>LAB: CI/CD con rollback, pagos, chaos</li>
          <li>Micro-SIEM: sensor, blocklist, rate limiting</li>
        </ul>
      </div>
      <div class="panel panel-out">
        <div class="panel-title">Fuera (por ahora)</div>
        <ul class="tight">
          <li>Multiusuario y roles — el panel es de un solo administrador</li>
          <li>Pasarela de pagos en producción real</li>
          <li>SAST y mutation testing automatizados</li>
        </ul>
      </div>
    </div>
  </section>

  {/* ── Stack ───────────────────────────────────────────────── */}
  <section>
    <h2>Stack técnico</h2>
    <div class="grid-3">
      {stack.map((s) => (
        <div class="panel">
          <div class="panel-title mono">{s.grupo}</div>
          <ul class="tight">{s.items.map((i) => <li>{i}</li>)}</ul>
        </div>
      ))}
    </div>
  </section>

  {/* ── Actores ─────────────────────────────────────────────── */}
  <section>
    <h2>Actores</h2>
    <p class="body">Tres humanos y tres sistemas externos interactúan con el portfolio.</p>
    <div class="grid-3">
      {ACTORES.map((a) => (
        <div class="panel">
          <div class="panel-title">{a.nombre}</div>
          <p>{a.descripcion}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ── RF (con verticales por módulo) ──────────────────────── */}
  <section>
    <section>
      <h2>Requerimientos funcionales</h2>
      <p class="body">
        {rfTotal} requerimientos en {REQUISITOS_FUNCIONALES.length} módulos. Cada uno declara
        dónde vive en el código y cómo se verifica.
      </p>
      <div class="grid-4">
        {REQUISITOS_FUNCIONALES.map((m) => (
          <div class="panel compact">
            <div class="panel-title">{m.nombre}</div>
            <div class="count">
              {m.items.filter((r) => r.estado === 'implementado').length}
              <span class="count-of">/{m.items.length}</span>
            </div>
            <div class="count-sub">implementados</div>
          </div>
        ))}
      </div>
      <p class="hint">↓ Convenciones de identificación</p>
    </section>
    <section>
      <h3>Convenciones de IDs</h3>
      <ul class="tight mono-list">
        <li><b>RF-0xx</b> público · <b>1xx</b> auth · <b>2xx</b> CRM · <b>3xx</b> finanzas</li>
        <li><b>RF-4xx</b> observabilidad · <b>5xx</b> LAB · <b>6xx</b> seguridad · <b>7xx</b> sistema</li>
        <li><b>RNF-nn</b> agrupados por categoría ISO/IEC 25010</li>
        <li><b>CU-nn</b> con trazabilidad al RF que realizan</li>
        <li><b>PF-&lt;iter&gt;-&lt;nn&gt;</b> historias del kanban</li>
      </ul>
    </section>
  </section>

  {/* ── RNF ─────────────────────────────────────────────────── */}
  <section>
    <section>
      <h2>Requerimientos no funcionales</h2>
      <p class="body">
        {rnfTotal} requerimientos por categoría ISO/IEC 25010, cada uno con una
        <strong> métrica verificable</strong> — no adjetivos.
      </p>
      <div class="grid-3">
        {REQUISITOS_NO_FUNCIONALES.map((m) => (
          <div class="panel compact">
            <div class="panel-title">{m.nombre}</div>
            <div class="count">{m.items.length}</div>
            <div class="count-sub">requerimientos</div>
          </div>
        ))}
      </div>
      <p class="hint">↓ Los más representativos</p>
    </section>
    <section>
      <h3>RNF representativos</h3>
      <ul class="tight rnf-list">
        {rnf.slice(0, 9).map((r) => (
          <li>
            <span class="tag mono">{r.id}</span>
            <span class="rnf-t">{r.titulo}</span>
            <span class={`estado estado-${r.estado}`}>{r.estado}</span>
          </li>
        ))}
      </ul>
    </section>
  </section>

  {/* ── Casos de uso ────────────────────────────────────────── */}
  <section>
    <section>
      <h2>Casos de uso</h2>
      <p class="body">
        {cuTotal} casos de uso, cada uno trazado al RF que realiza y al actor que lo dispara.
      </p>
      <div class="grid-2">
        {CASOS_DE_USO.slice(0, 10).map((c) => (
          <div class="cu">
            <span class="tag mono">{c.id}</span>
            <span class="cu-n">{c.nombre}</span>
            <span class="cu-a">{nombreActor(c.actor)}</span>
          </div>
        ))}
      </div>
      <p class="hint">↓ Formato extendido</p>
    </section>
    <section>
      <h3>Casos de uso extendidos</h3>
      <p class="body">
        {CASOS_DE_USO_EXTENDIDOS.length} de los CU críticos están documentados con
        precondiciones, flujo principal, flujos alternos, excepciones y postcondiciones.
      </p>
      <ul class="tight">
        {cuDestacados.map((c) => (
          <li><span class="tag mono">{c.id}</span> {c.nombre}</li>
        ))}
      </ul>
    </section>
  </section>

  {/* ── Diagramas ───────────────────────────────────────────── */}
  <section>
    <h2>Diagramas UML</h2>
    <p class="body">
      Escritos en Mermaid, versionados en el repo, renderizados en el cliente.
    </p>
    <div class="grid-2">
      {diagramas.map((d) => (
        <div class="panel">
          <div class="panel-title">{d.nombre}</div>
          <p>{d.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ── Video generado (HyperFrames) ───────────────────────────
      Slide de prueba: estructura lista para un .mp4 generado offline
      con HyperFrames (Puppeteer + FFmpeg, fuera del build de Vercel).
      Mientras no exista el clip real, el poster SVG evita un <video>
      roto en pantalla. ─────────────────────────────────────────── */}
  <section>
    <h2>Demo animada</h2>
    <p class="body">
      Clip generado offline con HyperFrames a partir de HTML/CSS versionado en
      el repo — no corre en el runtime de Vercel, solo el `.mp4` resultante se
      sube como asset estático.
    </p>
    <div class="video-frame">
      <video
        controls
        preload="none"
        poster="/videos/hyperframes-placeholder-poster.svg"
      >
        <source src="/videos/hyperframes-demo.mp4" type="video/mp4" />
      </video>
    </div>
    <p class="hint">↑ placeholder — pendiente de render con HyperFrames</p>
  </section>

  {/* ── Iteraciones ─────────────────────────────────────────── */}
  <section>
    <h2>Iteraciones</h2>
    <p class="body">
      {ITERACIONES.length} fases derivadas del historial real de git — {commitsTotal} commits,
      {' '}{historias.length} historias con su DoD.
    </p>
    <div class="timeline">
      {ITERACIONES.map((it) => (
        <div class="ti">
          <div class="ti-fase">{it.fase}</div>
          <div class="ti-nombre">{it.nombre}</div>
          <div class="ti-meta">
            <span class="mono">{it.rango}</span>
            <span class="ti-commits">{it.commits} commits</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* ── Testing: el pipeline ────────────────────────────────── */}
  <section>
    <h2>Cómo se prueba</h2>
    <p class="body">
      {TOTAL_AUTOMATIZADOS} pruebas automáticas en {TEST_REF.niveles} niveles distintos.
      Del portátil a producción, sin intervención humana.
    </p>
    <div class="timeline">
      {PIPELINE.slice(0, 4).map((e, i) => (
        <div class="ti fragment">
          <div class="ti-fase">{String(i + 1).padStart(2, '0')} · {e.nombre}</div>
          <div class="ti-nombre">{e.subtitulo}</div>
          <div class="ti-meta"><span class="mono">{e.duracion}</span></div>
        </div>
      ))}
    </div>
    <p class="foot">
      Y dos etapas más que casi nadie automatiza: <strong>verificación post-deploy con rollback</strong>
      {' '}(3 health checks, revierte solo si fallan 2) y <strong>operación continua</strong> (8 monitores cada 5 min).
    </p>
  </section>

  {/* ── Testing: pipeline paso a paso ──────────────────────── */}
  <section>
    <h2>El pipeline, paso a paso</h2>
    <p class="body">
      La misma corrida real de <a href="/docs/pipeline-en-vivo">/docs/pipeline-en-vivo</a>, pero cada evento
      espera al siguiente <kbd>→</kbd> en vez de reproducirse solo.
    </p>
    <div class="sim-grid">
      <ol class="sim-log" id="sim-log-deck">
        {ESCENARIO_VERDE.pasos.map((p) => (
          <li
            class="fragment sim-log-li"
            data-nodo={NODO_DE_ETAPA[p.etapa]}
            data-estado={p.estado}
          >
            <span class="sim-log-etapa">{PIPELINE.find((e) => e.id === p.etapa)?.nombre ?? p.etapa}</span>
            <span class="sim-log-txt">{p.texto}</span>
          </li>
        ))}
      </ol>
      <div class="sim-map" id="sim-map-deck">
        {NODOS_SIM.map((n) => (
          <div class="sim-nodo" data-nodo={n.id}>
            <span class="sim-nodo-dot"></span>{n.nombre}
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ── Testing: los niveles ────────────────────────────────── */}
  <section>
    <h2>{TEST_REF.niveles} niveles, {TEST_REF.tests} tests</h2>
    <div class="kpi-row">
      <div class="kpi fragment">
        <div class="kpi-value">{TEST_REF.tests}</div>
        <div class="kpi-label">Unitarios + integración</div>
        <div class="kpi-sub">Vitest, {TEST_REF.archivos} archivos</div>
      </div>
      <div class="kpi fragment">
        <div class="kpi-value">{TEST_REF.e2e}</div>
        <div class="kpi-label">End-to-end</div>
        <div class="kpi-sub">Playwright, navegador real</div>
      </div>
      <div class="kpi fragment">
        <div class="kpi-value">{TEST_REF.coberturaLineas}%</div>
        <div class="kpi-label">Cobertura</div>
        <div class="kpi-sub">líneas de src/lib</div>
      </div>
      <div class="kpi fragment">
        <div class="kpi-value">{NIVELES.filter((n) => !n.pendiente).length}</div>
        <div class="kpi-label">Niveles activos</div>
        <div class="kpi-sub">1 pendiente (carga)</div>
      </div>
    </div>
    <p class="foot">
      Cobertura dice «esta línea se ejecutó». <strong>Mutation testing</strong> dice «si la rompo,
      ¿algún test se entera?». Son preguntas distintas — detalle en /docs/testing.
    </p>
  </section>

  {/* ── Decisiones ──────────────────────────────────────────── */}
  <section>
    <h2>Decisiones de arquitectura</h2>
    <div class="grid-2">
      {decisiones.map((d) => (
        <div class="panel fragment">
          <div class="panel-title">{d.titulo}</div>
          <p>{d.detalle}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ── Cierre ──────────────────────────────────────────────── */}
  <section class="deck-cover">
    <div class="cover-halo" aria-hidden="true"></div>
    <div class="eyebrow">Documentación completa</div>
    <h2 class="close-h">codebymike.tech/docs</h2>
    <p class="lede">
      {rfTotal} RF · {rnfTotal} RNF · {cuTotal} casos de uso · {historias.length} historias ·
      {' '}{commitsTotal} commits
    </p>
    <div class="cover-meta">
      <span>Todo el contenido vive como datos tipados en el repositorio</span>
    </div>
  </section>
</SlidesLayout>

<style is:global>
  /* El deck usa el sistema del sitio (Inter / Instrument Serif / JetBrains Mono
     y los acentos de la paleta) sobre el fondo claro que define SlidesLayout.
     Reveal escala todo desde su font-size base, así que las medidas van en em. */
  .reveal-light .slides section {
    text-align: left;
    padding: 0 1.4em;
  }

  .reveal-light h2 {
    margin: 0 0 0.5em;
    line-height: 1.1;
  }
  .reveal-light h3 {
    margin: 0 0 0.6em;
  }

  .reveal-light .body {
    font-size: 0.46em;
    line-height: 1.55;
    color: var(--slide-fg-muted);
    max-width: 30em;
    margin: 0 0 1.2em;
  }
  .reveal-light .body strong {
    color: var(--slide-fg);
    font-weight: 600;
  }

  .reveal-light .foot,
  .reveal-light .hint {
    font-size: 0.34em;
    color: var(--slide-fg-muted);
    margin-top: 1.4em;
  }
  .reveal-light .hint {
    font-family: var(--font-mono, monospace);
    opacity: 0.6;
  }

  /* Portada y cierre */
  .reveal-light .deck-cover {
    position: relative;
  }
  /* Halo radial detrás de portada/cierre, igual criterio que el .halo del
     sitio (index.astro) pero contenido al slide y en tono claro. */
  .reveal-light .cover-halo {
    position: absolute;
    inset: -15% -10% auto -10%;
    height: 60%;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(
      55% 60% at 22% 30%,
      rgba(0, 242, 255, 0.14),
      rgba(0, 242, 255, 0) 70%
    );
  }
  .reveal-light .eyebrow {
    font-family: var(--font-mono, monospace);
    font-size: 0.32em;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--slide-accent);
    margin-bottom: 1em;
  }
  .reveal-light .deck-cover h1 {
    margin: 0 0 0.2em;
    line-height: 1;
  }
  /* Wordmark de marca: mismo patrón que Navbar/Footer del sitio (serif
     itálica, "By" en el acento cyan) en vez de un h1 genérico. */
  .reveal-light .brand-mark {
    font-style: italic;
    font-size: 3em;
    letter-spacing: -0.01em;
  }
  .reveal-light .brand-by {
    color: var(--slide-accent);
  }
  .reveal-light .close-h {
    font-size: 2em;
    margin: 0 0 0.25em;
  }
  .reveal-light .lede {
    font-size: 0.44em;
    line-height: 1.55;
    color: var(--slide-fg-muted);
    max-width: 26em;
    margin: 0 0 1.6em;
  }
  .reveal-light .cover-meta {
    font-family: var(--font-mono, monospace);
    font-size: 0.3em;
    color: var(--slide-fg-muted);
    display: flex;
    gap: 0.8em;
  }
  .reveal-light .cover-meta .dot {
    opacity: 0.5;
  }

  /* Rejillas */
  .reveal-light .two-up {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5em;
  }
  .reveal-light .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.4em;
  }
  .reveal-light .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4em;
  }
  .reveal-light .grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);

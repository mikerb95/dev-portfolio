<script>
  // Enciende los nodos del mapa al ritmo de Reveal, no de un timer propio.
  // Reveal marca cada .fragment revelado con class="visible" (y la quita al
  // retroceder); un MutationObserver sobre esa clase evita depender de su
  // API de eventos o de que SlidesLayout exponga la instancia global.
  const log = document.getElementById('sim-log-deck')
  const mapa = document.getElementById('sim-map-deck')

  if (log && mapa) {
    const nodos = new Map(
      [...mapa.querySelectorAll<HTMLElement>('[data-nodo]')].map((n) => [n.dataset.nodo!, n])
    )
    const items = [...log.querySelectorAll<HTMLElement>('[data-nodo]')]

    const aplicar = (li: HTMLElement) => {
      const nodo = nodos.get(li.dataset.nodo!)
      if (!nodo) return
      const visible = li.classList.contains('visible')
      if (!visible) {
        delete nodo.dataset.estado
        return
      }
      // "warn" en el escenario simulado representa una etapa en curso (el
      // mismo significado que 'in_progress' en /docs/pipeline-en-vivo).
      const estado = li.dataset.estado === 'warn' ? 'in_progress' : li.dataset.estado
      nodo.dataset.estado = estado
      // Turso no tiene fila propia en el log: se infiere encendida en el
      // mismo instante que "Verificación" pasa a ok, igual que en la
      // versión en vivo de esta página.
      if (li.dataset.nodo === 'verify' && estado === 'ok') {
        const turso = nodos.get('turso')
        if (turso) turso.dataset.estado = 'ok'
      }
    }

    const obs = new MutationObserver((muts) => {
      for (const m of muts) aplicar(m.target as HTMLElement)
    })
    for (const li of items) obs.observe(li, { attributes: true, attributeFilter: ['class'] })
  }
</script>

---
import BaseLayout from '../../layouts/BaseLayout.astro'
import DocsNav from '../../components/DocsNav.astro'
import RequisitosView from '../../components/admin/RequisitosView.astro'
import { REQUISITOS_FUNCIONALES } from '../../data/documentacion'

const total = REQUISITOS_FUNCIONALES.reduce((a, m) => a + m.items.length, 0)
const impl = REQUISITOS_FUNCIONALES.flatMap((m) => m.items).filter((r) => r.estado === 'implementado').length
---

<BaseLayout title="Requerimientos funcionales">
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">
  <DocsNav />
  <RequisitosView
    modulos={REQUISITOS_FUNCIONALES}
    unidad="req. funcionales"
    intro={`${total} requerimientos funcionales agrupados por módulo, con prioridad, estado real de implementación y su origen en el código. ${impl} de ${total} ya están implementados en producción. Filtra por estado o prioridad, o busca por ID, título o ruta.`}
  />
  </div>
</BaseLayout>

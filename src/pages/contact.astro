---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Contacto — CodeByMike"
  description="Contáctame para hablar de tu proyecto o colaboración."
  image="/og-contact.png"
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <div class="grid md:grid-cols-12 gap-10">

      <!-- Left rail -->
      <div class="md:col-span-5">
        <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
          <span class="text-cyan">/contact</span>
          <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
          <span>Intake</span>
        </div>
        <h1 class="font-sans text-5xl md:text-6xl font-medium tracking-[-.03em] text-mask leading-[1] max-w-md mb-5">
          Cuéntame qué estás construyendo.
        </h1>
        <p class="text-[15px] text-ink-100 leading-relaxed max-w-md mb-10">
          Puedo ayudarte a escalar tu producto, revisar tu arquitectura o construir desde cero. Primera respuesta en menos de 24 horas.
        </p>

        <div class="space-y-4 max-w-md mb-10">
          <div class="flex items-start gap-3 text-[13px] text-ink-200">
            <svg class="w-4 h-4 mt-0.5 text-cyan shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
            <span>Proyectos full-stack, arquitectura, performance y consultoría técnica.</span>
          </div>
          <div class="flex items-start gap-3 text-[13px] text-ink-200">
            <svg class="w-4 h-4 mt-0.5 text-cyan shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>Respondo en menos de 24 horas de lunes a viernes.</span>
          </div>
          <div class="flex items-start gap-3 text-[13px] text-ink-200">
            <svg class="w-4 h-4 mt-0.5 text-cyan shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Colombia · GMT−5 · Remoto global disponible.</span>
          </div>
        </div>

        <div class="glass rounded-2xl p-5 max-w-md">
          <div class="text-[10px] font-mono uppercase tracking-[.2em] text-ink-200 mb-3">Contacto directo</div>
          <ul class="space-y-2 text-[13px] text-ink-100">
            <li>
              <a href="mailto:mikedrb@proton.me" class="hover:text-cyan transition-colors flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-ink-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                mikedrb@proton.me
              </a>
            </li>
            <li>
              <a href="https://wa.me/573104641228" target="_blank" rel="noopener" class="hover:text-cyan transition-colors flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-ink-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.69a16 16 0 0 0 6.29 6.29l.94-.94a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                +57 310 464 1228 · WhatsApp
              </a>
            </li>
            <li>
              <a href="https://www.linkedin.com/in/mdrb95/" target="_blank" rel="noopener" class="hover:text-cyan transition-colors flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-ink-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                LinkedIn ↗
              </a>
            </li>
          </ul>
        </div>

        <a
          href="/cv/descargar"
          class="mt-4 w-full inline-flex items-center justify-center gap-2 h-11 px-5 text-[13px] font-medium rounded-full border border-white/15 text-ink-100 hover:border-cyan/40 hover:text-cyan transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          Descargar CV
        </a>
      </div>

      <!-- Form -->
      <div class="md:col-span-7">
        <div class="rounded-2xl glass border-grad p-7 relative">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-cyan pulse-dot"></span>
              <span class="text-[11px] font-mono uppercase tracking-[.2em] text-ink-100">Formulario</span>
            </div>
            <span class="text-[11px] font-mono text-ink-300" id="field-count">0/4 campos</span>
          </div>

          <form id="contact-form" class="grid md:grid-cols-2 gap-4">
            <label class="block">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[11px] font-mono uppercase tracking-wider text-ink-100">Nombre</span>
                <span class="text-[10px] font-mono text-ink-300" id="hint-name"></span>
              </div>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Tu nombre"
                class="input-base w-full rounded-lg px-3 py-2.5 text-[13px] placeholder:text-ink-300"
              />
            </label>

            <label class="block">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[11px] font-mono uppercase tracking-wider text-ink-100">Email</span>
                <span class="text-[10px] font-mono text-ink-300" id="hint-email"></span>
              </div>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="tu@email.com"
                class="input-base w-full rounded-lg px-3 py-2.5 text-[13px] placeholder:text-ink-300"
              />
            </label>

            <label class="block">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[11px] font-mono uppercase tracking-wider text-ink-100">Asunto</span>
                <span class="text-[10px] font-mono text-ink-300" id="hint-subject"></span>
              </div>
              <input
                id="subject"
                name="subject"
                type="text"
                placeholder="¿De qué trata tu proyecto?"
                class="input-base w-full rounded-lg px-3 py-2.5 text-[13px] placeholder:text-ink-300"
              />
            </label>

            <div class="md:col-span-2 block">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[11px] font-mono uppercase tracking-wider text-ink-100">Mensaje</span>
                <span class="text-[10px] font-mono text-ink-300" id="hint-body"></span>
              </div>
              <textarea
                id="body"
                name="body"
                required
                rows="5"
                placeholder="Cuéntame qué estás construyendo, dónde estás atascado, o qué necesitas."
                class="input-base w-full rounded-lg px-3 py-2.5 text-[13px] placeholder:text-ink-300 resize-none leading-relaxed"
              ></textarea>
            </div>

            <div class="md:col-span-2 flex items-center justify-between gap-4 pt-2">
              <div class="flex items-center gap-2 text-[11px] font-mono text-ink-300">
                <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="11" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Enviado sobre TLS
              </div>
              <button
                type="submit"
                id="submit-btn"
                class="inline-flex items-center gap-2 h-12 px-5 text-[14px] font-medium rounded-full bg-cyan text-ink-950 hover:brightness-110 transition-all disabled:opacity-40 disabled:cursor-not-allowed"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                Enviar mensaje
              </button>
            </div>
          </form>

          <p id="form-status" class="mt-4 text-[13px] font-mono hidden"></p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const status = document.getElementById('form-status') as HTMLParagraphElement
  const fieldCount = document.getElementById('field-count') as HTMLSpanElement

  const inputs = {
    name: document.getElementById('name') as HTMLInputElement,
    email: document.getElementById('email') as HTMLInputElement,
    body: document.getElementById('body') as HTMLTextAreaElement,
    subject: document.getElementById('subject') as HTMLInputElement,
  }

  const hints = {
    name: document.getElementById('hint-name') as HTMLSpanElement,
    email: document.getElementById('hint-email') as HTMLSpanElement,
    body: document.getElementById('hint-body') as HTMLSpanElement,
    subject: document.getElementById('hint-subject') as HTMLSpanElement,
  }

  function validateField(id: string, value: string): boolean {
    const input = inputs[id as keyof typeof inputs]
    const hint = hints[id as keyof typeof hints]
    if (!input) return true

    let ok = false
    let msg = ''

    if (id === 'name') {
      ok = value.length >= 2
      msg = ok ? '✓ Ok' : value ? `✗ Mínimo 2 caracteres` : ''
    } else if (id === 'email') {
      ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)
      msg = ok ? '✓ Ok' : value ? '✗ Email inválido' : ''
    } else if (id === 'body') {
      ok = value.length >= 20
      msg = ok ? `✓ ${value.length} chars` : value ? `✗ ${value.length}/20 mín.` : ''
    } else if (id === 'subject') {
      return true
    }

    input.classList.remove('input-ok', 'input-bad')
    if (value) {
      input.classList.add(ok ? 'input-ok' : 'input-bad')
    }

    if (hint) {
      hint.textContent = msg
      hint.className = `text-[10px] font-mono ${ok ? 'text-cyan' : 'text-ember'}`
    }

    return ok
  }

  function updateCount() {
    const required = ['name', 'email', 'body']
    const okCount = required.filter(id => validateField(id, inputs[id as keyof typeof inputs]?.value ?? '')).length
    fieldCount.textContent = `${okCount}/${required.length} campos`
  }

  Object.keys(inputs).forEach(id => {
    const input = inputs[id as keyof typeof inputs]
    input?.addEventListener('input', () => {
      validateField(id, input.value)
      updateCount()
    })
  })

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    const data = Object.fromEntries(new FormData(form))

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (res.ok) {
        form.reset()
        Object.values(inputs).forEach(el => el.classList.remove('input-ok', 'input-bad'))
        Object.values(hints).forEach(el => { el.textContent = ''; })
        fieldCount.textContent = '0/3 campos'
        status.textContent = '✓ Mensaje enviado. Te respondo en menos de 24 horas.'
        status.className = 'mt-4 text-[13px] font-mono text-cyan'
      } else {
        status.textContent = '✗ Error al enviar. Intenta de nuevo.'
        status.className = 'mt-4 text-[13px] font-mono text-ember'
      }
    } catch {
      status.textContent = '✗ Error de red. Intenta de nuevo.'
      status.className = 'mt-4 text-[13px] font-mono text-ember'
    }

    status.classList.remove('hidden')
  })
</script>

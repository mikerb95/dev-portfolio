---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Contacto">
  <div class="max-w-xl mx-auto px-6 py-16">
    <a href="/" class="text-zinc-500 hover:text-white text-sm mb-8 inline-block">← Volver</a>
    <h1 class="text-3xl font-bold mb-2">Contacto</h1>
    <p class="text-zinc-400 mb-6">Envíame un mensaje y te respondo a la brevedad.</p>
    <div class="flex flex-col gap-1 mb-8 text-sm text-zinc-500">
      <a href="mailto:mike95@duck.com" class="hover:text-zinc-300 transition-colors">mike95@duck.com</a>
      <a href="tel:+573104641228" class="hover:text-zinc-300 transition-colors">+57 310 464 1228</a>
      <span>Colombia · Remoto e híbrido internacional</span>
    </div>

    <form id="contact-form" class="flex flex-col gap-4">
      <div>
        <label class="block text-sm text-zinc-300 mb-1" for="name">Nombre</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full px-4 py-2.5 bg-zinc-900 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:border-zinc-500"
        />
      </div>
      <div>
        <label class="block text-sm text-zinc-300 mb-1" for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full px-4 py-2.5 bg-zinc-900 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:border-zinc-500"
        />
      </div>
      <div>
        <label class="block text-sm text-zinc-300 mb-1" for="subject">Asunto</label>
        <input
          id="subject"
          name="subject"
          type="text"
          class="w-full px-4 py-2.5 bg-zinc-900 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:border-zinc-500"
        />
      </div>
      <div>
        <label class="block text-sm text-zinc-300 mb-1" for="body">Mensaje</label>
        <textarea
          id="body"
          name="body"
          required
          rows="5"
          class="w-full px-4 py-2.5 bg-zinc-900 border border-zinc-700 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:border-zinc-500 resize-none"
        />
      </div>
      <button
        type="submit"
        class="px-6 py-2.5 bg-white text-zinc-900 font-medium rounded-lg hover:bg-zinc-100 transition-colors"
      >
        Enviar mensaje
      </button>
      <p id="form-status" class="text-sm hidden"></p>
    </form>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const status = document.getElementById('form-status') as HTMLParagraphElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    const data = Object.fromEntries(new FormData(form))

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (res.ok) {
        form.reset()
        status.textContent = 'Mensaje enviado. ¡Gracias!'
        status.className = 'text-sm text-emerald-400'
      } else {
        status.textContent = 'Error al enviar. Intenta de nuevo.'
        status.className = 'text-sm text-red-400'
      }
    } catch {
      status.textContent = 'Error de red. Intenta de nuevo.'
      status.className = 'text-sm text-red-400'
    }

    status.classList.remove('hidden')
  })
</script>

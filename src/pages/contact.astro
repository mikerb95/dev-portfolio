---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Contacto — CodeByMike">
  <div class="max-w-xl mx-auto px-6 pt-36 pb-24">
    <a href="/" class="text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-white text-sm mb-10 inline-block transition-colors">← Volver</a>

    <h1 class="text-3xl font-bold mb-2 text-slate-900 dark:text-white">Contacto</h1>
    <p class="text-slate-500 dark:text-slate-400 mb-6">Envíame un mensaje y te respondo a la brevedad.</p>

    <div class="flex flex-col gap-1 mb-8 text-sm text-slate-400 dark:text-slate-500">
      <a href="mailto:mdrb95@gmail.com" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">mdrb95@gmail.com</a>
      <a href="https://wa.me/573104641228" target="_blank" rel="noopener" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">+57 310 464 1228 · WhatsApp</a>
      <span>Colombia · Remoto e híbrido internacional</span>
    </div>

    <div class="flex gap-4 mb-10 text-sm">
      <a href="https://www.linkedin.com/in/mdrb95/" target="_blank" rel="noopener" class="text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">LinkedIn</a>
      <a href="https://github.com/mikerb95" target="_blank" rel="noopener" class="text-slate-400 dark:text-slate-500 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">GitHub</a>
    </div>

    <form id="contact-form" class="flex flex-col gap-4">
      <div>
        <label class="block text-sm text-slate-700 dark:text-slate-300 mb-1.5" for="name">Nombre</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          class="w-full px-4 py-2.5 bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-lg text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600 focus:outline-none focus:border-brand-500 dark:focus:border-brand-500 transition-colors"
        />
      </div>
      <div>
        <label class="block text-sm text-slate-700 dark:text-slate-300 mb-1.5" for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          class="w-full px-4 py-2.5 bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-lg text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600 focus:outline-none focus:border-brand-500 dark:focus:border-brand-500 transition-colors"
        />
      </div>
      <div>
        <label class="block text-sm text-slate-700 dark:text-slate-300 mb-1.5" for="subject">Asunto</label>
        <input
          id="subject"
          name="subject"
          type="text"
          class="w-full px-4 py-2.5 bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-lg text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600 focus:outline-none focus:border-brand-500 dark:focus:border-brand-500 transition-colors"
        />
      </div>
      <div>
        <label class="block text-sm text-slate-700 dark:text-slate-300 mb-1.5" for="body">Mensaje</label>
        <textarea
          id="body"
          name="body"
          required
          rows="5"
          class="w-full px-4 py-2.5 bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-lg text-slate-900 dark:text-white placeholder-slate-400 dark:placeholder-slate-600 focus:outline-none focus:border-brand-500 dark:focus:border-brand-500 transition-colors resize-none"
        />
      </div>
      <button
        type="submit"
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-slate-900 px-6 py-3 text-base font-medium text-white shadow-lg shadow-slate-900/20 transition hover:bg-slate-800 focus:outline-none dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100"
      >
        Enviar mensaje
      </button>
      <p id="form-status" class="text-sm hidden"></p>
    </form>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const status = document.getElementById('form-status') as HTMLParagraphElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    const data = Object.fromEntries(new FormData(form))

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })

      if (res.ok) {
        form.reset()
        status.textContent = 'Mensaje enviado. ¡Gracias!'
        status.className = 'text-sm text-emerald-600 dark:text-emerald-400'
      } else {
        status.textContent = 'Error al enviar. Intenta de nuevo.'
        status.className = 'text-sm text-red-600 dark:text-red-400'
      }
    } catch {
      status.textContent = 'Error de red. Intenta de nuevo.'
      status.className = 'text-sm text-red-600 dark:text-red-400'
    }

    status.classList.remove('hidden')
  })
</script>

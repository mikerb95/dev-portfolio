---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Engineering Log — CodeByMike"
  description="Registro de actividad de desarrollo en tiempo real. Commits, decisiones y métricas de trabajo profundo."
>
  <div class="max-w-3xl mx-auto px-6 pt-36 pb-24">
    <a href="/" class="text-slate-400 dark:text-slate-500 hover:text-slate-900 dark:hover:text-white text-sm mb-10 inline-block transition-colors">← Volver</a>

    <header class="mb-12">
      <h1 class="text-3xl font-bold mb-3 text-slate-900 dark:text-white">Engineering Log</h1>
      <p class="text-slate-500 dark:text-slate-400 text-base max-w-lg leading-relaxed">
        Actividad de desarrollo extraída en tiempo real de GitHub.
        Cada commit es evidencia de trabajo real en curso.
      </p>
    </header>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-12">
      <div class="border border-slate-200 dark:border-slate-800 rounded-lg px-4 py-4 bg-white/50 dark:bg-slate-900/20">
        <p class="text-slate-400 dark:text-slate-600 text-xs mb-2">Deep Work · 7 días</p>
        <p class="text-2xl font-bold text-slate-900 dark:text-white" id="stat-week">—</p>
        <p class="text-slate-400 dark:text-slate-600 text-xs mt-1">horas de foco</p>
      </div>
      <div class="border border-slate-200 dark:border-slate-800 rounded-lg px-4 py-4 bg-white/50 dark:bg-slate-900/20">
        <p class="text-slate-400 dark:text-slate-600 text-xs mb-2">Deep Work · 30 días</p>
        <p class="text-2xl font-bold text-slate-900 dark:text-white" id="stat-month">—</p>
        <p class="text-slate-400 dark:text-slate-600 text-xs mt-1">horas de foco</p>
      </div>
      <div class="border border-slate-200 dark:border-slate-800 rounded-lg px-4 py-4 bg-white/50 dark:bg-slate-900/20">
        <p class="text-slate-400 dark:text-slate-600 text-xs mb-2">Commits · 30 días</p>
        <p class="text-2xl font-bold text-slate-900 dark:text-white" id="stat-commits">—</p>
        <p class="text-slate-400 dark:text-slate-600 text-xs mt-1">contribuciones</p>
      </div>
      <div class="border border-slate-200 dark:border-slate-800 rounded-lg px-4 py-4 bg-white/50 dark:bg-slate-900/20">
        <p class="text-slate-400 dark:text-slate-600 text-xs mb-2">Racha activa</p>
        <p class="text-2xl font-bold text-slate-900 dark:text-white" id="stat-streak">—</p>
        <p class="text-slate-400 dark:text-slate-600 text-xs mt-1">días consecutivos</p>
      </div>
    </div>

    <div class="mb-2 flex justify-between text-xs text-slate-400 dark:text-slate-700" id="sparkline-labels"></div>
    <div class="flex items-end gap-1 h-12 mb-10" id="sparkline" aria-hidden="true"></div>

    <div id="log-feed" class="flex flex-col">
      {Array.from({ length: 8 }).map(() => (
        <div class="py-3 flex gap-3 border-b border-slate-100 dark:border-slate-800/50 animate-pulse">
          <div class="w-20 h-3 bg-slate-200 dark:bg-slate-800 rounded mt-1 shrink-0"></div>
          <div class="flex-1 h-3 bg-slate-100 dark:bg-slate-800/60 rounded"></div>
          <div class="w-12 h-3 bg-slate-200 dark:bg-slate-800 rounded mt-1 shrink-0"></div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  type FeedItem = {
    repo: string
    repoFull: string
    message: string
    sha: string
    timestamp: string
    type: 'commit' | 'pr_merged'
  }

  type ActivityData = {
    feed: FeedItem[]
    deepWork: { weekHours: number; monthHours: number; sessions: number }
    streak: number
    totalCommits: number
    sparkline: number[]
  }

  function relativeTime(iso: string): string {
    const diff = (Date.now() - new Date(iso).getTime()) / 1000
    if (diff < 3600) return `hace ${Math.floor(diff / 60)}m`
    if (diff < 86400) return `hace ${Math.floor(diff / 3600)}h`
    if (diff < 86400 * 7) return `hace ${Math.floor(diff / 86400)}d`
    return new Date(iso).toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  }

  function renderSparkline(data: number[]) {
    const bar = document.getElementById('sparkline')!
    const labels = document.getElementById('sparkline-labels')!
    const max = Math.max(...data, 1)
    const isDark = document.documentElement.classList.contains('dark')

    bar.innerHTML = data
      .map((v) => {
        const pct = Math.round((v / max) * 100)
        const color = v > 0
          ? (isDark ? 'bg-slate-400' : 'bg-slate-500')
          : (isDark ? 'bg-slate-800' : 'bg-slate-200')
        return `<div class="flex-1 ${color} rounded-sm" style="height:${Math.max(pct, 3)}%" title="${v} commits"></div>`
      })
      .join('')

    const today = new Date()
    const start = new Date(today)
    start.setDate(start.getDate() - 13)
    labels.innerHTML = `
      <span>${start.toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })}</span>
      <span>Hoy</span>`
  }

  function renderFeed(items: FeedItem[]) {
    const el = document.getElementById('log-feed')!

    if (!items.length) {
      el.innerHTML = '<p class="text-slate-400 dark:text-slate-600 text-sm py-6">Sin actividad reciente.</p>'
      return
    }

    const groups: Record<string, FeedItem[]> = {}
    for (const item of items) {
      const day = new Date(item.timestamp).toLocaleDateString('es-CO', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
      })
      if (!groups[day]) groups[day] = []
      groups[day].push(item)
    }

    el.innerHTML = Object.entries(groups)
      .map(([day, commits]) => {
        const rows = commits
          .map((c) => {
            const leftBadge = c.type === 'pr_merged'
              ? `<span class="text-purple-500 dark:text-purple-400 text-xs font-medium shrink-0 w-16 text-right">PR</span>`
              : `<span class="font-mono text-slate-400 dark:text-slate-600 text-xs shrink-0 w-16 text-right">${c.sha}</span>`

            return `
              <div class="py-2.5 flex items-baseline gap-4">
                ${leftBadge}
                <span class="text-slate-700 dark:text-slate-200 text-sm leading-snug flex-1">${escapeHtml(c.message)}</span>
                <span class="text-slate-400 dark:text-slate-500 text-xs shrink-0 hidden sm:inline">${c.repo}</span>
                <span class="text-slate-400 dark:text-slate-600 text-xs shrink-0">${relativeTime(c.timestamp)}</span>
              </div>`
          })
          .join('')

        return `
          <div class="mb-6">
            <p class="text-xs font-semibold text-slate-400 dark:text-slate-600 uppercase tracking-widest mb-3 capitalize border-b border-slate-100 dark:border-slate-800/60 pb-2">${day}</p>
            ${rows}
          </div>`
      })
      .join('')
  }

  async function load() {
    try {
      const res = await fetch('/api/github/activity')
      if (!res.ok) throw new Error()
      const data: ActivityData = await res.json()

      document.getElementById('stat-week')!.textContent = `${data.deepWork.weekHours}h`
      document.getElementById('stat-month')!.textContent = `${data.deepWork.monthHours}h`
      document.getElementById('stat-commits')!.textContent = String(data.totalCommits)
      document.getElementById('stat-streak')!.textContent = `${data.streak}d`

      renderSparkline(data.sparkline)
      renderFeed(data.feed)
    } catch {
      document.getElementById('log-feed')!.innerHTML =
        '<p class="text-slate-400 dark:text-slate-700 text-sm py-6">No se pudo cargar la actividad de GitHub.</p>'
    }
  }

  load()
</script>

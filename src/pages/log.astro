---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Engineering Log — CodeByMike"
  description="Registro de actividad de desarrollo en tiempo real. Commits, decisiones y métricas de trabajo profundo."
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <header class="mb-12">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">/log</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan pulse-dot"></span>
          En tiempo real
        </span>
      </div>
      <h1 class="text-5xl md:text-6xl font-medium tracking-[-.035em] text-mask leading-[.95] mb-5">
        Engineering Log.
      </h1>
      <p class="text-[16px] text-ink-100 max-w-xl leading-relaxed">
        Actividad de desarrollo extraída en tiempo real de GitHub. Cada commit es evidencia de trabajo real en curso.
      </p>
    </header>

    <!-- Stats bento -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
      {[
        { label: 'Deep Work · 7 días', id: 'stat-week', unit: 'horas de foco' },
        { label: 'Deep Work · 30 días', id: 'stat-month', unit: 'horas de foco' },
        { label: 'Commits · 30 días', id: 'stat-commits', unit: 'contribuciones' },
        { label: 'Racha activa', id: 'stat-streak', unit: 'días consecutivos' },
      ].map((s) => (
        <div class="rounded-2xl glass p-5">
          <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200 mb-3">{s.label}</div>
          <div class="text-3xl font-medium text-ink-50 tracking-tight" id={s.id}>—</div>
          <div class="text-[10px] font-mono text-ink-300 mt-1">{s.unit}</div>
        </div>
      ))}
    </div>

    <!-- Sparkline -->
    <div class="rounded-2xl glass p-5 mb-10 relative">
      <div class="flex justify-between text-[10px] font-mono text-ink-300 mb-3" id="sparkline-labels"></div>
      <div class="flex items-end gap-1 h-12" id="sparkline"></div>
      <div
        id="sparkline-tip"
        class="pointer-events-none absolute z-20 hidden -translate-x-1/2 -translate-y-full rounded-lg border border-white/10 bg-black/90 px-2.5 py-1.5 text-center shadow-lg backdrop-blur"
      >
        <div class="text-[13px] font-medium text-ink-50 leading-none" id="sparkline-tip-count"></div>
        <div class="text-[9px] font-mono uppercase tracking-[.15em] text-ink-300 mt-1" id="sparkline-tip-date"></div>
      </div>
    </div>

    <!-- Activity feed -->
    <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
      <span class="text-cyan">/feed</span>
      <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
      <span>Actividad reciente</span>
    </div>

    <div id="feed-wrap" class="relative">
      <div id="log-feed" class="rounded-2xl glass overflow-hidden">
        {Array.from({ length: 6 }).map(() => (
          <div class="px-5 py-3.5 border-b border-white/[.03] flex gap-4 animate-pulse">
            <div class="w-16 h-3 bg-white/5 rounded mt-1 shrink-0"></div>
            <div class="flex-1 h-3 bg-white/5 rounded"></div>
            <div class="w-12 h-3 bg-white/5 rounded mt-1 shrink-0"></div>
          </div>
        ))}
      </div>

      <!-- Bottom fade: dissolves the last rows into the page background while
           there are still older commits left to load. -->
      <div
        id="feed-fade"
        class="pointer-events-none absolute inset-x-0 bottom-0 h-28 rounded-b-2xl opacity-0 transition-opacity duration-300"
        style="background:linear-gradient(to bottom, rgba(7,7,10,0) 0%, rgba(7,7,10,.55) 52%, #07070a 100%)"
      ></div>

      <!-- Loader: small dots pinned to the bottom-center, shown only while an
           older batch is being fetched into view. -->
      <div
        id="feed-loader"
        class="pointer-events-none absolute inset-x-0 bottom-4 flex justify-center opacity-0 transition-opacity duration-300"
      >
        <span class="feed-loader-pill">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
        </span>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .feed-loader-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 7px 13px;
    border-radius: 9999px;
    background: rgba(8, 8, 12, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .feed-loader-pill .dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--color-cyan, #00f2ff);
    animation: feed-bounce 1s ease-in-out infinite;
  }
  .feed-loader-pill .dot:nth-child(2) {
    animation-delay: 0.15s;
  }
  .feed-loader-pill .dot:nth-child(3) {
    animation-delay: 0.3s;
  }
  @keyframes feed-bounce {
    0%, 80%, 100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    40% {
      transform: translateY(-5px);
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .feed-loader-pill .dot {
      animation: none;
      opacity: 0.7;
    }
  }
</style>

<script>
  type FeedItem = {
    repo: string
    repoFull: string
    message: string
    sha: string
    timestamp: string
    type: 'commit' | 'pr_merged'
  }

  type ActivityData = {
    feed: FeedItem[]
    deepWork: { weekHours: number; monthHours: number; sessions: number }
    streak: number
    totalCommits: number
    sparkline: number[]
  }

  function relativeTime(iso: string): string {
    const diff = (Date.now() - new Date(iso).getTime()) / 1000
    if (diff < 3600) return `hace ${Math.floor(diff / 60)}m`
    if (diff < 86400) return `hace ${Math.floor(diff / 3600)}h`
    if (diff < 86400 * 7) return `hace ${Math.floor(diff / 86400)}d`
    return new Date(iso).toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  }

  function renderSparkline(data: number[]) {
    const bar = document.getElementById('sparkline')!
    const labels = document.getElementById('sparkline-labels')!
    const max = Math.max(...data, 1)
    const n = data.length

    bar.innerHTML = data
      .map((v, i) => {
        const pct = Math.round((v / max) * 100)
        const color = v > 0 ? 'bg-cyan/60' : 'bg-white/5'
        const d = new Date()
        d.setDate(d.getDate() - (n - 1 - i))
        const label = d.toLocaleDateString('es-CO', { weekday: 'short', day: 'numeric', month: 'short' })
        return `<div class="flex-1 ${color} rounded-sm transition-all hover:bg-cyan cursor-default" style="height:${Math.max(pct, 3)}%" data-count="${v}" data-date="${label}"></div>`
      })
      .join('')

    const tip = document.getElementById('sparkline-tip')!
    const tipCount = document.getElementById('sparkline-tip-count')!
    const tipDate = document.getElementById('sparkline-tip-date')!
    const container = bar.parentElement!

    bar.addEventListener('pointermove', (e) => {
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-count]')
      if (!target) {
        tip.classList.add('hidden')
        return
      }
      const count = Number(target.dataset.count)
      tipCount.textContent = count === 1 ? '1 commit' : `${count} commits`
      tipDate.textContent = target.dataset.date ?? ''
      const cRect = container.getBoundingClientRect()
      const bRect = target.getBoundingClientRect()
      tip.style.left = `${bRect.left - cRect.left + bRect.width / 2}px`
      tip.style.top = `${bRect.top - cRect.top - 8}px`
      tip.classList.remove('hidden')
    })
    bar.addEventListener('pointerleave', () => tip.classList.add('hidden'))

    const today = new Date()
    const start = new Date(today)
    start.setDate(start.getDate() - 13)
    labels.innerHTML = `
      <span>${start.toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })}</span>
      <span>Hoy</span>`
  }

  function dayLabel(iso: string): string {
    return new Date(iso).toLocaleDateString('es-CO', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
    })
  }

  function rowHtml(c: FeedItem): string {
    const leftBadge = c.type === 'pr_merged'
      ? `<span class="text-violet text-[10px] font-mono shrink-0 w-14 text-right">PR</span>`
      : `<span class="font-mono text-ink-300 text-[10.5px] shrink-0 w-14 text-right">${c.sha}</span>`

    return `
      <div class="flex items-baseline gap-4 px-5 py-3 border-b border-white/[.03] hover:bg-white/[.02]">
        ${leftBadge}
        <span class="text-ink-50 text-[13px] leading-snug flex-1">${escapeHtml(c.message)}</span>
        <span class="text-ink-300 text-[10.5px] font-mono shrink-0 hidden sm:inline">${c.repo}</span>
        <span class="text-ink-300 text-[10.5px] font-mono shrink-0">${relativeTime(c.timestamp)}</span>
      </div>`
  }

  function dayHeaderHtml(day: string): string {
    return `
      <div class="px-5 py-2.5 border-b border-white/[.03] bg-white/[.01]">
        <span class="text-[10px] font-mono uppercase tracking-[.18em] text-ink-300 capitalize">${day}</span>
      </div>`
  }

  const BATCH_SIZE = 60
  const LOAD_DELAY_MS = 450
  let allItems: FeedItem[] = []
  let cursor = 0
  let lastDay = ''
  let loading = false
  let feedObserver: IntersectionObserver | null = null

  function hasMore() {
    return cursor < allItems.length
  }

  // Show the bottom fade only while older commits remain; hide the loader once
  // everything is mounted so the final rows stay fully readable.
  function updateBottomUi() {
    document.getElementById('feed-fade')?.classList.toggle('opacity-0', !hasMore())
    if (!hasMore()) document.getElementById('feed-loader')?.classList.add('opacity-0')
  }

  function renderNextBatch() {
    const el = document.getElementById('log-feed')!
    const end = Math.min(cursor + BATCH_SIZE, allItems.length)
    let html = ''
    for (let i = cursor; i < end; i++) {
      const c = allItems[i]
      const day = dayLabel(c.timestamp)
      if (day !== lastDay) {
        html += dayHeaderHtml(day)
        lastDay = day
      }
      html += rowHtml(c)
    }
    el.insertAdjacentHTML('beforeend', html)
    cursor = end

    if (!hasMore()) {
      feedObserver?.disconnect()
      feedObserver = null
      document.getElementById('feed-sentinel')?.remove()
    }
  }

  // Reveal the loader, wait a beat so the "loading older data" animation is
  // actually perceptible, then mount the next batch.
  function loadMore() {
    if (loading || !hasMore()) return
    loading = true
    document.getElementById('feed-loader')?.classList.remove('opacity-0')
    setTimeout(() => {
      renderNextBatch()
      loading = false
      updateBottomUi()
    }, LOAD_DELAY_MS)
  }

  function renderFeed(items: FeedItem[]) {
    const el = document.getElementById('log-feed')!
    allItems = items
    cursor = 0
    lastDay = ''
    loading = false
    feedObserver?.disconnect()
    feedObserver = null

    if (!items.length) {
      el.innerHTML = '<p class="px-5 py-10 text-center text-[12px] font-mono text-ink-300">Sin actividad reciente.</p>'
      updateBottomUi()
      return
    }

    el.innerHTML = ''
    renderNextBatch()
    updateBottomUi()

    // Infinite scroll: a sentinel just below the feed triggers the next batch
    // whenever it scrolls into view, so thousands of commits never all mount at
    // once.
    if (hasMore()) {
      const sentinel = document.createElement('div')
      sentinel.id = 'feed-sentinel'
      sentinel.className = 'h-2'
      el.after(sentinel)
      feedObserver = new IntersectionObserver(
        (entries) => {
          if (entries.some((e) => e.isIntersecting)) loadMore()
        },
        { rootMargin: '600px 0px' }
      )
      feedObserver.observe(sentinel)
    }
  }

  async function load() {
    try {
      const res = await fetch('/api/github/activity')
      if (!res.ok) throw new Error()
      const data: ActivityData = await res.json()

      document.getElementById('stat-week')!.textContent = `${data.deepWork.weekHours}h`
      document.getElementById('stat-month')!.textContent = `${data.deepWork.monthHours}h`
      document.getElementById('stat-commits')!.textContent = String(data.totalCommits)
      document.getElementById('stat-streak')!.textContent = `${data.streak}d`

      renderSparkline(data.sparkline)
      renderFeed(data.feed)
    } catch {
      document.getElementById('log-feed')!.innerHTML =
        '<p class="px-5 py-10 text-center text-[12px] font-mono text-ink-300">No se pudo cargar la actividad de GitHub.</p>'
    }
  }

  load()
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Engineering Log — CodeByMike"
  description="Registro de actividad de desarrollo en tiempo real. Commits, decisiones y métricas de trabajo profundo."
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <header class="mb-12">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">/log</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan pulse-dot"></span>
          En tiempo real
        </span>
      </div>
      <h1 class="text-5xl md:text-6xl font-medium tracking-[-.035em] text-mask leading-[.95] mb-5">
        Engineering Log.
      </h1>
      <p class="text-[16px] text-ink-100 max-w-xl leading-relaxed">
        Actividad de desarrollo extraída en tiempo real de GitHub. Cada commit es evidencia de trabajo real en curso.
      </p>
    </header>

    <!-- Stats bento -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
      {[
        { label: 'Deep Work · 7 días', id: 'stat-week', unit: 'horas de foco' },
        { label: 'Deep Work · 30 días', id: 'stat-month', unit: 'horas de foco' },
        { label: 'Commits · 30 días', id: 'stat-commits', unit: 'contribuciones' },
        { label: 'Racha activa', id: 'stat-streak', unit: 'días consecutivos' },
      ].map((s) => (
        <div class="rounded-2xl glass p-5">
          <div class="text-[10px] font-mono uppercase tracking-[.22em] text-ink-200 mb-3">{s.label}</div>
          <div class="text-3xl font-medium text-ink-50 tracking-tight" id={s.id}>—</div>
          <div class="text-[10px] font-mono text-ink-300 mt-1">{s.unit}</div>
        </div>
      ))}
    </div>

    <!-- Sparkline -->
    <div class="rounded-2xl glass p-5 mb-10 relative">
      <div class="flex justify-between text-[10px] font-mono text-ink-300 mb-3" id="sparkline-labels"></div>
      <div class="flex items-end gap-1 h-12" id="sparkline"></div>
      <div
        id="sparkline-tip"
        class="pointer-events-none absolute z-20 hidden -translate-x-1/2 -translate-y-full rounded-lg border border-white/10 bg-black/90 px-2.5 py-1.5 text-center shadow-lg backdrop-blur"
      >
        <div class="text-[13px] font-medium text-ink-50 leading-none" id="sparkline-tip-count"></div>
        <div class="text-[9px] font-mono uppercase tracking-[.15em] text-ink-300 mt-1" id="sparkline-tip-date"></div>
      </div>
    </div>

    <!-- Activity feed -->
    <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
      <span class="text-cyan">/feed</span>
      <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
      <span>Actividad reciente</span>
    </div>

    <div id="log-feed" class="rounded-2xl glass overflow-hidden">
      {Array.from({ length: 6 }).map(() => (
        <div class="px-5 py-3.5 border-b border-white/[.03] flex gap-4 animate-pulse">
          <div class="w-16 h-3 bg-white/5 rounded mt-1 shrink-0"></div>
          <div class="flex-1 h-3 bg-white/5 rounded"></div>
          <div class="w-12 h-3 bg-white/5 rounded mt-1 shrink-0"></div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  type FeedItem = {
    repo: string
    repoFull: string
    message: string
    sha: string
    timestamp: string
    type: 'commit' | 'pr_merged'
  }

  type ActivityData = {
    feed: FeedItem[]
    deepWork: { weekHours: number; monthHours: number; sessions: number }
    streak: number
    totalCommits: number
    sparkline: number[]
  }

  function relativeTime(iso: string): string {
    const diff = (Date.now() - new Date(iso).getTime()) / 1000
    if (diff < 3600) return `hace ${Math.floor(diff / 60)}m`
    if (diff < 86400) return `hace ${Math.floor(diff / 3600)}h`
    if (diff < 86400 * 7) return `hace ${Math.floor(diff / 86400)}d`
    return new Date(iso).toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
  }

  function renderSparkline(data: number[]) {
    const bar = document.getElementById('sparkline')!
    const labels = document.getElementById('sparkline-labels')!
    const max = Math.max(...data, 1)

    bar.innerHTML = data
      .map((v) => {
        const pct = Math.round((v / max) * 100)
        const color = v > 0 ? 'bg-cyan/60' : 'bg-white/5'
        return `<div class="flex-1 ${color} rounded-sm transition-all" style="height:${Math.max(pct, 3)}%" title="${v} commits"></div>`
      })
      .join('')

    const today = new Date()
    const start = new Date(today)
    start.setDate(start.getDate() - 13)
    labels.innerHTML = `
      <span>${start.toLocaleDateString('es-CO', { day: 'numeric', month: 'short' })}</span>
      <span>Hoy</span>`
  }

  function renderFeed(items: FeedItem[]) {
    const el = document.getElementById('log-feed')!

    if (!items.length) {
      el.innerHTML = '<p class="px-5 py-10 text-center text-[12px] font-mono text-ink-300">Sin actividad reciente.</p>'
      return
    }

    const groups: Record<string, FeedItem[]> = {}
    for (const item of items) {
      const day = new Date(item.timestamp).toLocaleDateString('es-CO', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
      })
      if (!groups[day]) groups[day] = []
      groups[day].push(item)
    }

    el.innerHTML = Object.entries(groups)
      .map(([day, commits]) => {
        const rows = commits
          .map((c) => {
            const leftBadge = c.type === 'pr_merged'
              ? `<span class="text-violet text-[10px] font-mono shrink-0 w-14 text-right">PR</span>`
              : `<span class="font-mono text-ink-300 text-[10.5px] shrink-0 w-14 text-right">${c.sha}</span>`

            return `
              <div class="flex items-baseline gap-4 px-5 py-3 border-b border-white/[.03] hover:bg-white/[.02]">
                ${leftBadge}
                <span class="text-ink-50 text-[13px] leading-snug flex-1">${escapeHtml(c.message)}</span>
                <span class="text-ink-300 text-[10.5px] font-mono shrink-0 hidden sm:inline">${c.repo}</span>
                <span class="text-ink-300 text-[10.5px] font-mono shrink-0">${relativeTime(c.timestamp)}</span>
              </div>`
          })
          .join('')

        return `
          <div>
            <div class="px-5 py-2.5 border-b border-white/[.03] bg-white/[.01]">
              <span class="text-[10px] font-mono uppercase tracking-[.18em] text-ink-300 capitalize">${day}</span>
            </div>
            ${rows}
          </div>`
      })
      .join('')
  }

  async function load() {
    try {
      const res = await fetch('/api/github/activity')
      if (!res.ok) throw new Error()
      const data: ActivityData = await res.json()

      document.getElementById('stat-week')!.textContent = `${data.deepWork.weekHours}h`
      document.getElementById('stat-month')!.textContent = `${data.deepWork.monthHours}h`
      document.getElementById('stat-commits')!.textContent = String(data.totalCommits)
      document.getElementById('stat-streak')!.textContent = `${data.streak}d`

      renderSparkline(data.sparkline)
      renderFeed(data.feed)
    } catch {
      document.getElementById('log-feed')!.innerHTML =
        '<p class="px-5 py-10 text-center text-[12px] font-mono text-ink-300">No se pudo cargar la actividad de GitHub.</p>'
    }
  }

  load()
</script>

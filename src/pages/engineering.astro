---
import BaseLayout from '../layouts/BaseLayout.astro'
import { db } from '../db'
import { webVitals, ciRuns, monitorChecks, monitors } from '../db/schema'
import { and, desc, eq, gte, sql } from 'drizzle-orm'
import {
  p75,
  rateVital,
  formatVital,
  VITAL_META,
  type VitalMetric,
  type VitalRating,
} from '../lib/vitals'

export const prerender = false

// Panel público de ingeniería. Reúne señales VERIFICABLES y en vivo:
// - Core Web Vitals p75 de usuarios reales (RUM, tabla web_vitals).
// - Resultado del pipeline CI real (tabla ci_runs): tests, cobertura, duración.
// - Disponibilidad agregada de la infraestructura de monitoreo.
// Nada de badges decorativos: cada número sale de datos de producción.

const DAY_MS = 86_400_000
const now = Date.now()
const VITALS_DAYS = 30
const vitalsSince = new Date(now - VITALS_DAYS * DAY_MS)

// ── Core Web Vitals (RUM) ────────────────────────────────────────────────
const METRIC_ORDER: VitalMetric[] = ['LCP', 'INP', 'CLS', 'FCP', 'TTFB']
const vitalRows = await db
  .select({ metric: webVitals.metric, value: webVitals.value })
  .from(webVitals)
  .where(gte(webVitals.createdAt, vitalsSince))
  .limit(20000)

const byMetric = new Map<VitalMetric, number[]>()
for (const r of vitalRows) {
  const arr = byMetric.get(r.metric) ?? []
  arr.push(r.value)
  byMetric.set(r.metric, arr)
}
const vitals = METRIC_ORDER.map((m) => {
  const values = byMetric.get(m) ?? []
  const v = p75(values)
  return {
    metric: m,
    label: VITAL_META[m].label,
    p75: v,
    display: v === null ? '—' : formatVital(m, v),
    rating: (v === null ? null : rateVital(m, v)) as VitalRating | null,
    samples: values.length,
  }
})
const totalSamples = vitalRows.length

// ── Pipeline CI (datos reales de GitHub Actions) ─────────────────────────
const recentRuns = await db.select().from(ciRuns).orderBy(desc(ciRuns.createdAt)).limit(20)
const lastSuccess = recentRuns.find((r) => r.conclusion === 'success') ?? null
const greenStreak = (() => {
  let n = 0
  for (const r of recentRuns) {
    if (r.conclusion === 'failure') break
    if (r.conclusion === 'success') n++
  }
  return n
})()

// ── Disponibilidad agregada (90 días) ────────────────────────────────────
const uptimeSince = new Date(now - 90 * DAY_MS)
const [uptimeAgg] = await db
  .select({
    total: sql<number>`count(*)`,
    ok: sql<number>`coalesce(sum(${monitorChecks.ok}), 0)`,
  })
  .from(monitorChecks)
  .where(gte(monitorChecks.at, uptimeSince))
const [monCount] = await db
  .select({ n: sql<number>`count(*)` })
  .from(monitors)
  .where(and(eq(monitors.active, true), eq(monitors.paused, false)))
const uptime90 =
  uptimeAgg && uptimeAgg.total > 0 ? Math.round((uptimeAgg.ok / uptimeAgg.total) * 10000) / 100 : null

const fmtDuration = (ms: number | null) => {
  if (ms == null) return '—'
  if (ms < 1000) return `${ms} ms`
  const s = ms / 1000
  return s < 60 ? `${s.toFixed(1)} s` : `${Math.floor(s / 60)}m ${Math.round(s % 60)}s`
}
const fmtDate = new Intl.DateTimeFormat('es-CO', {
  day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit', timeZone: 'America/Bogota',
})

const ratingCls: Record<VitalRating, string> = {
  good: 'text-lime border-lime/30 bg-lime/10',
  'needs-improvement': 'text-ember border-ember/30 bg-ember/10',
  poor: 'text-ember border-ember/40 bg-ember/15',
}
const ratingLabel: Record<VitalRating, string> = {
  good: 'Bueno',
  'needs-improvement': 'Mejorable',
  poor: 'Pobre',
}
---

<BaseLayout
  title="Ingeniería — CodeByMike"
  description="Métricas de ingeniería medidas en producción: Core Web Vitals de usuarios reales, resultado del pipeline CI y disponibilidad. Datos vivos y verificables, no afirmaciones."
  image="/og-default.png"
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <header class="mb-12">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">/engineering</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
        <span>Excelencia medida, no afirmada</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-medium tracking-[-.035em] text-mask leading-[.95] mb-5">
        La calidad,<br/>en números.
      </h1>
      <p class="text-[16px] text-ink-100 max-w-2xl leading-relaxed">
        Cualquiera puede decir que su código es rápido, probado y confiable. Esta página lo
        <em>mide</em>: Web Vitals de visitantes reales, el resultado de mi pipeline de CI y la
        disponibilidad de mis servicios. Todo sale de datos de producción, en vivo.
      </p>
    </header>

    <!-- ── Core Web Vitals (RUM) ── -->
    <section class="mb-14">
      <div class="flex items-baseline justify-between mb-5">
        <h2 class="text-[13px] font-mono uppercase tracking-[.2em] text-ink-200">Core Web Vitals · usuarios reales</h2>
        <span class="text-[11px] font-mono text-ink-400">
          p75 · {VITALS_DAYS}d · {totalSamples.toLocaleString('es-CO')} muestras
        </span>
      </div>

      {totalSamples === 0 ? (
        <div class="rounded-2xl glass p-8 text-center">
          <p class="text-[13px] text-ink-300">Aún recolectando telemetría de visitantes reales. Vuelve pronto.</p>
        </div>
      ) : (
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
          {vitals.map((v) => (
            <div class="rounded-2xl glass p-4">
              <div class="flex items-center justify-between mb-3">
                <span class="text-[12px] font-mono font-semibold text-ink-50">{v.metric}</span>
                {v.rating && (
                  <span class={`px-1.5 py-0.5 rounded-full text-[9px] font-mono uppercase tracking-wider border ${ratingCls[v.rating]}`}>
                    {ratingLabel[v.rating]}
                  </span>
                )}
              </div>
              <div class="text-2xl font-medium tracking-tight text-ink-50 tabular-nums">{v.display}</div>
              <div class="text-[10px] text-ink-400 mt-1 leading-tight">{v.label}</div>
            </div>
          ))}
        </div>
      )}
    </section>

    <!-- ── Pipeline CI + disponibilidad ── -->
    <section class="mb-14 grid md:grid-cols-2 gap-3">
      <div class="rounded-2xl glass p-6">
        <h2 class="text-[13px] font-mono uppercase tracking-[.2em] text-ink-200 mb-5">Último pipeline verde</h2>
        {lastSuccess ? (
          <div class="grid grid-cols-3 gap-4">
            <div>
              <div class="text-3xl font-medium text-lime tabular-nums">{lastSuccess.testsPassed ?? '—'}</div>
              <div class="text-[10px] font-mono uppercase tracking-wider text-ink-400 mt-1">tests ✓</div>
            </div>
            <div>
              <div class="text-3xl font-medium text-ink-50 tabular-nums">{lastSuccess.coveragePct != null ? `${Math.round(lastSuccess.coveragePct)}%` : '—'}</div>
              <div class="text-[10px] font-mono uppercase tracking-wider text-ink-400 mt-1">cobertura</div>
            </div>
            <div>
              <div class="text-3xl font-medium text-ink-50 tabular-nums">{fmtDuration(lastSuccess.durationMs)}</div>
              <div class="text-[10px] font-mono uppercase tracking-wider text-ink-400 mt-1">duración</div>
            </div>
            <div class="col-span-3 pt-3 mt-1 border-t border-white/5 flex items-center justify-between text-[11px] font-mono text-ink-400">
              <span>{greenStreak > 1 ? `${greenStreak} runs verdes seguidos` : 'último run'}</span>
              <span>{lastSuccess.createdAt ? fmtDate.format(lastSuccess.createdAt) : ''}</span>
            </div>
          </div>
        ) : (
          <p class="text-[13px] text-ink-300 py-4">El pipeline aún no ha reportado ejecuciones. Se poblará con el próximo deploy.</p>
        )}
      </div>

      <div class="rounded-2xl glass p-6 flex flex-col">
        <h2 class="text-[13px] font-mono uppercase tracking-[.2em] text-ink-200 mb-5">Disponibilidad · 90 días</h2>
        <div class="flex-1 flex items-center">
          <div>
            <div class="text-4xl font-medium tabular-nums text-lime">{uptime90 != null ? `${uptime90}%` : '—'}</div>
            <div class="text-[11px] font-mono text-ink-400 mt-2">
              {monCount?.n ?? 0} servicios monitoreados · {(uptimeAgg?.total ?? 0).toLocaleString('es-CO')} sondeos
            </div>
          </div>
        </div>
        <a href="/status" class="text-[11px] font-mono text-cyan hover:underline mt-3">Ver status en vivo →</a>
      </div>
    </section>

    <!-- ── Verificable ── -->
    <section>
      <h2 class="text-[13px] font-mono uppercase tracking-[.2em] text-ink-200 mb-5">Compruébalo tú mismo</h2>
      <div class="grid sm:grid-cols-3 gap-3">
        <a href="/security" class="rounded-2xl glass p-5 hover:border-cyan/30 transition-colors group">
          <div class="text-[13px] text-ink-50 mb-1 group-hover:text-cyan transition-colors">Auditoría de seguridad</div>
          <div class="text-[11px] text-ink-400 leading-relaxed">Hallazgos OWASP reales, cada uno mapeado al commit que lo corrigió.</div>
        </a>
        <a href="/status" class="rounded-2xl glass p-5 hover:border-cyan/30 transition-colors group">
          <div class="text-[13px] text-ink-50 mb-1 group-hover:text-cyan transition-colors">Status operacional</div>
          <div class="text-[11px] text-ink-400 leading-relaxed">Uptime, latencia y presupuesto de error de mi propia infraestructura.</div>
        </a>
        <a href="/tools" class="rounded-2xl glass p-5 hover:border-cyan/30 transition-colors group">
          <div class="text-[13px] text-ink-50 mb-1 group-hover:text-cyan transition-colors">Herramientas internas</div>
          <div class="text-[11px] text-ink-400 leading-relaxed">Casos de estudio de lo que construí sobre este mismo sitio.</div>
        </a>
      </div>
      <p class="text-[11px] text-ink-500 mt-6 leading-relaxed max-w-2xl">
        Web Vitals recolectados con la librería oficial <span class="font-mono">web-vitals</span> en el navegador
        de cada visitante, agregados al percentil 75 (el que Google usa para clasificar). Sin cookies ni datos personales.
      </p>
    </section>
  </div>
</BaseLayout>

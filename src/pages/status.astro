---
import BaseLayout from '../layouts/BaseLayout.astro'
import { db } from '../db'
import { monitors, monitorChecks, monitorIncidents } from '../db/schema'
import { and, desc, eq, gte, isNotNull, sql } from 'drizzle-orm'
import { computeSloFromCounts, formatMinutes, budgetHealth } from '../lib/slo'

// Página de status pública. Expone SOLO datos operativos agregados de los
// monitores activos (nombre, uptime, latencia); nunca URLs internas, errores
// crudos ni configuración. El filtrado ocurre aquí, en el servidor.

const OBJECTIVE = 99.5
const WINDOW_DAYS = 90
const SLO_DAYS = 30
const DAY_MS = 86_400_000

const now = Date.now()
const since = new Date(now - WINDOW_DAYS * DAY_MS)

const mons = await db
  .select({
    id: monitors.id,
    name: monitors.name,
    lastStatus: monitors.lastStatus,
    lastCheckedAt: monitors.lastCheckedAt,
    lastResponseMs: monitors.lastResponseMs,
  })
  .from(monitors)
  .where(and(eq(monitors.active, true), eq(monitors.paused, false)))
  .orderBy(monitors.name)

// Agregado diario por SQL: monitores × días en vez de un row por check.
const dayExpr = sql<string>`date(${monitorChecks.at}, 'unixepoch')`
const daily = await db
  .select({
    monitorId: monitorChecks.monitorId,
    day: dayExpr,
    total: sql<number>`count(*)`,
    ok: sql<number>`coalesce(sum(${monitorChecks.ok}), 0)`,
    sumMs: sql<number>`coalesce(sum(${monitorChecks.responseMs}), 0)`,
  })
  .from(monitorChecks)
  .where(gte(monitorChecks.at, since))
  .groupBy(monitorChecks.monitorId, dayExpr)

type Bucket = { day: string; total: number; ok: number; sumMs: number }
const byMonitor = new Map<number, Map<string, Bucket>>()
for (const row of daily) {
  const map = byMonitor.get(row.monitorId) ?? new Map<string, Bucket>()
  map.set(row.day, row)
  byMonitor.set(row.monitorId, map)
}

// Últimos 90 días como claves ISO (UTC), del más antiguo al más reciente.
const days: string[] = []
for (let i = WINDOW_DAYS - 1; i >= 0; i--) {
  days.push(new Date(now - i * DAY_MS).toISOString().slice(0, 10))
}
const sloCutoff = new Date(now - SLO_DAYS * DAY_MS).toISOString().slice(0, 10)

const cards = mons.map((m) => {
  const buckets = byMonitor.get(m.id) ?? new Map<string, Bucket>()

  const bars = days.map((day) => {
    const b = buckets.get(day)
    if (!b || b.total === 0) return { day, pct: null as number | null }
    return { day, pct: Math.round((b.ok / b.total) * 1000) / 10 }
  })

  let ok30 = 0, total30 = 0, sumMs30 = 0
  let ok90 = 0, total90 = 0
  for (const [day, b] of buckets) {
    ok90 += b.ok
    total90 += b.total
    if (day >= sloCutoff) {
      ok30 += b.ok
      total30 += b.total
      sumMs30 += b.sumMs
    }
  }

  const slo = computeSloFromCounts(ok30, total30, OBJECTIVE, SLO_DAYS)
  return {
    ...m,
    bars,
    slo,
    health: budgetHealth(slo),
    uptime90: total90 > 0 ? Math.round((ok90 / total90) * 1000) / 10 : null,
    avgMs30: total30 > 0 ? Math.round(sumMs30 / total30) : null,
  }
})

// Incidentes resueltos recientes: nombre, inicio y duración. Sin causa ni
// mensajes de error (pueden contener detalle interno).
const publicIds = new Set(mons.map((m) => m.id))
const nameById = new Map(mons.map((m) => [m.id, m.name]))
const incidents = (
  await db
    .select({
      monitorId: monitorIncidents.monitorId,
      startedAt: monitorIncidents.startedAt,
      durationSec: monitorIncidents.durationSec,
    })
    .from(monitorIncidents)
    .where(and(isNotNull(monitorIncidents.resolvedAt), gte(monitorIncidents.startedAt, since)))
    .orderBy(desc(monitorIncidents.startedAt))
    .limit(10)
).filter((i) => publicIds.has(i.monitorId))

const overall = cards.some((c) => c.lastStatus === 'down')
  ? 'down'
  : cards.some((c) => c.lastStatus === 'degraded')
    ? 'degraded'
    : 'up'

const overallLabel = {
  up: 'Todos los sistemas operativos',
  degraded: 'Rendimiento degradado en algún servicio',
  down: 'Incidente activo en algún servicio',
}[overall]

const fmtDate = new Intl.DateTimeFormat('es-CO', {
  day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit',
  timeZone: 'America/Bogota',
})

function ago(d: Date | null): string {
  if (!d) return '—'
  const min = Math.round((now - d.getTime()) / 60_000)
  if (min < 1) return 'hace <1 min'
  if (min < 60) return `hace ${min} min`
  const h = Math.floor(min / 60)
  return h < 24 ? `hace ${h} h` : `hace ${Math.floor(h / 24)} d`
}

function barColor(pct: number | null): string {
  if (pct === null) return 'bg-ink-600'
  if (pct >= OBJECTIVE) return 'bg-lime'
  if (pct >= 95) return 'bg-ember/70'
  return 'bg-ember'
}

const statusBadge = {
  up: { label: 'Operativo', cls: 'text-lime border-lime/30 bg-lime/10', dot: 'bg-lime' },
  degraded: { label: 'Degradado', cls: 'text-ember border-ember/30 bg-ember/10', dot: 'bg-ember' },
  down: { label: 'Caído', cls: 'text-ember border-ember/40 bg-ember/15', dot: 'bg-ember' },
  unknown: { label: 'Sin datos', cls: 'text-ink-200 border-white/10 bg-white/5', dot: 'bg-ink-400' },
} as const

const healthLabel = {
  healthy: 'saludable',
  warning: 'en alerta',
  critical: 'crítico',
  exhausted: 'agotado',
} as const
---

<BaseLayout
  title="Status — CodeByMike"
  description="Estado en tiempo real de los servicios que opero: uptime, latencia y presupuesto de error, medidos por mi propia infraestructura de monitoreo."
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <header class="mb-12">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">/status</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
        <span>Transparencia operacional</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-medium tracking-[-.035em] text-mask leading-[.95] mb-5">
        Estado de los<br/>servicios.
      </h1>
      <p class="text-[16px] text-ink-100 max-w-xl leading-relaxed">
        Uptime, latencia y presupuesto de error de los servicios que opero, medidos cada pocos
        minutos por mi propia infraestructura de monitoreo. Datos reales, sin maquillaje.
      </p>
    </header>

    <!-- Banner de estado global -->
    <div class={`rounded-2xl glass p-5 mb-12 flex items-center gap-4 ${overall === 'up' ? 'border-lime/20' : 'border-ember/30'}`}>
      <span class={`w-2.5 h-2.5 rounded-full pulse-dot ${overall === 'up' ? 'bg-lime' : 'bg-ember'}`}></span>
      <span class="text-[15px] font-medium">{overallLabel}</span>
      <span class="ml-auto text-[11px] font-mono text-ink-300 hidden sm:block">
        Objetivo SLO {OBJECTIVE}% · ventana {SLO_DAYS} días
      </span>
    </div>

    {cards.length === 0 && (
      <div class="rounded-2xl glass p-12 text-center">
        <p class="text-[13px] font-mono text-ink-300">No hay monitores públicos configurados.</p>
      </div>
    )}

    <!-- Monitores -->
    <div class="space-y-4 mb-20">
      {cards.map((c) => {
        const badge = statusBadge[c.lastStatus ?? 'unknown']
        return (
          <div class="rounded-2xl glass p-6 lift">
            <div class="flex flex-wrap items-center gap-3 mb-5">
              <span class={`w-1.5 h-1.5 rounded-full ${badge.dot} ${c.lastStatus === 'up' ? '' : 'pulse-dot'}`}></span>
              <h2 class="text-[15px] font-medium">{c.name}</h2>
              <span class={`text-[10px] font-mono uppercase tracking-[.15em] px-2.5 py-1 rounded-full border ${badge.cls}`}>
                {badge.label}
              </span>
              <span class="ml-auto text-[11px] font-mono text-ink-300">
                último check {ago(c.lastCheckedAt)}
              </span>
            </div>

            <!-- 90 días de uptime diario -->
            <div class="flex items-end gap-[2px] h-9 mb-2">
              {c.bars.map((b) => (
                <div
                  class={`flex-1 rounded-[2px] ${barColor(b.pct)} ${b.pct === null ? 'h-2 self-center' : 'h-full'} opacity-90 hover:opacity-100`}
                  title={`${b.day} · ${b.pct === null ? 'sin datos' : `${b.pct}% uptime`}`}
                ></div>
              ))}
            </div>
            <div class="flex justify-between text-[10px] font-mono text-ink-300 mb-5">
              <span>hace {WINDOW_DAYS} días</span>
              <span>hoy</span>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-[13px]">
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mb-1">Uptime {SLO_DAYS}d</div>
                <div class={`font-mono ${c.slo.meetsObjective ? 'text-lime' : 'text-ember'}`}>
                  {c.slo.sliPct === null ? '—' : `${c.slo.sliPct}%`}
                </div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mb-1">Uptime {WINDOW_DAYS}d</div>
                <div class="font-mono text-ink-50">{c.uptime90 === null ? '—' : `${c.uptime90}%`}</div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mb-1">Latencia media</div>
                <div class="font-mono text-ink-50">{c.avgMs30 === null ? '—' : `${c.avgMs30} ms`}</div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mb-1">Error budget</div>
                <div class="font-mono text-ink-50">
                  {c.slo.budgetRemainingPct === null
                    ? '—'
                    : `${c.slo.budgetRemainingPct}% (${formatMinutes(c.slo.remainingMinutes)})`}
                  <span class="text-ink-300"> · {healthLabel[c.health]}</span>
                </div>
              </div>
            </div>
          </div>
        )
      })}
    </div>

    <!-- Incidentes recientes -->
    <section class="mb-20">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-ink-400"></span>
        <span>Incidentes resueltos · últimos {WINDOW_DAYS} días</span>
      </div>
      {incidents.length === 0 ? (
        <div class="rounded-2xl glass p-8">
          <p class="text-[13px] font-mono text-ink-200">Sin incidentes registrados en la ventana. 🎉</p>
        </div>
      ) : (
        <div class="rounded-2xl glass divide-y divide-white/5">
          {incidents.map((i) => (
            <div class="p-5 flex flex-wrap items-center gap-3 text-[13px]">
              <span class="font-medium">{nameById.get(i.monitorId)}</span>
              <span class="text-ink-300 font-mono text-[11px]">{fmtDate.format(i.startedAt)}</span>
              <span class="ml-auto font-mono text-[11px] text-ember">
                {i.durationSec != null ? formatMinutes(i.durationSec / 60) : 'duración desconocida'} de caída
              </span>
            </div>
          ))}
        </div>
      )}
    </section>

    <!-- Metodología -->
    <section class="rounded-2xl glass p-8">
      <div class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-4">Cómo se mide</div>
      <div class="grid md:grid-cols-3 gap-6 text-[13px] text-ink-100 leading-relaxed">
        <p>
          Un cron externo sondea cada servicio cada pocos minutos: código HTTP esperado,
          contenido de la respuesta y latencia. Un 200 con la página equivocada también cuenta como caída.
        </p>
        <p>
          El <span class="text-ink-50">SLO</span> es {OBJECTIVE}% de disponibilidad en {SLO_DAYS} días.
          El <span class="text-ink-50">presupuesto de error</span> es el tiempo de caída que ese objetivo
          permite; aquí se muestra cuánto queda.
        </p>
        <p>
          Todo el sistema — motor de checks, incidentes, SLOs y alertas — es una herramienta
          propia construida sobre este mismo sitio. Los datos se sirven tal cual se midieron.
        </p>
      </div>
    </section>

  </div>
</BaseLayout>

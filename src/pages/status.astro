---
import BaseLayout from '../layouts/BaseLayout.astro'
import { db } from '../db'
import { monitors, monitorChecks, monitorIncidents } from '../db/schema'
import { and, desc, eq, gte, isNotNull, sql } from 'drizzle-orm'
import { computeSloFromCounts, formatMinutes, budgetHealth } from '../lib/slo'
import { recentLatency } from '../lib/latency'

// Página de status pública. Expone SOLO datos operativos agregados de los
// monitores activos (nombre, uptime, latencia); nunca URLs internas, errores
// crudos ni configuración. El filtrado ocurre aquí, en el servidor.

const OBJECTIVE = 99.5
const WINDOW_DAYS = 90
const SLO_DAYS = 30
const DAY_MS = 86_400_000

const now = Date.now()
const since = new Date(now - WINDOW_DAYS * DAY_MS)

const mons = await db
  .select({
    id: monitors.id,
    name: monitors.name,
    lastStatus: monitors.lastStatus,
    lastCheckedAt: monitors.lastCheckedAt,
    lastResponseMs: monitors.lastResponseMs,
    sslExpiresAt: monitors.sslExpiresAt,
  })
  .from(monitors)
  .where(and(eq(monitors.active, true), eq(monitors.paused, false)))
  .orderBy(monitors.name)

// Agregado diario por SQL: monitores × días en vez de un row por check.
const dayExpr = sql<string>`date(${monitorChecks.at}, 'unixepoch')`
const daily = await db
  .select({
    monitorId: monitorChecks.monitorId,
    day: dayExpr,
    total: sql<number>`count(*)`,
    ok: sql<number>`coalesce(sum(${monitorChecks.ok}), 0)`,
    sumMs: sql<number>`coalesce(sum(${monitorChecks.responseMs}), 0)`,
  })
  .from(monitorChecks)
  .where(gte(monitorChecks.at, since))
  .groupBy(monitorChecks.monitorId, dayExpr)

type Bucket = { day: string; total: number; ok: number; sumMs: number }
const byMonitor = new Map<number, Map<string, Bucket>>()
for (const row of daily) {
  const map = byMonitor.get(row.monitorId) ?? new Map<string, Bucket>()
  map.set(row.day, row)
  byMonitor.set(row.monitorId, map)
}

// Últimos 90 días como claves ISO (UTC), del más antiguo al más reciente.
const days: string[] = []
for (let i = WINDOW_DAYS - 1; i >= 0; i--) {
  days.push(new Date(now - i * DAY_MS).toISOString().slice(0, 10))
}
const sloCutoff = new Date(now - SLO_DAYS * DAY_MS).toISOString().slice(0, 10)

// Serie de latencia reciente por monitor para la mini-gráfica tipo EKG.
const latencyByMonitor = await recentLatency(mons.map((m) => m.id))

// p95 de latencia (30d) por monitor: nearest-rank vía window function.
// La media esconde la cola; el p95 es lo que de verdad sienten los usuarios lentos.
const p95Cutoff = Math.floor((now - SLO_DAYS * DAY_MS) / 1000)
const p95Rows = await db.all<{ monitor_id: number; p95: number }>(sql`
  select monitor_id, response_ms as p95 from (
    select
      monitor_id,
      response_ms,
      row_number() over (partition by monitor_id order by response_ms) as rn,
      count(*) over (partition by monitor_id) as cnt
    from monitor_checks
    where at >= ${p95Cutoff} and response_ms is not null
  )
  where rn = max(1, cast(0.95 * cnt as integer) + (0.95 * cnt > cast(0.95 * cnt as integer)))
`)
const p95ByMonitor = new Map<number, number>(p95Rows.map((r) => [r.monitor_id, r.p95]))

const cards = mons.map((m) => {
  const buckets = byMonitor.get(m.id) ?? new Map<string, Bucket>()
  const latency = (latencyByMonitor.get(m.id) ?? []).map((p) => p.ms)

  const bars = days.map((day) => {
    const b = buckets.get(day)
    if (!b || b.total === 0) return { day, pct: null as number | null }
    return { day, pct: Math.round((b.ok / b.total) * 1000) / 10 }
  })

  let ok30 = 0, total30 = 0, sumMs30 = 0
  let ok90 = 0, total90 = 0
  for (const [day, b] of buckets) {
    ok90 += b.ok
    total90 += b.total
    if (day >= sloCutoff) {
      ok30 += b.ok
      total30 += b.total
      sumMs30 += b.sumMs
    }
  }

  const slo = computeSloFromCounts(ok30, total30, OBJECTIVE, SLO_DAYS)
  return {
    ...m,
    bars,
    latency,
    slo,
    health: budgetHealth(slo),
    uptime90: total90 > 0 ? Math.round((ok90 / total90) * 1000) / 10 : null,
    avgMs30: total30 > 0 ? Math.round(sumMs30 / total30) : null,
    p95Ms30: p95ByMonitor.get(m.id) ?? null,
    ok30,
    total30,
  }
})

// Uptime agregado global (30d): un solo número ancla para el encabezado.
const globalOk30 = cards.reduce((s, c) => s + c.ok30, 0)
const globalTotal30 = cards.reduce((s, c) => s + c.total30, 0)
const globalUptime30 = globalTotal30 > 0
  ? Math.round((globalOk30 / globalTotal30) * 1000) / 10
  : null

// Incidentes resueltos recientes: nombre, inicio y duración. Sin causa ni
// mensajes de error (pueden contener detalle interno).
const publicIds = new Set(mons.map((m) => m.id))
const nameById = new Map(mons.map((m) => [m.id, m.name]))
const incidents = (
  await db
    .select({
      monitorId: monitorIncidents.monitorId,
      startedAt: monitorIncidents.startedAt,
      durationSec: monitorIncidents.durationSec,
    })
    .from(monitorIncidents)
    .where(and(isNotNull(monitorIncidents.resolvedAt), gte(monitorIncidents.startedAt, since)))
    .orderBy(desc(monitorIncidents.startedAt))
    .limit(10)
).filter((i) => publicIds.has(i.monitorId))

// Incidentes ACTIVOS (sin resolver): lo primero que busca alguien al entrar.
const activeIncidents = (
  await db
    .select({
      monitorId: monitorIncidents.monitorId,
      startedAt: monitorIncidents.startedAt,
    })
    .from(monitorIncidents)
    .where(sql`${monitorIncidents.resolvedAt} is null`)
    .orderBy(desc(monitorIncidents.startedAt))
).filter((i) => publicIds.has(i.monitorId))

const overall = cards.some((c) => c.lastStatus === 'down')
  ? 'down'
  : cards.some((c) => c.lastStatus === 'degraded')
    ? 'degraded'
    : 'up'

const overallLabel = {
  up: 'Todos los sistemas operativos',
  degraded: 'Rendimiento degradado en algún servicio',
  down: 'Incidente activo en algún servicio',
}[overall]

const fmtDate = new Intl.DateTimeFormat('es-CO', {
  day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit',
  timeZone: 'America/Bogota',
})

function ago(d: Date | null): string {
  if (!d) return '—'
  const min = Math.round((now - d.getTime()) / 60_000)
  if (min < 1) return 'hace <1 min'
  if (min < 60) return `hace ${min} min`
  const h = Math.floor(min / 60)
  return h < 24 ? `hace ${h} h` : `hace ${Math.floor(h / 24)} d`
}

function barColor(pct: number | null): string {
  if (pct === null) return 'bg-ink-600'
  if (pct >= OBJECTIVE) return 'bg-lime'
  if (pct >= 95) return 'bg-ember/70'
  return 'bg-ember'
}

// Badge de certificado TLS: días hasta la expiración, con color de alerta.
function sslInfo(d: Date | null): { label: string; cls: string } | null {
  if (!d) return null
  const days = Math.round((d.getTime() - now) / DAY_MS)
  if (days < 0) return { label: 'TLS vencido', cls: 'text-ember border-ember/40 bg-ember/15' }
  if (days <= 14) return { label: `TLS · ${days} d`, cls: 'text-ember border-ember/30 bg-ember/10' }
  if (days <= 30) return { label: `TLS · ${days} d`, cls: 'text-ember/80 border-ember/20 bg-ember/5' }
  return { label: `TLS · ${days} d`, cls: 'text-lime/80 border-lime/20 bg-lime/5' }
}

// Color del trazo EKG según el estado actual del monitor.
const ekgColor: Record<string, string> = {
  up: 'text-lime',
  degraded: 'text-ember',
  down: 'text-ember',
  unknown: 'text-ink-400',
}

const statusBadge = {
  up: { label: 'Operativo', cls: 'text-lime border-lime/30 bg-lime/10', dot: 'bg-lime' },
  degraded: { label: 'Degradado', cls: 'text-ember border-ember/30 bg-ember/10', dot: 'bg-ember' },
  down: { label: 'Caído', cls: 'text-ember border-ember/40 bg-ember/15', dot: 'bg-ember' },
  unknown: { label: 'Sin datos', cls: 'text-ink-200 border-white/10 bg-white/5', dot: 'bg-ink-400' },
} as const

const healthLabel = {
  healthy: 'saludable',
  warning: 'en alerta',
  critical: 'crítico',
  exhausted: 'agotado',
} as const
---

<BaseLayout
  title="Status — CodeByMike"
  description="Estado en tiempo real de los servicios que opero: uptime, latencia y presupuesto de error, medidos por mi propia infraestructura de monitoreo."
  image="/og-status.png"
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <header class="mb-12">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">/status</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
        <span>Transparencia operacional</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-medium tracking-[-.035em] text-mask leading-[.95] mb-5">
        Estado de los<br/>servicios.
      </h1>
      <p class="text-[16px] text-ink-100 max-w-xl leading-relaxed">
        Uptime, latencia y presupuesto de error de los servicios que opero, medidos cada pocos
        minutos por mi propia infraestructura de monitoreo. Datos reales, sin maquillaje.
      </p>
    </header>

    <!-- Banner de estado global + uptime agregado -->
    <div class={`rounded-2xl glass p-5 mb-4 flex items-center gap-4 ${overall === 'up' ? 'border-lime/20' : 'border-ember/30'}`}>
      <span class={`w-2.5 h-2.5 rounded-full pulse-dot ${overall === 'up' ? 'bg-lime' : 'bg-ember'}`}></span>
      <span class="text-[15px] font-medium">{overallLabel}</span>
      <div class="ml-auto text-right">
        <div class={`font-mono text-[22px] leading-none tracking-tight ${globalUptime30 !== null && globalUptime30 >= OBJECTIVE ? 'text-lime' : 'text-ember'}`}>
          {globalUptime30 === null ? '—' : `${globalUptime30}%`}
        </div>
        <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mt-1">
          Uptime agregado · {SLO_DAYS}d
        </div>
      </div>
    </div>

    {activeIncidents.length > 0 && (
      <div class="rounded-2xl border border-ember/40 bg-ember/10 p-5 mb-4">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-2 h-2 rounded-full bg-ember pulse-dot"></span>
          <span class="text-[13px] font-medium text-ember">
            {activeIncidents.length === 1 ? 'Incidente activo' : `${activeIncidents.length} incidentes activos`}
          </span>
        </div>
        <div class="space-y-1.5">
          {activeIncidents.map((i) => (
            <div class="flex flex-wrap items-center gap-x-3 text-[13px]">
              <span class="font-medium">{nameById.get(i.monitorId)}</span>
              <span class="font-mono text-[11px] text-ember">en curso · {ago(i.startedAt)}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <div class="mb-12 flex justify-end">
      <span class="text-[11px] font-mono text-ink-300">
        Objetivo SLO {OBJECTIVE}% · ventana {SLO_DAYS} días
      </span>
    </div>

    {cards.length === 0 && (
      <div class="rounded-2xl glass p-12 text-center">
        <p class="text-[13px] font-mono text-ink-300">No hay monitores públicos configurados.</p>
      </div>
    )}

    <!-- Monitores -->
    <div class="space-y-4 mb-20">
      {cards.map((c) => {
        const badge = statusBadge[c.lastStatus ?? 'unknown']
        return (
          <div class="rounded-2xl glass p-6 lift" data-card-id={c.id}>
            <div class="flex flex-wrap items-center gap-3 mb-5">
              <span class={`status-dot w-1.5 h-1.5 rounded-full ${badge.dot} ${c.lastStatus === 'up' ? '' : 'pulse-dot'}`}></span>
              <h2 class="text-[15px] font-medium">{c.name}</h2>
              <span class={`status-label text-[10px] font-mono uppercase tracking-[.15em] px-2.5 py-1 rounded-full border ${badge.cls}`}>
                {badge.label}
              </span>
              {(() => {
                const ssl = sslInfo(c.sslExpiresAt)
                return ssl && (
                  <span class={`text-[10px] font-mono uppercase tracking-[.15em] px-2.5 py-1 rounded-full border ${ssl.cls}`} title="Días hasta la expiración del certificado TLS">
                    {ssl.label}
                  </span>
                )
              })()}
              <span class="last-checked ml-auto text-[11px] font-mono text-ink-300" data-checked-at={c.lastCheckedAt ? c.lastCheckedAt.getTime() : ''}>
                último check {ago(c.lastCheckedAt)}
              </span>
            </div>

            <!-- Latencia en vivo (osciloscopio / EKG) -->
            <div class="mb-5">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300">Latencia en vivo</span>
                <span class="ekg-now font-mono text-[11px] text-ink-100 tabular-nums" data-monitor-id={c.id}>
                  {c.lastResponseMs != null ? `${c.lastResponseMs} ms` : '—'}
                </span>
              </div>
              <div class={`ekg relative h-14 rounded-lg overflow-hidden bg-black/30 ring-1 ring-white/5 ${ekgColor[c.lastStatus ?? 'unknown']}`}
                   data-monitor-id={c.id}
                   data-status={c.lastStatus ?? 'unknown'}
                   data-series={JSON.stringify(c.latency)}>
                <svg class="w-full h-full block" viewBox="0 0 300 56" preserveAspectRatio="none" aria-hidden="true">
                  <line x1="0" y1="28" x2="300" y2="28" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.15"></line>
                  <path class="ekg-glow" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round" stroke-linecap="round" opacity="0.35" vector-effect="non-scaling-stroke"></path>
                  <path class="ekg-trace" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke"></path>
                </svg>
                <span class="ekg-cursor absolute right-0 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-current shadow-[0_0_8px_currentColor]" style="top:50%"></span>
                <span class="ekg-empty absolute inset-0 hidden items-center justify-center text-[10px] font-mono text-ink-400">sin datos aún</span>
              </div>
            </div>

            <!-- 90 días de uptime diario -->
            <div class="flex items-end gap-[2px] h-9 mb-2">
              {c.bars.map((b) => (
                <div
                  class={`flex-1 rounded-[2px] ${barColor(b.pct)} ${b.pct === null ? 'h-2 self-center' : 'h-full'} opacity-90 hover:opacity-100`}
                  title={`${b.day} · ${b.pct === null ? 'sin datos' : `${b.pct}% uptime`}`}
                ></div>
              ))}
            </div>
            <div class="flex justify-between text-[10px] font-mono text-ink-300 mb-5">
              <span>hace {WINDOW_DAYS} días</span>
              <span>hoy</span>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-[13px]">
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mb-1">Uptime {SLO_DAYS}d</div>
                <div class={`font-mono ${c.slo.meetsObjective ? 'text-lime' : 'text-ember'}`}>
                  {c.slo.sliPct === null ? '—' : `${c.slo.sliPct}%`}
                </div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mb-1">Uptime {WINDOW_DAYS}d</div>
                <div class="font-mono text-ink-50">{c.uptime90 === null ? '—' : `${c.uptime90}%`}</div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mb-1">Latencia media · p95</div>
                <div class="font-mono text-ink-50">
                  {c.avgMs30 === null ? '—' : `${c.avgMs30}`}
                  <span class="text-ink-300"> · {c.p95Ms30 === null ? '—' : `${c.p95Ms30}`} ms</span>
                </div>
              </div>
              <div>
                <div class="text-[10px] font-mono uppercase tracking-[.15em] text-ink-300 mb-1">Error budget</div>
                <div class="font-mono text-ink-50">
                  {c.slo.budgetRemainingPct === null
                    ? '—'
                    : `${c.slo.budgetRemainingPct}% (${formatMinutes(c.slo.remainingMinutes)})`}
                  <span class="text-ink-300"> · {healthLabel[c.health]}</span>
                </div>
              </div>
            </div>
          </div>
        )
      })}
    </div>

    <!-- Incidentes recientes -->
    <section class="mb-20">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-ink-400"></span>
        <span>Incidentes resueltos · últimos {WINDOW_DAYS} días</span>
      </div>
      {incidents.length === 0 ? (
        <div class="rounded-2xl glass p-8">
          <p class="text-[13px] font-mono text-ink-200">Sin incidentes registrados en la ventana. 🎉</p>
        </div>
      ) : (
        <div class="rounded-2xl glass divide-y divide-white/5">
          {incidents.map((i) => (
            <div class="p-5 flex flex-wrap items-center gap-3 text-[13px]">
              <span class="font-medium">{nameById.get(i.monitorId)}</span>
              <span class="text-ink-300 font-mono text-[11px]">{fmtDate.format(i.startedAt)}</span>
              <span class="ml-auto font-mono text-[11px] text-ember">
                {i.durationSec != null ? formatMinutes(i.durationSec / 60) : 'duración desconocida'} de caída
              </span>
            </div>
          ))}
        </div>
      )}
    </section>

    <!-- Metodología -->
    <section class="rounded-2xl glass p-8">
      <div class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-4">Cómo se mide</div>
      <div class="grid md:grid-cols-3 gap-6 text-[13px] text-ink-100 leading-relaxed">
        <p>
          Un cron externo sondea cada servicio cada pocos minutos: código HTTP esperado,
          contenido de la respuesta y latencia. Un 200 con la página equivocada también cuenta como caída.
        </p>
        <p>
          El <span class="text-ink-50">SLO</span> es {OBJECTIVE}% de disponibilidad en {SLO_DAYS} días.
          El <span class="text-ink-50">presupuesto de error</span> es el tiempo de caída que ese objetivo
          permite; aquí se muestra cuánto queda.
        </p>
        <p>
          Todo el sistema — motor de checks, incidentes, SLOs y alertas — es una herramienta
          propia construida sobre este mismo sitio. Los datos se sirven tal cual se midieron.
        </p>
      </div>
    </section>

  </div>

  <style>
    /* Barrido tipo osciloscopio: da sensación de "vivo" entre repintados. */
    .ekg::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(90deg, transparent 0%, currentColor 50%, transparent 100%);
      opacity: 0.06;
      width: 40%;
      animation: ekg-sweep 3.5s linear infinite;
    }
    @keyframes ekg-sweep {
      0% { transform: translateX(-60%); }
      100% { transform: translateX(300%); }
    }
    .ekg-trace, .ekg-glow { transition: d 0.6s ease; }
    .ekg-cursor { transition: top 0.6s ease; }
    @media (prefers-reduced-motion: reduce) {
      .ekg::after { animation: none; }
      .ekg-trace, .ekg-glow, .ekg-cursor { transition: none; }
    }
  </style>

  <script>
    const W = 300, H = 56, PAD = 6

    function pathFor(series) {
      if (!series || series.length < 2) return null
      let min = Infinity, max = -Infinity
      for (const v of series) { if (v < min) min = v; if (v > max) max = v }
      const range = Math.max(max - min, 1)
      const n = series.length
      const dx = W / (n - 1)
      let d = '', lastY = H / 2
      for (let i = 0; i < n; i++) {
        const x = i * dx
        const y = PAD + (H - 2 * PAD) * (1 - (series[i] - min) / range)
        d += (i ? 'L' : 'M') + x.toFixed(1) + ' ' + y.toFixed(1) + ' '
        lastY = y
      }
      return { d: d.trim(), lastY }
    }

    function draw(el, series) {
      const trace = el.querySelector('.ekg-trace')
      const glow = el.querySelector('.ekg-glow')
      const cursor = el.querySelector('.ekg-cursor')
      const empty = el.querySelector('.ekg-empty')
      const p = pathFor(series)
      if (!p) {
        trace?.setAttribute('d', '')
        glow?.setAttribute('d', '')
        if (empty) empty.style.display = 'flex'
        return
      }
      if (empty) empty.style.display = 'none'
      trace?.setAttribute('d', p.d)
      glow?.setAttribute('d', p.d)
      if (cursor) cursor.style.top = ((p.lastY / H) * 100).toFixed(2) + '%'

      // Etiqueta de latencia actual (último punto).
      const id = el.getAttribute('data-monitor-id')
      const now = document.querySelector(`.ekg-now[data-monitor-id="${id}"]`)
      if (now) now.textContent = series[series.length - 1] + ' ms'
    }

    function drawAll(seriesById) {
      document.querySelectorAll('.ekg').forEach((el) => {
        const id = el.getAttribute('data-monitor-id')
        let series = seriesById ? seriesById[id] : null
        if (!series) {
          try { series = JSON.parse(el.getAttribute('data-series') || '[]') } catch { series = [] }
        }
        draw(el, series)
      })
    }

    // Dibujo inicial con los datos incrustados por el servidor.
    drawAll(null)

    // Poll cada 30s: trae la latencia fresca y repinta.
    async function refresh() {
      try {
        const res = await fetch('/api/status/latency', { headers: { Accept: 'application/json' } })
        if (!res.ok) return
        const { series } = await res.json()
        const byId = {}
        for (const id in series) byId[id] = (series[id] || []).map((p) => p.ms)
        drawAll(byId)
      } catch { /* red intermitente: reintenta en el próximo tick */ }
    }
    setInterval(refresh, 30_000)
  </script>

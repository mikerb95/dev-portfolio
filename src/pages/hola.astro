---
import BaseLayout from '../layouts/BaseLayout.astro'

// Herramienta personal para armar rápido un mensaje de WhatsApp cuando conozco a alguien
// en una conferencia o evento: número + contexto → link wa.me con presentación breve y
// CTA a la web, listo para abrir sin escribirlo a mano cada vez. No entra al sitemap
// (STATIC_PATHS en sitemap.xml.ts) ni se enlaza desde el nav.
---

<BaseLayout
  title="Hola — CodeByMike"
  description="Herramienta para armar un mensaje de presentación por WhatsApp."
  image="/og-default.png"
>
  <div class="max-w-[720px] mx-auto px-6 md:px-12 pt-32 pb-24">

    <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
      <span class="text-cyan">/hola</span>
      <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
      <span>Presentación rápida</span>
    </div>

    <h1 class="font-sans text-4xl md:text-5xl font-medium tracking-[-.03em] text-mask leading-[1.05] mb-4">
      Recién conociste a alguien.
    </h1>
    <p class="text-[15px] text-ink-100 leading-relaxed max-w-lg mb-10">
      Pon su número y, si quieres, dónde se conocieron. Te arma el mensaje y el link de
      WhatsApp para enviarlo al toque.
    </p>

    <div class="rounded-2xl glass border-grad p-6 space-y-5">
      <label class="block">
        <div class="flex items-center justify-between mb-1.5">
          <span class="text-[11px] font-mono uppercase tracking-wider text-ink-100">Número de WhatsApp</span>
          <span class="text-[10px] font-mono text-ink-300" id="hint-phone"></span>
        </div>
        <input
          id="phone"
          type="tel"
          inputmode="tel"
          required
          placeholder="+57 300 123 4567"
          class="input-base w-full rounded-lg px-3 py-2.5 text-[13px] placeholder:text-ink-300"
        />
      </label>

      <label class="block">
        <span class="text-[11px] font-mono uppercase tracking-wider text-ink-100 mb-1.5 block">
          Dónde se conocieron <span class="text-ink-300 normal-case font-sans">(opcional)</span>
        </span>
        <input
          id="context"
          type="text"
          placeholder="ej: Platzi Conf, la conferencia de hoy"
          class="input-base w-full rounded-lg px-3 py-2.5 text-[13px] placeholder:text-ink-300"
        />
      </label>

      <div>
        <div class="flex items-center gap-2 mb-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan"></span>
          <span class="text-[11px] font-mono uppercase tracking-wider text-ink-100">Mensaje</span>
        </div>
        <p id="preview" class="rounded-lg bg-white/[.03] border border-white/10 px-3 py-2.5 text-[13px] text-ink-100 leading-relaxed whitespace-pre-wrap"></p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 pt-1">
        <a
          id="wa-link"
          href="#"
          target="_blank"
          rel="noopener"
          aria-disabled="true"
          class="flex-1 h-12 rounded-full bg-cyan text-ink-950 text-[14px] font-medium flex items-center justify-center gap-2 hover:brightness-110 transition-all pointer-events-none opacity-40"
        >
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true">
            <path d="M17.5 14.4c-.3-.2-1.7-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.7 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.2-.5-2.3-1.4-.9-.8-1.4-1.7-1.6-2-.2-.3 0-.5.1-.6l.5-.5c.1-.2.2-.3.3-.5 0-.2 0-.4-.1-.5C10.1 9.1 9.6 8 9.4 7.5c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.3.3-1 .9-1 2.3s1 2.7 1.2 2.9c.1.2 2 3.1 4.9 4.3 2.4 1 2.9.8 3.4.8.5 0 1.7-.7 1.9-1.4.2-.7.2-1.2.2-1.4-.1-.2-.3-.3-.6-.4M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2" />
          </svg>
          Abrir en WhatsApp
        </a>
        <button
          id="copy-btn"
          type="button"
          disabled
          class="h-12 px-5 rounded-full border border-white/15 text-[14px] font-medium text-ink-100 hover:border-cyan/50 hover:text-cyan transition-all disabled:opacity-40 disabled:cursor-not-allowed"
        >
          Copiar link
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const phoneInput = document.getElementById('phone') as HTMLInputElement
  const contextInput = document.getElementById('context') as HTMLInputElement
  const hintPhone = document.getElementById('hint-phone') as HTMLSpanElement
  const preview = document.getElementById('preview') as HTMLParagraphElement
  const waLink = document.getElementById('wa-link') as HTMLAnchorElement
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement

  function buildMessage(context: string): string {
    const lugar = context.trim()
    const inicio = lugar ? `Hola! Un gusto conocerte en ${lugar}.` : 'Hola! Un gusto conocerte hoy.'
    return `${inicio} Soy Mike, developer full-stack — te dejo mi web por si quieres ver en qué ando: https://codebymike.tech`
  }

  function digitsOnly(value: string): string {
    return value.replace(/\D/g, '')
  }

  function update() {
    const digits = digitsOnly(phoneInput.value)
    const message = buildMessage(contextInput.value)
    preview.textContent = message

    const valid = digits.length >= 10
    if (phoneInput.value && !valid) {
      hintPhone.textContent = '✗ Incluye código de país, ej: 57...'
      hintPhone.className = 'text-[10px] font-mono text-ember'
    } else if (valid) {
      hintPhone.textContent = '✓ Ok'
      hintPhone.className = 'text-[10px] font-mono text-cyan'
    } else {
      hintPhone.textContent = ''
    }

    if (valid) {
      const url = `https://wa.me/${digits}?text=${encodeURIComponent(message)}`
      waLink.href = url
      waLink.removeAttribute('aria-disabled')
      waLink.classList.remove('pointer-events-none', 'opacity-40')
      copyBtn.disabled = false
      copyBtn.dataset.url = url
    } else {
      waLink.href = '#'
      waLink.setAttribute('aria-disabled', 'true')
      waLink.classList.add('pointer-events-none', 'opacity-40')
      copyBtn.disabled = true
      delete copyBtn.dataset.url
    }
  }

  phoneInput.addEventListener('input', update)
  contextInput.addEventListener('input', update)

  copyBtn.addEventListener('click', async () => {
    const url = copyBtn.dataset.url
    if (!url) return
    await navigator.clipboard.writeText(url)
    const original = copyBtn.textContent
    copyBtn.textContent = '✓ Copiado'
    setTimeout(() => { copyBtn.textContent = original }, 1500)
  })

  update()
</script>

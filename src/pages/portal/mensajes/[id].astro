---
import PortalLayout from '../../../layouts/PortalLayout.astro'
import { markThreadRead, renderBody, threadWithMessages } from '../../../lib/portal/threads'
import { formatDateTime } from '../../../lib/portal/format'

const { user, client } = Astro.locals.portal!

if (user.role === 'billing') return Astro.redirect('/portal')

const id = Number(Astro.params.id)
const result = Number.isInteger(id) ? await threadWithMessages(client.id, id) : null
if (!result) return Astro.rewrite('/404')

const { thread, messages } = result

// Abrir el hilo lo marca leído para ESTE usuario (no para sus compañeros).
await markThreadRead(thread.id, user.id)

const rendered = messages.map((m) => ({
  ...m,
  html: renderBody(m.body),
  displayName: m.authorType === 'admin' ? 'Mike' : (m.userName ?? m.authorName ?? 'Tu equipo'),
}))
---

<PortalLayout title={thread.subject} section="mensajes">
  <a href="/portal/mensajes" class="inline-flex items-center gap-1.5 text-[12px] text-ink-300 hover:text-cyan transition-colors mb-5">
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    Todas las conversaciones
  </a>

  {thread.projectTitle && (
    <p class="mb-4 text-[11px] font-mono uppercase tracking-[.18em] text-ink-300">{thread.projectTitle}</p>
  )}

  <div class="space-y-3 mb-6">
    {rendered.map((m) => (
      <div class:list={['flex gap-3', m.authorType === 'client' && 'flex-row-reverse']}>
        <span
          class:list={[
            'shrink-0 w-7 h-7 rounded-full grid place-items-center text-[10px] font-semibold',
            m.authorType === 'admin' ? 'bg-cyan/15 text-cyan border border-cyan/25' : 'bg-white/[.06] text-ink-100 border border-white/10',
          ]}
        >
          {m.displayName.slice(0, 2).toUpperCase()}
        </span>

        <div class:list={['min-w-0 max-w-[min(78%,560px)]', m.authorType === 'client' && 'text-right']}>
          <div class="flex items-baseline gap-2 mb-1" style={m.authorType === 'client' ? 'justify-content:flex-end' : ''}>
            <span class="text-[12px] font-medium text-ink-100">{m.displayName}</span>
            <span class="text-[10px] font-mono text-ink-300">{formatDateTime(m.createdAt)}</span>
          </div>
          <div
            class:list={[
              'rounded-2xl px-3.5 py-2.5 text-[13.5px] leading-relaxed text-left',
              m.authorType === 'admin'
                ? 'bg-white/[.04] border border-white/[.06] text-ink-100'
                : 'bg-cyan/[.08] border border-cyan/20 text-ink-50',
            ]}
          >
            {/*
              `html` viene de renderBody, que escapa TODO el cuerpo y solo
              después reintroduce un puñado de etiquetas seguras. Sin ese
              escapado previo, esto sería un XSS de libro.
            */}
            <Fragment set:html={m.html} />
          </div>
        </div>
      </div>
    ))}
  </div>

  <form id="reply" class="glass rounded-2xl p-4">
    <label for="body" class="block text-[12px] font-medium text-ink-100 mb-2">Responder</label>
    <textarea
      id="body"
      name="body"
      required
      rows="4"
      maxlength="5000"
      class="input-base w-full resize-y"
      placeholder="Escribe tu respuesta…"
    />
    <div class="mt-3 flex items-center justify-between gap-3">
      <p class="text-[11px] text-ink-300">
        Puedes usar <code class="px-1 rounded bg-white/[.06] font-mono">**negrita**</code>,
        <code class="px-1 rounded bg-white/[.06] font-mono">*cursiva*</code> y
        <code class="px-1 rounded bg-white/[.06] font-mono">`código`</code>.
      </p>
      <button
        type="submit"
        id="send"
        class="shrink-0 h-9 px-4 rounded-full bg-cyan text-ink-950 text-[13px] font-semibold hover:bg-cyan-glow transition-colors disabled:opacity-50"
      >
        Enviar
      </button>
    </div>
    <p id="error" class="hidden mt-2 text-[12px] text-ember" role="alert" />
  </form>
</PortalLayout>

<script define:vars={{ threadId: thread.id }}>
  const form = document.getElementById('reply')
  const errorEl = document.getElementById('error')
  const send = document.getElementById('send')

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    send.disabled = true
    send.textContent = 'Enviando…'

    const body = new FormData(form).get('body')
    try {
      const res = await fetch(`/api/portal/mensajes/${threadId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body }),
      })
      if (res.ok) {
        // Recargar en vez de insertar el mensaje en el DOM: así el hilo se ve
        // exactamente como lo renderiza el servidor, sin una segunda ruta de
        // pintado que mantener en sincronía.
        window.location.reload()
        return
      }
      const data = await res.json().catch(() => ({}))
      errorEl.textContent = data.error ?? 'No se pudo enviar el mensaje.'
      errorEl.classList.remove('hidden')
    } catch {
      errorEl.textContent = 'Error de conexión. Inténtalo de nuevo.'
      errorEl.classList.remove('hidden')
    }
    send.disabled = false
    send.textContent = 'Enviar'
  })
</script>

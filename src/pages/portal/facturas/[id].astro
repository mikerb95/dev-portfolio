---
import PortalLayout from '../../../layouts/PortalLayout.astro'
import { clientInvoice, INVOICE_STATUS_LABELS, isPayable } from '../../../lib/portal/invoices'
import { formatMoney, formatDate } from '../../../lib/portal/format'
import { audit } from '../../../lib/portal/audit'
import { clientIp } from '../../../lib/device-info'

const { user, client } = Astro.locals.portal!

const id = Number(Astro.params.id)
// Un id que no es de este cliente cae aquí como 404, igual que uno inexistente:
// distinguirlos con un 403 ya confirmaría que la factura existe.
const result = Number.isInteger(id) ? await clientInvoice(client.id, id) : null
if (!result) return Astro.rewrite('/404')

const { invoice, items } = result

audit({
  clientId: client.id,
  clientUserId: user.id,
  action: 'invoice.viewed',
  entity: 'invoice',
  entityId: invoice.id,
  ip: clientIp(Astro.request.headers),
})

// `billing` y `owner` pagan; `member` ve la factura pero no la paga.
const canPay = isPayable(invoice.status) && (user.role === 'owner' || user.role === 'billing')

const billing = (() => {
  try {
    return invoice.billingInfo ? (JSON.parse(invoice.billingInfo) as Record<string, string>) : null
  } catch {
    return null
  }
})()

const STATUS_STYLE: Record<string, string> = {
  sent: 'bg-cyan/10 text-cyan border-cyan/25',
  paid: 'bg-lime/10 text-lime border-lime/25',
  overdue: 'bg-ember/10 text-ember border-ember/25',
  void: 'bg-white/[.04] text-ink-300 border-white/10',
}
---

<PortalLayout title={`Factura ${invoice.number}`} section="facturas">
  <div class="flex items-center justify-between mb-5">
    <a href="/portal/facturas" class="inline-flex items-center gap-1.5 text-[12px] text-ink-300 hover:text-cyan transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Todas las facturas
    </a>
    <a
      href={`/api/portal/facturas/${invoice.id}/pdf`}
      class="inline-flex items-center gap-1.5 text-[12px] text-ink-200 hover:text-cyan transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
      Descargar PDF
    </a>
  </div>

  <div class="grid gap-5 lg:grid-cols-[1fr_300px] items-start">
    <div class="glass rounded-2xl p-5 md:p-7">
      <div class="flex flex-wrap items-start justify-between gap-3 pb-5 border-b border-white/5">
        <div>
          <p class="font-mono text-[18px] text-ink-50">{invoice.number}</p>
          {invoice.projectTitle && <p class="mt-0.5 text-[13px] text-ink-200">{invoice.projectTitle}</p>}
        </div>
        <span class:list={['px-2.5 py-1 rounded-full border text-[11px] font-mono', STATUS_STYLE[invoice.status] ?? '']}>
          {INVOICE_STATUS_LABELS[invoice.status]}
        </span>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 py-5 border-b border-white/5">
        <div>
          <p class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300">Emitida</p>
          <p class="mt-1 text-[13px] text-ink-50">{formatDate(invoice.issuedAt)}</p>
        </div>
        <div>
          <p class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300">Vence</p>
          <p class:list={['mt-1 text-[13px]', invoice.status === 'overdue' ? 'text-ember' : 'text-ink-50']}>
            {formatDate(invoice.dueAt)}
          </p>
        </div>
        {invoice.paidAt && (
          <div>
            <p class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300">Pagada</p>
            <p class="mt-1 text-[13px] text-lime">{formatDate(invoice.paidAt)}</p>
          </div>
        )}
      </div>

      <div class="py-5">
        <p class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300 mb-3">Facturado a</p>
        <p class="text-[14px] text-ink-50">{invoice.company ?? invoice.clientName}</p>
        {billing &&
          Object.entries(billing).map(([k, v]) => (
            <p class="text-[12px] text-ink-200">
              <span class="text-ink-300">{k}:</span> {v}
            </p>
          ))}
      </div>

      <div class="overflow-x-auto -mx-5 md:-mx-7 px-5 md:px-7">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-y border-white/5 text-ink-300 text-left text-[11px] font-mono uppercase tracking-wider">
              <th class="py-2.5 font-medium">Concepto</th>
              <th class="py-2.5 font-medium text-right">Cant.</th>
              <th class="py-2.5 font-medium text-right">Precio</th>
              <th class="py-2.5 font-medium text-right">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            {items.map((item) => (
              <tr class="text-ink-100">
                <td class="py-3 pr-3 text-[13px] text-ink-50">{item.description}</td>
                <td class="py-3 text-right font-mono text-[13px] text-ink-200">{item.quantity}</td>
                <td class="py-3 text-right font-mono text-[13px] text-ink-200">
                  {formatMoney(item.unitCents, invoice.currency)}
                </td>
                <td class="py-3 text-right font-mono text-[13px] text-ink-50">
                  {formatMoney(item.totalCents, invoice.currency)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="mt-5 pt-4 border-t border-white/5 space-y-1.5 max-w-[280px] ml-auto">
        <div class="flex justify-between text-[13px]">
          <span class="text-ink-200">Subtotal</span>
          <span class="font-mono text-ink-50">{formatMoney(invoice.subtotalCents, invoice.currency)}</span>
        </div>
        {invoice.taxCents > 0 && (
          <div class="flex justify-between text-[13px]">
            <span class="text-ink-200">Impuestos</span>
            <span class="font-mono text-ink-50">{formatMoney(invoice.taxCents, invoice.currency)}</span>
          </div>
        )}
        <div class="flex justify-between pt-2 border-t border-white/5">
          <span class="text-[14px] font-medium text-ink-50">Total</span>
          <span class="font-mono text-[17px] font-medium text-cyan">{formatMoney(invoice.totalCents, invoice.currency)}</span>
        </div>
      </div>

      {invoice.notes && (
        <div class="mt-6 pt-5 border-t border-white/5">
          <p class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300 mb-2">Notas</p>
          <p class="text-[13px] leading-relaxed text-ink-200 whitespace-pre-line">{invoice.notes}</p>
        </div>
      )}
    </div>

    <div class="space-y-3">
      {invoice.status === 'paid' ? (
        <div class="rounded-2xl border border-lime/25 bg-lime/[.07] p-5 text-center">
          <p class="text-[14px] font-medium text-lime">Factura pagada</p>
          <p class="mt-1 text-[12px] text-ink-200">Recibimos tu pago el {formatDate(invoice.paidAt)}.</p>
        </div>
      ) : invoice.status === 'void' ? (
        <div class="glass rounded-2xl p-5 text-center">
          <p class="text-[14px] text-ink-100">Factura anulada</p>
          <p class="mt-1 text-[12px] text-ink-300">No requiere pago.</p>
        </div>
      ) : canPay ? (
        <div class="glass rounded-2xl p-5">
          <p class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300">A pagar</p>
          <p class="mt-1.5 text-[26px] font-medium tracking-tight text-ink-50 font-mono">
            {formatMoney(invoice.totalCents, invoice.currency)}
          </p>
          {invoice.status === 'overdue' && (
            <p class="mt-1.5 text-[12px] text-ember">Esta factura está vencida.</p>
          )}
          <button
            id="pay"
            data-invoice={invoice.id}
            class="mt-4 w-full h-10 rounded-full bg-cyan text-ink-950 text-[14px] font-semibold hover:bg-cyan-glow transition-colors disabled:opacity-50"
          >
            Pagar ahora
          </button>
          <p id="pay-error" class="hidden mt-2 text-[12px] text-ember" role="alert" />
          <p class="mt-3 text-[11px] leading-relaxed text-ink-300">
            Pago seguro procesado por la pasarela. No guardo datos de tu tarjeta.
          </p>
        </div>
      ) : (
        <div class="glass rounded-2xl p-5">
          <p class="text-[11px] font-mono uppercase tracking-[.18em] text-ink-300">A pagar</p>
          <p class="mt-1.5 text-[26px] font-medium tracking-tight text-ink-50 font-mono">
            {formatMoney(invoice.totalCents, invoice.currency)}
          </p>
          <p class="mt-3 text-[12px] leading-relaxed text-ink-300">
            Tu rol no permite realizar pagos. Avisa a quien lleve la facturación en tu empresa.
          </p>
        </div>
      )}
    </div>
  </div>
</PortalLayout>

<script>
  const btn = document.getElementById('pay') as HTMLButtonElement | null
  if (btn) {
    const errorEl = document.getElementById('pay-error') as HTMLParagraphElement

    btn.addEventListener('click', async () => {
      errorEl.classList.add('hidden')
      btn.disabled = true
      btn.textContent = 'Preparando el pago…'
      try {
        const res = await fetch(`/api/portal/facturas/${btn.dataset.invoice}/pagar`, { method: 'POST' })
        const body = await res.json().catch(() => ({}))
        if (res.ok && body.redirect) {
          window.location.href = body.redirect
          return
        }
        errorEl.textContent = body.error ?? 'No se pudo iniciar el pago.'
        errorEl.classList.remove('hidden')
      } catch {
        errorEl.textContent = 'Error de conexión. Inténtalo de nuevo.'
        errorEl.classList.remove('hidden')
      }
      btn.disabled = false
      btn.textContent = 'Pagar ahora'
    })
  }
</script>

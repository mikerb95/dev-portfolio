---
import PortalAuthLayout from '../../layouts/PortalAuthLayout.astro'
import { getPortalSession } from '../../lib/portal/session'

// Ya autenticado: no tiene sentido mostrar el formulario.
if (await getPortalSession(Astro)) return Astro.redirect('/portal')

// `next` viene del middleware al interceptar una ruta protegida. Solo se acepta
// una ruta interna del portal: un `next` con URL absoluta convertiría el login
// en un redirector abierto para phishing.
const rawNext = Astro.url.searchParams.get('next') ?? ''
const next = /^\/portal(\/|$)/.test(rawNext) && !rawNext.startsWith('//') ? rawNext : '/portal'

const flash = Astro.url.searchParams.get('m')
const MESSAGES: Record<string, string> = {
  'password-set': 'Tu contraseña quedó lista. Ya puedes entrar.',
  'password-reset': 'Tu contraseña se restableció. Entra con la nueva.',
  'session-closed': 'Cerraste sesión correctamente.',
}
const flashMessage = flash ? MESSAGES[flash] : null
---

<PortalAuthLayout title="Entra a tu portal" subtitle="Consulta el estado de tus proyectos, tus facturas y tus documentos.">
  {flashMessage && (
    <div class="mb-5 rounded-xl border border-lime/25 bg-lime/[.07] px-4 py-3 text-[13px] text-lime">
      {flashMessage}
    </div>
  )}

  <form id="form" class="space-y-4" novalidate>
    <input type="hidden" name="next" value={next} />

    <div>
      <label for="email" class="block text-[12px] font-medium text-ink-100 mb-1.5">Correo electrónico</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="username"
        autofocus
        class="input-base w-full"
        placeholder="tu@empresa.com"
      />
    </div>

    <div>
      <div class="flex items-baseline justify-between mb-1.5">
        <label for="password" class="block text-[12px] font-medium text-ink-100">Contraseña</label>
        <a href="/portal/olvide" class="text-[11px] text-ink-300 hover:text-cyan transition-colors">¿La olvidaste?</a>
      </div>
      <input
        type="password"
        id="password"
        name="password"
        required
        autocomplete="current-password"
        class="input-base w-full"
        placeholder="••••••••••"
      />
    </div>

    <p id="error" class="hidden text-[13px] text-ember" role="alert" aria-live="polite"></p>

    <button
      type="submit"
      id="submit"
      class="w-full h-11 rounded-full bg-cyan text-ink-950 text-[14px] font-semibold hover:bg-cyan-glow transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Entrar
    </button>
  </form>

  <p class="mt-6 text-[12px] leading-relaxed text-ink-300">
    El acceso al portal es por invitación. Si aún no tienes cuenta y crees que deberías,
    <a href="/contact" class="text-cyan hover:underline">escríbeme</a>.
  </p>
</PortalAuthLayout>

<script>
  const form = document.getElementById('form') as HTMLFormElement
  const errorEl = document.getElementById('error') as HTMLParagraphElement
  const submit = document.getElementById('submit') as HTMLButtonElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorEl.classList.add('hidden')
    submit.disabled = true
    submit.textContent = 'Entrando…'

    const data = Object.fromEntries(new FormData(form))
    try {
      const res = await fetch('/api/portal/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      })
      const body = await res.json().catch(() => ({}))
      if (res.ok && body.redirect) {
        window.location.href = body.redirect
        return
      }
      errorEl.textContent = body.error ?? 'No se pudo iniciar sesión. Inténtalo de nuevo.'
      errorEl.classList.remove('hidden')
    } catch {
      errorEl.textContent = 'Error de conexión. Revisa tu red e inténtalo de nuevo.'
      errorEl.classList.remove('hidden')
    }
    submit.disabled = false
    submit.textContent = 'Entrar'
  })
</script>

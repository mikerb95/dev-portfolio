---
import PortalAuthLayout from '../../layouts/PortalAuthLayout.astro'
---

<PortalAuthLayout
  title="¿Olvidaste tu contraseña?"
  subtitle="Escribe tu correo y te enviamos un enlace para elegir una nueva."
>
  <form id="form" class="space-y-4" novalidate>
    <div>
      <label for="email" class="block text-[12px] font-medium text-ink-100 mb-1.5">Correo electrónico</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="username"
        autofocus
        class="input-base w-full"
        placeholder="tu@empresa.com"
      />
    </div>

    <button
      type="submit"
      id="submit"
      class="w-full h-11 rounded-full bg-cyan text-ink-950 text-[14px] font-semibold hover:bg-cyan-glow transition-colors disabled:opacity-50"
    >
      Enviarme el enlace
    </button>
  </form>

  <!--
    Confirmación idéntica exista o no la cuenta: si dijéramos "ese correo no
    está registrado", el formulario sería una herramienta para averiguar quiénes
    son mis clientes.
  -->
  <div id="done" class="hidden glass rounded-2xl p-5">
    <p class="text-[14px] leading-relaxed text-ink-100">
      Si ese correo tiene una cuenta en el portal, el enlace ya va en camino.
    </p>
    <p class="mt-3 text-[13px] leading-relaxed text-ink-200">
      Caduca en 30 minutos. Revisa también la carpeta de spam.
    </p>
  </div>

  <p class="mt-6 text-[12px] text-ink-300">
    <a href="/portal/login" class="hover:text-cyan transition-colors">← Volver al login</a>
  </p>
</PortalAuthLayout>

<script>
  const form = document.getElementById('form') as HTMLFormElement
  const done = document.getElementById('done') as HTMLDivElement
  const submit = document.getElementById('submit') as HTMLButtonElement

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    submit.disabled = true
    submit.textContent = 'Enviando…'

    const data = Object.fromEntries(new FormData(form))
    // Se muestra el mismo mensaje pase lo que pase, incluso si el fetch falla:
    // el usuario no debe poder inferir nada del resultado.
    await fetch('/api/portal/reset', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    }).catch(() => {})

    form.classList.add('hidden')
    done.classList.remove('hidden')
  })
</script>

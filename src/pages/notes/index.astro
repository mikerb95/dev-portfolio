---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)

const fmtDate = new Intl.DateTimeFormat('es-CO', { day: 'numeric', month: 'long', year: 'numeric' })
---

<BaseLayout
  title="Notas de ingeniería — CodeByMike"
  description="Artículos técnicos sobre las decisiones detrás de mis herramientas: observabilidad, SLOs, chaos engineering y operación de proyectos."
>
  <div class="max-w-[1280px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Volver
    </a>

    <header class="mb-16">
      <div class="flex items-center gap-3 text-[11px] font-mono uppercase tracking-[.18em] text-ink-200 mb-6">
        <span class="text-cyan">/notes</span>
        <span class="h-px flex-1 bg-gradient-to-r from-white/15 to-transparent max-w-[80px]"></span>
        <span>Notas de ingeniería</span>
      </div>
      <h1 class="text-5xl md:text-6xl font-medium tracking-[-.035em] text-mask leading-[.95] mb-5">
        Decisiones,<br/>no tutoriales.
      </h1>
      <p class="text-[16px] text-ink-100 max-w-xl leading-relaxed">
        El criterio detrás de las <a href="/tools" class="text-cyan hover:underline">herramientas que construyo</a>:
        qué problema había, qué decidí y por qué. Escrito desde código en producción, no desde la teoría.
      </p>
    </header>

    {notes.length === 0 && (
      <div class="rounded-2xl glass p-12 text-center">
        <p class="text-[13px] font-mono text-ink-300">Aún no hay notas publicadas.</p>
      </div>
    )}

    <div class="space-y-4">
      {notes.map((n) => (
        <a href={`/notes/${n.id}`} class="block rounded-2xl glass p-7 lift group">
          <div class="flex flex-wrap items-center gap-3 mb-3">
            <span class="text-[11px] font-mono text-ink-300">{fmtDate.format(n.data.date)}</span>
            {n.data.tags.map((t) => (
              <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full border border-white/10 text-ink-200">{t}</span>
            ))}
          </div>
          <h2 class="text-xl md:text-2xl font-medium tracking-[-.02em] text-ink-50 group-hover:text-cyan transition-colors mb-2">
            {n.data.title}
          </h2>
          <p class="text-[14px] text-ink-200 leading-relaxed max-w-2xl">{n.data.description}</p>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getEntry, render } from 'astro:content'

const { slug } = Astro.params
const note = await getEntry('notes', slug!)

if (!note || note.data.draft) {
  return new Response(null, { status: 404 })
}

const { Content } = await render(note)
const fmtDate = new Intl.DateTimeFormat('es-CO', { day: 'numeric', month: 'long', year: 'numeric' })
---

<BaseLayout title={`${note.data.title} — CodeByMike`} description={note.data.description} type="article">
  <div class="max-w-[820px] mx-auto px-6 md:px-12 pt-32 pb-24">

    <!-- Back -->
    <a href="/notes" class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[.2em] text-ink-300 hover:text-cyan transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Notas
    </a>

    <header class="mb-12">
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class="text-[11px] font-mono text-ink-300">{fmtDate.format(note.data.date)}</span>
        {note.data.tags.map((t) => (
          <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded-full border border-white/10 text-ink-200">{t}</span>
        ))}
      </div>
      <h1 class="text-4xl md:text-5xl font-medium tracking-[-.03em] text-mask leading-[1.05] mb-5">
        {note.data.title}
      </h1>
      <p class="text-[16px] text-ink-200 leading-relaxed">{note.data.description}</p>
    </header>

    <article class="note-prose">
      <Content />
    </article>

    <div class="mt-16 pt-8 border-t border-white/5 flex flex-wrap items-center gap-4">
      <a href="/notes" class="text-[13px] font-mono text-ink-200 hover:text-cyan transition-colors">← Todas las notas</a>
      <a href="/tools" class="ml-auto text-[13px] font-mono text-cyan hover:underline">Ver las herramientas →</a>
    </div>

  </div>
</BaseLayout>

<style is:global>
  .note-prose { color: #c4c4cc; font-size: 16px; line-height: 1.75; }
  .note-prose h2 {
    color: #e7e7ec; font-size: 24px; font-weight: 550; letter-spacing: -0.02em;
    margin: 2.2em 0 0.7em;
  }
  .note-prose h3 { color: #e7e7ec; font-size: 19px; font-weight: 550; margin: 1.8em 0 0.6em; }
  .note-prose p { margin: 0 0 1.2em; }
  .note-prose strong { color: #e7e7ec; font-weight: 600; }
  .note-prose em { font-style: italic; }
  .note-prose a { color: #00f2ff; text-decoration: none; }
  .note-prose a:hover { text-decoration: underline; }
  .note-prose ul, .note-prose ol { margin: 0 0 1.2em; padding-left: 1.4em; }
  .note-prose li { margin: 0.4em 0; }
  .note-prose li::marker { color: #00f2ff; }
  .note-prose code {
    font-family: "JetBrains Mono Variable", ui-monospace, monospace;
    font-size: 0.88em; color: #9bfaff;
    background: rgba(0, 242, 255, 0.07);
    border: 1px solid rgba(0, 242, 255, 0.12);
    border-radius: 6px; padding: 0.1em 0.4em;
  }
  .note-prose pre {
    background: #0e0e12; border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px; padding: 1.1em 1.3em; margin: 0 0 1.4em;
    overflow-x: auto; font-size: 13.5px; line-height: 1.6;
  }
  .note-prose pre code { background: none; border: none; padding: 0; color: inherit; }
  .note-prose blockquote {
    border-left: 2px solid #00f2ff; margin: 0 0 1.2em; padding: 0.2em 0 0.2em 1.2em;
    color: #85858f; font-style: italic;
  }
  .note-prose hr { border: none; border-top: 1px solid rgba(255, 255, 255, 0.06); margin: 2.5em 0; }
</style>

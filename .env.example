# Base de datos Turso
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Credenciales de acceso al panel admin
DEV_USER=tu-usuario-admin
DEV_PASSWORD=tu-contraseña-segura

# Token personal de GitHub (github.com/settings/tokens → scopes: read:user, repo)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_USERNAME=mikerb95

# Secreto para Auth.js: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-32-chars

# URL pública del sitio (Vercel la inyecta automáticamente en producción)
# AUTH_URL=https://your-domain.vercel.app

# Base de datos Turso
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# GitHub OAuth App (github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Tu usuario de GitHub (solo este puede acceder al admin)
GITHUB_ADMIN_USERNAME=your-github-username

# Token personal de GitHub para leer repos (github.com/settings/tokens)
GITHUB_TOKEN=your-github-personal-access-token

# Secreto para Auth.js: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-32-chars

# URL pública del sitio (Vercel la inyecta automáticamente en producción)
# AUTH_URL=https://your-domain.vercel.app

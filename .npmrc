# @auth/core declara un peerOptional sobre @simplewebauthn/browser@^9 (para su
# provider de passkeys, que este proyecto NO usa). Nosotros integramos WebAuthn
# con los paquetes standalone @simplewebauthn/*@13. Ese choque es solo de un peer
# opcional, así que relajamos la resolución estricta para que install/CI pasen.
legacy-peer-deps=true
